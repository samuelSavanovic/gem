# compiler/builtins.gem — single source of truth for the language's
# builtin function set. Maps each Gem-visible name to the C symbol the
# runtime exports for it.
#
# Imported by:
#   - compiler/codegen.gem — emits `gem_make_fn(<c_symbol>, NULL)` for
#     builtin references and direct calls.
#   - lsp/completion.gem — surfaces the names as completion items so the
#     LSP doesn't fork the list and drift.
#
# When adding a new builtin: edit this table only. CLAUDE.md's
# "Adding a New Builtin" checklist still applies for the runtime + spec
# updates, but the codegen + LSP halves are now driven from this map.

let BUILTIN_FNS = {
  print: "gem_print",
  error: "gem_error_fn",
  len: "gem_len_fn",
  type: "gem_type_fn",
  to_string: "gem_to_string_fn",
  push: "gem_push_fn",
  pcall: "gem_pcall_fn",
  keys: "gem_keys_fn",
  str_replace: "gem_str_replace_fn",
  has_key: "gem_has_key_fn",
  substr: "gem_substr_fn",
  chr: "gem_chr_fn",
  ord: "gem_ord_fn",
  to_int: "gem_to_int_fn",
  to_float: "gem_to_float_fn",
  buf_new: "gem_buf_new_fn",
  buf_push: "gem_buf_push_fn",
  build_string: "gem_build_string_fn",
  spawn: "gem_spawn_builtin",
  send: "gem_send_builtin",
  receive: "gem_receive_builtin",
  self: "gem_self_builtin",
  monitor: "gem_monitor_builtin",
  spawn_monitor: "gem_spawn_monitor_builtin",
  register: "gem_register_builtin",
  whereis: "gem_whereis_builtin",
  time_ms: "gem_time_ms_builtin",
  kill: "gem_exit_builtin",
  link: "gem_link_builtin",
  unlink: "gem_unlink_builtin",
  spawn_link: "gem_spawn_link_builtin",
  process_flag: "gem_process_flag_builtin",
  make_ref: "gem_make_ref_builtin",
  sleep: "gem_sleep_builtin",
  send_after: "gem_send_after_builtin",
  cancel_timer: "gem_cancel_timer_builtin",
  processes: "gem_processes_builtin",
  process_info: "gem_process_info_builtin",
  read_file: "gem_read_file_fn",
  write_file: "gem_write_file_fn",
  delete: "gem_delete_fn",
  pop: "gem_pop_fn",
  values: "gem_values_fn",
  eprint: "gem_eprint_fn",
  exit: "gem_exit_process_fn",
  argv: "gem_argv_fn",
  sort: "gem_sort_fn",
  floor: "gem_floor_fn",
  ceil: "gem_ceil_fn",
  round: "gem_round_fn",
  abs: "gem_abs_fn",
  pow: "gem_pow_fn",
  sqrt: "gem_sqrt_fn",
  random: "gem_random_fn",
  append_file: "gem_append_file_fn",
  getenv: "gem_getenv_fn",
  input: "gem_input_fn",
  read_stdin: "gem_read_stdin_fn",
  write_stdout: "gem_write_stdout_fn",
  insert: "gem_insert_fn",
  remove_at: "gem_remove_at_fn",
  band: "gem_band_fn",
  bor: "gem_bor_fn",
  bxor: "gem_bxor_fn",
  bnot: "gem_bnot_fn",
  bshl: "gem_bshl_fn",
  bshr: "gem_bshr_fn",
  file_exists: "gem_file_exists_fn",
  dirname: "gem_dirname_fn",
  path_join: "gem_path_join_fn",
  normalize_path: "gem_normalize_path_fn",
  remove_file: "gem_remove_file_fn",
  mkdir: "gem_mkdir_fn",
  list_dir: "gem_list_dir_fn",
  is_dir: "gem_is_dir_fn",
  exec: "gem_exec_fn",
  tcp_connect: "gem_tcp_connect_fn",
  tcp_listen: "gem_tcp_listen_fn",
  tcp_accept: "gem_tcp_accept_fn",
  tcp_read: "gem_tcp_read_fn",
  tcp_write: "gem_tcp_write_fn",
  tcp_close: "gem_tcp_close_fn",
  epoch_ms: "gem_epoch_ms_fn",
  format_time: "gem_format_time_fn",
  format_time_local: "gem_format_time_local_fn",
  sqlite_open: "gem_sqlite_open_fn",
  sqlite_close: "gem_sqlite_close_fn",
  sqlite_exec: "gem_sqlite_exec_fn",
  sqlite_query: "gem_sqlite_query_fn",
  sqlite_last_insert_id: "gem_sqlite_last_insert_id_fn",
  sqlite_changes: "gem_sqlite_changes_fn",
  __table_key_at: "gem_table_key_at_fn",
  __table_val_at: "gem_table_val_at_fn"
}

# User-visible builtin names, sorted lexicographically. The double-underscore
# entries (`__table_key_at`, `__table_val_at`) are codegen-internal — the
# parser doesn't rewrite them; users would have to type the underscores
# themselves to reference them. They're filtered out so completion doesn't
# offer them.
fn user_builtin_names()
  let out = []
  for k, _ in BUILTIN_FNS
    if not (len(k) >= 2 and substr(k, 0, 2) == "__")
      push(out, k)
    end
  end
  sort(out)
  out
end

let BUILTIN_NAMES = user_builtin_names()

export BUILTIN_FNS, BUILTIN_NAMES
