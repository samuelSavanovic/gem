# Code generator — compiles AST to C source code.
# Faithful port of bootstrap/gem.py CodeGen class.
# Uses closure-based pattern: fn make_codegen() returns a table of methods.

load "liveness" (compute_live_at_backedge, compute_live_for_pt_loops_in_stmts)

# ─── String helpers ─────────────────────────────────────────────

fn escape_c_string(s)
  let cr = chr(13)
  let b = buf_new()
  for i = 0, len(s)
    let ch = s[i]
    if ch == "\\"
      buf_push(b, "\\\\")
    elif ch == "\""
      buf_push(b, "\\\"")
    elif ch == "\n"
      buf_push(b, "\\n")
    elif ch == cr
      buf_push(b, "\\r")
    elif ch == "\t"
      buf_push(b, "\\t")
    elif ord(ch) == 0
      buf_push(b, "\\0")
    else
      buf_push(b, ch)
    end
  end
  buf_str(b)
end

fn repeat_str(s, n)
  let b = buf_new()
  for i = 0, n
    buf_push(b, s)
  end
  buf_str(b)
end

fn pad_for(indent)
  repeat_str("    ", indent)
end

fn format_float(val)
  let s = to_string(val)
  # Ensure the string has a decimal point
  let has_dot = false
  for i = 0, len(s)
    if s[i] == "."
      has_dot = true
    end
  end
  if not has_dot
    s = s + ".0"
  end
  s
end

# ─── Array/set helpers ────────────────────────────────────────────

fn set_add(s, val)
  if s[val] != true
    s[val] = true
  end
end

fn set_contains(s, val)
  s[val] == true
end

fn set_union(a, b)
  let result = {}
  for k, _ in a
    result[k] = true
  end
  for k, _ in b
    result[k] = true
  end
  result
end

fn set_intersect(a, b)
  let result = {}
  for k, _ in a
    if b[k] == true
      result[k] = true
    end
  end
  result
end

fn sorted_array_to_set(arr)
  let s = {}
  for item in arr
    s[item] = true
  end
  s
end

fn is_node(node, tag)
  type(node) == "table" and node.tag == tag
end

# ─── Codegen constructor ───────────────────────────────────────

fn collect_block_lets(stmt, result)
  if is_node(stmt, "block")
    for j = 0, len(stmt.stmts)
      if is_node(stmt.stmts[j], "let")
        set_add(result, stmt.stmts[j].name)
      end
    end
  end
end

fn collect_top_let_names(stmts, result)
  for i = 0, len(stmts)
    let s = stmts[i]
    if is_node(s, "let")
      set_add(result, s.name)
    end
    collect_block_lets(s, result)
  end
end

# Collects all let-bound names anywhere in this fn body (descending through
# control flow), but not into nested anon_fn or fn_def. Used by compile_fn
# to over-approximate the set of locally-shadowed names — anything in here
# must not be confused with a top-level boxed global of the same name.
let collect_shadow_lets_in_node = nil
let collect_shadow_lets_in_stmts = nil

collect_shadow_lets_in_stmts = fn(stmts, result)
  if stmts == nil
    return nil
  end
  for i = 0, len(stmts)
    collect_shadow_lets_in_node(stmts[i], result)
  end
end

collect_shadow_lets_in_node = fn(node, result)
  if node == nil
    return nil
  end
  if type(node) != "table"
    return nil
  end
  if node.tag == nil
    return nil
  end
  if node.tag == "anon_fn" or node.tag == "fn_def"
    return nil
  end
  if node.tag == "let"
    set_add(result, node.name)
    return nil
  end
  if node.tag == "block"
    collect_shadow_lets_in_stmts(node.stmts, result)
    return nil
  end
  if node.tag == "if"
    collect_shadow_lets_in_stmts(node.then, result)
    if node.elifs != nil
      for ei in node.elifs
        collect_shadow_lets_in_stmts(ei.body, result)
      end
    end
    collect_shadow_lets_in_stmts(node.else, result)
    return nil
  end
  if node.tag == "while"
    collect_shadow_lets_in_stmts(node.body, result)
    return nil
  end
  if node.tag == "for" or node.tag == "for_kv" or node.tag == "for_range"
    if node.var != nil
      set_add(result, node.var)
    end
    if node.kvar != nil
      set_add(result, node.kvar)
    end
    if node.vvar != nil
      set_add(result, node.vvar)
    end
    if node.name != nil and (node.tag == "for" or node.tag == "for_range")
      set_add(result, node.name)
    end
    collect_shadow_lets_in_stmts(node.body, result)
    return nil
  end
  if node.tag == "match"
    if node.whens != nil
      for w in node.whens
        if w.bindings != nil
          for b in w.bindings
            if type(b) == "table" and b.tag == "var" and b.name != nil
              set_add(result, b.name)
            end
          end
        end
        collect_shadow_lets_in_stmts(w.body, result)
      end
    end
    collect_shadow_lets_in_stmts(node.else, result)
    return nil
  end
  if node.tag == "receive_match"
    if node.arms != nil
      for a in node.arms
        if a.pattern != nil and a.pattern.bindings != nil
          for b in a.pattern.bindings
            if type(b) == "table" and b.tag == "var" and b.name != nil
              set_add(result, b.name)
            end
          end
        end
        collect_shadow_lets_in_stmts(a.body, result)
      end
    end
    if node.after_body != nil
      collect_shadow_lets_in_stmts(node.after_body, result)
    end
    return nil
  end
  nil
end

let collect_shadow_lets_in_fn = nil
collect_shadow_lets_in_fn = fn(stmts, result)
  collect_shadow_lets_in_stmts(stmts, result)
end

# ─── Arm-merged let lift pre-pass ──────────────────────────────
#
# Rewrites
#
#   if c then let X = a else let X = b end
#   ... use(X)
#
# to
#
#   let X = nil
#   if c then X = a else X = b end
#   ... use(X)
#
# The transform makes a name introduced at the top of EVERY arm of an
# `if` / `match` / `receive_match` visible after the construct, with a
# stable C local that the process-tail rescue can address by name.
#
# Conditions for a hoist:
#   - The construct's "exit arms" all top-level-declare X. For `if`, that's
#     the then arm AND the else arm (no lift on else-less if). For `match`,
#     all `when` arms (and the `else` arm if present). For `receive_match`,
#     all arms (and `after_body` if present — `after_ms` defines a real
#     timeout path).
#   - X is not already in the enclosing scope (params or sibling lets in
#     this block). We over-skip on shadowing rather than risk mutating the
#     wrong binding.
#
# Walk is bottom-up: arms are lifted before the enclosing construct, so a
# nested `if`/`match` whose lift inserts a top-level `let X = nil` into an
# arm becomes visible to the outer intersection check.

fn arm_top_let_names(stmts)
  let r = {}
  if stmts == nil
    return r
  end
  for s in stmts
    if is_node(s, "let") and s.name != nil
      r[s.name] = true
    end
  end
  r
end

fn arm_intersect_if_node(node)
  if node.else == nil
    return {}
  end
  let merged = arm_top_let_names(node.then)
  if node.elifs != nil
    for ei in node.elifs
      merged = set_intersect(merged, arm_top_let_names(ei.body))
    end
  end
  set_intersect(merged, arm_top_let_names(node.else))
end

fn arm_intersect_match_node(node)
  if node.whens == nil or len(node.whens) == 0
    if node.else != nil
      return arm_top_let_names(node.else)
    end
    return {}
  end
  let merged = arm_top_let_names(node.whens[0].body)
  let i = 1
  while i < len(node.whens)
    merged = set_intersect(merged, arm_top_let_names(node.whens[i].body))
    i += 1
  end
  if node.else != nil
    merged = set_intersect(merged, arm_top_let_names(node.else))
  end
  merged
end

fn arm_intersect_receive_node(node)
  let arms = node.arms
  if arms == nil or len(arms) == 0
    if node.after_body != nil
      return arm_top_let_names(node.after_body)
    end
    return {}
  end
  let merged = arm_top_let_names(arms[0].body)
  let i = 1
  while i < len(arms)
    merged = set_intersect(merged, arm_top_let_names(arms[i].body))
    i += 1
  end
  if node.after_body != nil
    merged = set_intersect(merged, arm_top_let_names(node.after_body))
  end
  merged
end

# Convert top-level `let X = expr` inside `stmts` to `assign X = expr` for
# each X in `names`. Mutates the AST node tag in place.
fn rewrite_arm_lets_to_assigns(stmts, names)
  if stmts == nil
    return nil
  end
  for s in stmts
    if is_node(s, "let") and s.name != nil and names[s.name] == true
      s.tag = "assign"
    end
  end
end

let lift_arm_lets_node = nil
let lift_arm_lets_stmts = nil

lift_arm_lets_stmts = fn(stmts, scope)
  if stmts == nil
    return nil
  end
  # Block-level scope: parent scope plus all top-level lets currently in
  # this block (a name declared anywhere in this block is "taken"). This
  # blocks hoists that would shadow a sibling let or duplicate a name.
  let block_scope = set_union(scope, {})
  for s in stmts
    if is_node(s, "let") and s.name != nil
      set_add(block_scope, s.name)
    end
  end

  let i = 0
  while i < len(stmts)
    let s = stmts[i]
    # Recurse into children FIRST. Bottom-up lifting lets a nested
    # if/match insert a top-level `let X = nil` into an arm, which then
    # makes the outer construct intersect-eligible for X.
    lift_arm_lets_node(s, block_scope)

    let intersect = nil
    if is_node(s, "if")
      intersect = arm_intersect_if_node(s)
    elif is_node(s, "match")
      intersect = arm_intersect_match_node(s)
    elif is_node(s, "receive_match")
      intersect = arm_intersect_receive_node(s)
    end

    if intersect != nil
      let to_hoist = []
      for n, _ in intersect
        if not set_contains(block_scope, n)
          push(to_hoist, n)
        end
      end
      if len(to_hoist) > 0
        let hoist_set = {}
        for n in to_hoist
          set_add(hoist_set, n)
        end
        if is_node(s, "if")
          rewrite_arm_lets_to_assigns(s.then, hoist_set)
          if s.elifs != nil
            for ei in s.elifs
              rewrite_arm_lets_to_assigns(ei.body, hoist_set)
            end
          end
          rewrite_arm_lets_to_assigns(s.else, hoist_set)
        elif is_node(s, "match")
          if s.whens != nil
            for w in s.whens
              rewrite_arm_lets_to_assigns(w.body, hoist_set)
            end
          end
          rewrite_arm_lets_to_assigns(s.else, hoist_set)
        else
          if s.arms != nil
            for a in s.arms
              rewrite_arm_lets_to_assigns(a.body, hoist_set)
            end
          end
          if s.after_body != nil
            rewrite_arm_lets_to_assigns(s.after_body, hoist_set)
          end
        end
        for n in to_hoist
          insert(stmts, i, {tag: "let", name: n, value: {tag: "nil"}, line: s.line})
          set_add(block_scope, n)
          i += 1
        end
      end
    end
    i += 1
  end
end

lift_arm_lets_node = fn(node, scope)
  if node == nil
    return nil
  end
  if type(node) != "table"
    return nil
  end
  if node.tag == nil
    return nil
  end
  if node.tag == "anon_fn" or node.tag == "fn_def"
    let params = node.params
    let inner_scope = {}
    if params != nil
      for p in params
        set_add(inner_scope, p)
      end
    end
    if node.rest_param != nil
      set_add(inner_scope, node.rest_param)
    end
    lift_arm_lets_stmts(node.body, inner_scope)
    if node.defaults != nil
      for d in node.defaults
        if d != nil
          lift_arm_lets_node(d, scope)
        end
      end
    end
    return nil
  end
  if node.tag == "if"
    lift_arm_lets_node(node.cond, scope)
    lift_arm_lets_stmts(node.then, scope)
    if node.elifs != nil
      for ei in node.elifs
        lift_arm_lets_stmts(ei.body, scope)
      end
    end
    lift_arm_lets_stmts(node.else, scope)
    return nil
  end
  if node.tag == "while"
    lift_arm_lets_node(node.cond, scope)
    lift_arm_lets_stmts(node.body, scope)
    return nil
  end
  if node.tag == "for" or node.tag == "for_kv" or node.tag == "for_range"
    let body_scope = set_union(scope, {})
    if node.var != nil
      set_add(body_scope, node.var)
    end
    if node.kvar != nil
      set_add(body_scope, node.kvar)
    end
    if node.vvar != nil
      set_add(body_scope, node.vvar)
    end
    if node.name != nil and (node.tag == "for" or node.tag == "for_range")
      set_add(body_scope, node.name)
    end
    # Recurse into iter expressions / range bounds (may contain anon_fns).
    for k, v in node
      if k != "tag" and k != "body" and type(v) == "table"
        lift_arm_lets_node(v, scope)
      end
    end
    lift_arm_lets_stmts(node.body, body_scope)
    return nil
  end
  if node.tag == "match"
    lift_arm_lets_node(node.target, scope)
    if node.whens != nil
      for w in node.whens
        let arm_scope = set_union(scope, {})
        if w.bindings != nil
          for b in w.bindings
            if type(b) == "table" and b.tag == "var" and b.name != nil
              set_add(arm_scope, b.name)
            end
          end
        end
        lift_arm_lets_stmts(w.body, arm_scope)
      end
    end
    lift_arm_lets_stmts(node.else, scope)
    return nil
  end
  if node.tag == "receive_match"
    if node.arms != nil
      for a in node.arms
        let arm_scope = set_union(scope, {})
        if a.pattern != nil and a.pattern.bindings != nil
          for b in a.pattern.bindings
            if type(b) == "table" and b.tag == "var" and b.name != nil
              set_add(arm_scope, b.name)
            end
          end
        end
        lift_arm_lets_stmts(a.body, arm_scope)
      end
    end
    if node.after_body != nil
      lift_arm_lets_stmts(node.after_body, scope)
    end
    return nil
  end
  if node.tag == "block"
    lift_arm_lets_stmts(node.stmts, scope)
    return nil
  end
  # Generic recursion for non-control-flow nodes (lets, assigns, calls,
  # expressions). Catches anon_fns embedded in expression positions.
  for k, v in node
    if k != "tag" and type(v) == "table"
      let vks = keys(v)
      if len(vks) > 0 and type(vks[0]) == "int"
        for child in v
          if type(child) == "table"
            lift_arm_lets_node(child, scope)
          end
        end
      else
        lift_arm_lets_node(v, scope)
      end
    end
  end
  nil
end

fn lift_arm_lets_in_fn(fn_node)
  let scope = {}
  if fn_node.params != nil
    for p in fn_node.params
      set_add(scope, p)
    end
  end
  if fn_node.rest_param != nil
    set_add(scope, fn_node.rest_param)
  end
  lift_arm_lets_stmts(fn_node.body, scope)
  if fn_node.defaults != nil
    for d in fn_node.defaults
      if d != nil
        lift_arm_lets_node(d, scope)
      end
    end
  end
end

# Top-level wrapper so callers from inside nested closures (compile()) can
# invoke the lift pass via a plain fn_def (gem_fn_*) rather than capturing
# the mutually-recursive `lift_arm_lets_stmts` / `lift_arm_lets_node` lets.
# The latter are boxed at module scope (mutual fwd-decls), and capturing a
# module-level boxed var from inside a non-top-level closure tickles a
# pre-existing bug in the `&` capture path.
fn lift_arm_lets_top_stmts(stmts)
  lift_arm_lets_stmts(stmts, {})
end

# ─── Process-tail `while true` tagging ──────────────────────────
#
# Walks every fn_def body and the top-level program, tagging each
# `while true` node that lies in a process-tail context with
# `process_tail = true` directly on the AST node. The codegen
# (`compile_while`) consults this flag to decide whether to emit the
# arena rescue+reset at the back-edge.
#
# Process-tail context: directly inside a fn in `process_tail_fns`, inside
# the top-level program, or inside the body of an anon_fn passed as
# arg[0] to spawn / spawn_link / spawn_monitor (each a fresh process root).
#
# Walker semantics: descend through if/match/while/for/etc. preserving the
# current is_pt flag; reset is_pt=false at anon_fn boundaries (a closure
# invoked from a non-tail context holds caller-frame state); reset is_pt=true
# when descending into a spawn-arg anon_fn body.

fn is_spawn_callee_name(name)
  name == "spawn" or name == "spawn_link" or name == "spawn_monitor"
end

let walk_for_tagging_node = nil
let walk_for_tagging_stmts = nil

walk_for_tagging_stmts = fn(stmts, is_pt)
  if stmts == nil
    return nil
  end
  for s in stmts
    walk_for_tagging_node(s, is_pt)
  end
end

walk_for_tagging_node = fn(node, is_pt)
  if node == nil
    return nil
  end
  if type(node) != "table"
    return nil
  end
  if node.tag == nil
    return nil
  end
  if node.tag == "fn_def"
    # Top-level fn_defs are walked separately by tag_process_tail_while_loops;
    # parser disallows nested fn_def. Skip.
    return nil
  end
  if node.tag == "anon_fn"
    # Generic anon_fn (not at spawn arg[0]): not a process-tail context.
    walk_for_tagging_stmts(node.body, false)
    if node.defaults != nil
      for d in node.defaults
        if d != nil
          walk_for_tagging_node(d, is_pt)
        end
      end
    end
    return nil
  end
  if node.tag == "while" and is_pt
    node.process_tail = true
    walk_for_tagging_stmts(node.body, is_pt)
    return nil
  end
  if node.tag == "call" and is_node(node.func, "var") and is_spawn_callee_name(node.func.name)
    if node.args != nil and len(node.args) > 0 and is_node(node.args[0], "anon_fn")
      let anon = node.args[0]
      walk_for_tagging_stmts(anon.body, true)
      if anon.defaults != nil
        for d in anon.defaults
          if d != nil
            walk_for_tagging_node(d, is_pt)
          end
        end
      end
      let i = 1
      while i < len(node.args)
        walk_for_tagging_node(node.args[i], is_pt)
        i += 1
      end
      return nil
    end
  end
  # Generic recursion over child nodes/arrays.
  for k, v in node
    if k != "tag" and type(v) == "table"
      let vks = keys(v)
      if len(vks) > 0 and type(vks[0]) == "int"
        let vi = 0
        while vi < len(v)
          if type(v[vi]) == "table"
            walk_for_tagging_node(v[vi], is_pt)
          end
          vi += 1
        end
      else
        walk_for_tagging_node(v, is_pt)
      end
    end
  end
  nil
end

let tag_process_tail_while_loops = nil
tag_process_tail_while_loops = fn(fn_defs, top_stmts, process_tail_fns)
  for fd in fn_defs
    let is_pt = process_tail_fns[fd.name] == true
    walk_for_tagging_stmts(fd.body, is_pt)
  end
  # Top-level statements run in `gem_main_pid` and are PT-tagged uniformly
  # with fn bodies. (Earlier the runtime shared strings allocated in main's
  # arena across processes via a fast-path in `gem_deep_copy_internal`, which
  # would dangle if main's arena got reset; that fast-path is gone, so a
  # `while true` accept loop at top level resets main's arena like any other
  # PT loop.)
  walk_for_tagging_stmts(top_stmts, true)
end

fn make_codegen(source_name)
  let functions = []
  let forward_decls = []
  let extern_c_decls = []
  let tmp_counter = 0
  let ic_counter = 0
  let ic_init = chr(123) + "0" + chr(125)
  let anon_counter = 0
  let defined_fns = {}
  let builtin_fns = {
    print: "gem_print",
    error: "gem_error_fn",
    len: "gem_len_fn",
    type: "gem_type_fn",
    to_string: "gem_to_string_fn",
    push: "gem_push_fn",
    pcall: "gem_pcall_fn",
    keys: "gem_keys_fn",
    str_replace: "gem_str_replace_fn",
    has_key: "gem_has_key_fn",
    substr: "gem_substr_fn",
    chr: "gem_chr_fn",
    ord: "gem_ord_fn",
    to_int: "gem_to_int_fn",
    to_float: "gem_to_float_fn",
    buf_new: "gem_buf_new_fn",
    buf_push: "gem_buf_push_fn",
    buf_str: "gem_buf_str_fn",
    build_string: "gem_build_string_fn",
    spawn: "gem_spawn_builtin",
    send: "gem_send_builtin",
    receive: "gem_receive_builtin",
    self: "gem_self_builtin",
    monitor: "gem_monitor_builtin",
    spawn_monitor: "gem_spawn_monitor_builtin",
    register: "gem_register_builtin",
    whereis: "gem_whereis_builtin",
    time_ms: "gem_time_ms_builtin",
    kill: "gem_exit_builtin",
    link: "gem_link_builtin",
    unlink: "gem_unlink_builtin",
    spawn_link: "gem_spawn_link_builtin",
    process_flag: "gem_process_flag_builtin",
    make_ref: "gem_make_ref_builtin",
    sleep: "gem_sleep_builtin",
    send_after: "gem_send_after_builtin",
    cancel_timer: "gem_cancel_timer_builtin",
    processes: "gem_processes_builtin",
    process_info: "gem_process_info_builtin",
    read_file: "gem_read_file_fn",
    write_file: "gem_write_file_fn",
    delete: "gem_delete_fn",
    pop: "gem_pop_fn",
    values: "gem_values_fn",
    eprint: "gem_eprint_fn",
    exit: "gem_exit_process_fn",
    argv: "gem_argv_fn",
    sort: "gem_sort_fn",
    floor: "gem_floor_fn",
    ceil: "gem_ceil_fn",
    round: "gem_round_fn",
    abs: "gem_abs_fn",
    pow: "gem_pow_fn",
    sqrt: "gem_sqrt_fn",
    random: "gem_random_fn",
    append_file: "gem_append_file_fn",
    getenv: "gem_getenv_fn",
    input: "gem_input_fn",
    insert: "gem_insert_fn",
    remove_at: "gem_remove_at_fn",
    band: "gem_band_fn",
    bor: "gem_bor_fn",
    bxor: "gem_bxor_fn",
    bnot: "gem_bnot_fn",
    bshl: "gem_bshl_fn",
    bshr: "gem_bshr_fn",
    file_exists: "gem_file_exists_fn",
    dirname: "gem_dirname_fn",
    path_join: "gem_path_join_fn",
    normalize_path: "gem_normalize_path_fn",
    remove_file: "gem_remove_file_fn",
    mkdir: "gem_mkdir_fn",
    list_dir: "gem_list_dir_fn",
    is_dir: "gem_is_dir_fn",
    exec: "gem_exec_fn",
    tcp_connect: "gem_tcp_connect_fn",
    tcp_listen: "gem_tcp_listen_fn",
    tcp_accept: "gem_tcp_accept_fn",
    tcp_read: "gem_tcp_read_fn",
    tcp_write: "gem_tcp_write_fn",
    tcp_close: "gem_tcp_close_fn",
    epoch_ms: "gem_epoch_ms_fn",
    format_time: "gem_format_time_fn",
    format_time_local: "gem_format_time_local_fn",
    sqlite_open: "gem_sqlite_open_fn",
    sqlite_close: "gem_sqlite_close_fn",
    sqlite_exec: "gem_sqlite_exec_fn",
    sqlite_query: "gem_sqlite_query_fn",
    sqlite_last_insert_id: "gem_sqlite_last_insert_id_fn",
    sqlite_changes: "gem_sqlite_changes_fn",
    __table_key_at: "gem_table_key_at_fn",
    __table_val_at: "gem_table_val_at_fn"
  }
  let builtins = {}
  for k, _ in builtin_fns
    builtins[k] = true
  end
  let boxed_vars = {}
  let top_level_vars = {}
  let top_level_boxed = {}
  let in_top_level = false
  let local_names = {}
  # Subset of `local_names` whose names have an addressable C local at the
  # current fn's top-level scope (params + top-of-body lets, or top-level
  # vars at module scope). Used by `filter_live_for_rescue` to distinguish
  # arm-lets (declared inside a nested if/match block — block-scoped, not
  # addressable from the enclosing while's back-edge) from fn-scope locals.
  let fn_scope_locals = {}
  let tco_fn_name = nil
  let tco_params = nil
  let tco_captured = nil
  let tco_is_process_tail = false
  let process_tail_fns = {}
  let append_buf_vars = {}

  # ─── Helpers ──

  let tmp = fn()
    tmp_counter += 1
    "_t{tmp_counter}"
  end

  let anon_name = fn()
    anon_counter += 1
    "_anon_{anon_counter}"
  end

  let mangle = fn(name)
    "gem_v_{name}"
  end

  # ─── Free variable analysis ──

  let collect_free_vars = nil
  let collect_free_node = nil

  collect_free_node = fn(node, defined, free)
    if node == nil
      return nil
    end
    if type(node) != "table"
      return nil
    end
    if node.tag == nil
      return nil
    end

    match node
    when {tag: "var", name: name}
      if not set_contains(defined, name) and (not set_contains(builtins, name) or set_contains(local_names, name)) and not set_contains(defined_fns, name)
        set_add(free, name)
      end
    when {tag: "let", value: value}
      collect_free_node(value, defined, free)
    when {tag: "assign", name: name, value: value}
      if not set_contains(defined, name) and (not set_contains(builtins, name) or set_contains(local_names, name)) and not set_contains(defined_fns, name)
        set_add(free, name)
      end
      collect_free_node(value, defined, free)
    when {tag: "anon_fn", params: params, rest_param: rest_param, body: body}
      let inner_defined = set_union(defined, sorted_array_to_set(params))
      if rest_param != nil
        set_add(inner_defined, rest_param)
      end
      let inner_free = collect_free_vars(body, inner_defined)
      if node.defaults != nil
        for d in node.defaults
          if d != nil
            collect_free_node(d, inner_defined, inner_free)
          end
        end
      end
      for ifk, _ in inner_free
        set_add(free, ifk)
      end
    when {tag: "fn_def"}
      # Named functions are global — skip
    when {tag: "if", cond: cond, then: thens, else: el}
      collect_free_node(cond, defined, free)
      let d = set_union(defined, {})
      for i = 0, len(thens)
        collect_free_node(thens[i], d, free)
        if is_node(thens[i], "let")
          set_add(d, thens[i].name)
        end
      end
      if el != nil
        d = set_union(defined, {})
        for i = 0, len(el)
          collect_free_node(el[i], d, free)
          if is_node(el[i], "let")
            set_add(d, el[i].name)
          end
        end
      end
    when {tag: "while", cond: cond, body: body}
      collect_free_node(cond, defined, free)
      let d = set_union(defined, {})
      for i = 0, len(body)
        collect_free_node(body[i], d, free)
        if is_node(body[i], "let")
          set_add(d, body[i].name)
        end
      end
    when {tag: "match", target: target, target_var: target_var, whens: whens, else: el}
      collect_free_node(target, defined, free)
      let match_def = set_union(defined, {})
      if target_var != nil
        set_add(match_def, target_var)
      end
      for i = 0, len(whens)
        let w = whens[i]
        collect_free_node(w.value, match_def, free)
        let d = set_union(match_def, {})
        if w.bindings != nil
          for bi = 0, len(w.bindings)
            collect_free_node(w.bindings[bi], d, free)
            if is_node(w.bindings[bi], "let")
              set_add(d, w.bindings[bi].name)
            end
          end
        end
        for j = 0, len(w.body)
          collect_free_node(w.body[j], d, free)
          if is_node(w.body[j], "let")
            set_add(d, w.body[j].name)
          end
        end
      end
      if el != nil
        let d = set_union(defined, {})
        for j = 0, len(el)
          collect_free_node(el[j], d, free)
          if is_node(el[j], "let")
            set_add(d, el[j].name)
          end
        end
      end
    when {tag: "when_clause", value: value, bindings: bindings, body: body}
      collect_free_node(value, defined, free)
      let d = set_union(defined, {})
      if bindings != nil
        for bi = 0, len(bindings)
          collect_free_node(bindings[bi], d, free)
          if is_node(bindings[bi], "let")
            set_add(d, bindings[bi].name)
          end
        end
      end
      for i = 0, len(body)
        collect_free_node(body[i], d, free)
        if is_node(body[i], "let")
          set_add(d, body[i].name)
        end
      end
    when {tag: "receive_match", arms: rm_arms, after_ms: rm_after_ms, after_body: rm_after_body}
      let recv_def = set_union(defined, {})
      if node.recv_var != nil
        set_add(recv_def, node.recv_var)
      end
      for i = 0, len(rm_arms)
        let arm = rm_arms[i]
        collect_free_node(arm.pattern.condition, recv_def, free)
        let d = set_union(recv_def, {})
        if arm.pattern.bindings != nil
          for bi = 0, len(arm.pattern.bindings)
            collect_free_node(arm.pattern.bindings[bi], d, free)
            if is_node(arm.pattern.bindings[bi], "let")
              set_add(d, arm.pattern.bindings[bi].name)
            end
          end
        end
        for j = 0, len(arm.body)
          collect_free_node(arm.body[j], d, free)
          if is_node(arm.body[j], "let")
            set_add(d, arm.body[j].name)
          end
        end
      end
      if rm_after_ms != nil
        collect_free_node(rm_after_ms, recv_def, free)
      end
      if rm_after_body != nil
        let d = set_union(recv_def, {})
        for j = 0, len(rm_after_body)
          collect_free_node(rm_after_body[j], d, free)
          if is_node(rm_after_body[j], "let")
            set_add(d, rm_after_body[j].name)
          end
        end
      end
    when {tag: "table", entries: entries}
      for i = 0, len(entries)
        collect_free_node(entries[i].value, defined, free)
      end
    when {tag: "array", elements: elements}
      for i = 0, len(elements)
        collect_free_node(elements[i], defined, free)
      end
    when {tag: "block", stmts: stmts}
      let d = set_union(defined, {})
      for i = 0, len(stmts)
        collect_free_node(stmts[i], d, free)
        if is_node(stmts[i], "let")
          set_add(d, stmts[i].name)
        end
      end
    when {tag: "return", value: value}
      if value != nil
        collect_free_node(value, defined, free)
      end
    else
      # Generic recursion for binop, unop, call, dot, index, etc.
      for nk, v in node
        if nk != "tag"
          if type(v) == "table"
            let vks = keys(v)
            if len(vks) > 0 and type(vks[0]) == "int"
              let vi = 0
              while vi < len(v)
                if type(v[vi]) == "table"
                  collect_free_node(v[vi], defined, free)
                end
                vi += 1
              end
            else
              collect_free_node(v, defined, free)
            end
          end
        end
      end
    end
  end

  collect_free_vars = fn(stmts, defined)
    let free = {}
    let d = set_union(defined, {})
    for i = 0, len(stmts)
      collect_free_node(stmts[i], d, free)
      if is_node(stmts[i], "let")
        set_add(d, stmts[i].name)
      end
      collect_block_lets(stmts[i], d)
    end
    free
  end

  # ─── Capture analysis ──

  let walk_captures = nil
  let walk_captures_node = nil

  walk_captures_node = fn(node, scope_vars, captured)
    if node == nil
      return nil
    end
    if type(node) != "table"
      return nil
    end
    if node.tag == nil
      return nil
    end

    match node
    when {tag: "anon_fn", params: params, rest_param: rest_param, body: body}
      if node.non_escaping == true
        # Marked as immediate-call arg of an allowlisted callee (pcall/sort)
        # with no nested anon_fns. References to outer scope_vars don't
        # force boxing in the enclosing frame.
        return nil
      end
      let inner_defined = sorted_array_to_set(params)
      if rest_param != nil
        set_add(inner_defined, rest_param)
      end
      let free = collect_free_vars(body, inner_defined)
      if node.defaults != nil
        for d in node.defaults
          if d != nil
            collect_free_node(d, inner_defined, free)
          end
        end
      end
      let inter = set_intersect(free, scope_vars)
      for ik, _ in inter
        set_add(captured, ik)
      end
    when {tag: "fn_def"}
      # Named fns are global — skip
    when {tag: "if", cond: cond, then: thens, else: el}
      walk_captures_node(cond, scope_vars, captured)
      walk_captures(thens, scope_vars, captured)
      if el != nil
        walk_captures(el, scope_vars, captured)
      end
    when {tag: "while", cond: cond, body: body}
      walk_captures_node(cond, scope_vars, captured)
      walk_captures(body, scope_vars, captured)
    when {tag: "match", target: target, whens: whens, else: el}
      walk_captures_node(target, scope_vars, captured)
      for i = 0, len(whens)
        walk_captures_node(whens[i].value, scope_vars, captured)
        if whens[i].bindings != nil
          for bi = 0, len(whens[i].bindings)
            walk_captures_node(whens[i].bindings[bi], scope_vars, captured)
          end
        end
        walk_captures(whens[i].body, scope_vars, captured)
      end
      if el != nil
        walk_captures(el, scope_vars, captured)
      end
    when {tag: "receive_match", arms: rm_arms, after_ms: rm_after_ms, after_body: rm_after_body}
      for i = 0, len(rm_arms)
        walk_captures_node(rm_arms[i].pattern.condition, scope_vars, captured)
        if rm_arms[i].pattern.bindings != nil
          for bi = 0, len(rm_arms[i].pattern.bindings)
            walk_captures_node(rm_arms[i].pattern.bindings[bi], scope_vars, captured)
          end
        end
        walk_captures(rm_arms[i].body, scope_vars, captured)
      end
      if rm_after_ms != nil
        walk_captures_node(rm_after_ms, scope_vars, captured)
      end
      if rm_after_body != nil
        walk_captures(rm_after_body, scope_vars, captured)
      end
    when {tag: "table", entries: entries}
      for i = 0, len(entries)
        walk_captures_node(entries[i].value, scope_vars, captured)
      end
    when {tag: "array", elements: elements}
      for i = 0, len(elements)
        walk_captures_node(elements[i], scope_vars, captured)
      end
    when {tag: "block", stmts: stmts}
      walk_captures(stmts, scope_vars, captured)
    when {tag: "return", value: value}
      if value != nil
        walk_captures_node(value, scope_vars, captured)
      end
    when {tag: "let", value: value}
      walk_captures_node(value, scope_vars, captured)
    when {tag: "assign", value: value}
      walk_captures_node(value, scope_vars, captured)
    else
      # Generic recursion
      for nk, v in node
        if nk != "tag"
          if type(v) == "table"
            let vks = keys(v)
            if len(vks) > 0 and type(vks[0]) == "int"
              let vi = 0
              while vi < len(v)
                if type(v[vi]) == "table"
                  walk_captures_node(v[vi], scope_vars, captured)
                end
                vi += 1
              end
            else
              walk_captures_node(v, scope_vars, captured)
            end
          end
        end
      end
    end
  end

  walk_captures = fn(stmts, scope_vars, captured)
    let sv = set_union(scope_vars, {})
    for i = 0, len(stmts)
      walk_captures_node(stmts[i], sv, captured)
      if is_node(stmts[i], "let")
        set_add(sv, stmts[i].name)
      end
      collect_block_lets(stmts[i], sv)
    end
  end

  let find_captured_in_scope = fn(body, scope_vars)
    let captured = {}
    walk_captures(body, scope_vars, captured)
    captured
  end

  # ─── Mutation classification for captures ──
  #
  # For a body and its scope_vars, return the subset of scope_vars that any
  # escaping anon_fn within body (or any anon_fn nested within those) writes
  # to via a bare `name = value` assign. Captures not in this set are
  # read-only-from-the-outer's-perspective and qualify for Route A: the env
  # stores a `GemVal` snapshot rather than a `GemVal *`, and the outer frame
  # need not box them.
  #
  # The same walker also handles the per-closure perspective: passing
  # inside_anon=true treats the body itself as already inside a closure, so
  # direct assigns to scope_vars at the body level (not inside a further
  # nested anon_fn) also count. Used by compile_closure_fn to classify which
  # of its incoming env captures it itself mutates.
  #
  # `dot_assign` / `index_assign` mutate the value, not the binding, so they
  # do not count. `let` introduces a fresh local that shadows the outer name
  # for subsequent statements in scope.
  let walk_writes = nil
  let walk_writes_node = nil

  walk_writes_node = fn(node, scope_vars, defined, writes, inside_anon)
    if node == nil
      return nil
    end
    if type(node) != "table"
      return nil
    end
    if node.tag == nil
      return nil
    end

    match node
    when {tag: "assign", name: name, value: value}
      # A captured name needs boxing whenever it is reassigned anywhere in
      # its lexical scope — whether the assign is inside a nested closure
      # (closure mutates outer's binding) or outside (later closures must
      # see the new value via the shared box, matching established
      # closure-rebind-after-capture semantics).
      if set_contains(scope_vars, name) and not set_contains(defined, name)
        set_add(writes, name)
      end
      walk_writes_node(value, scope_vars, defined, writes, inside_anon)
    when {tag: "let", value: value}
      walk_writes_node(value, scope_vars, defined, writes, inside_anon)
    when {tag: "anon_fn", params: params, rest_param: rest_param, body: body}
      if node.non_escaping == true
        # Non-escaping closures use stack-pointer semantics; their writes
        # mutate the outer's local directly without forcing it to be boxed,
        # so they don't contribute to the writes set we use to decide boxing.
        return nil
      end
      # When transitioning from outside-any-closure into an anon_fn, reset
      # `defined` to just this anon's params: the surrounding scope's lets
      # are the *targets* of mutation analysis, not local shadows. When
      # already inside an anon (anon-in-anon), carry the outer anon's locals
      # forward — those do shadow further-out names from this inner anon's
      # perspective.
      let inner_def = nil
      if inside_anon
        inner_def = set_union(defined, sorted_array_to_set(params))
      else
        inner_def = sorted_array_to_set(params)
      end
      if rest_param != nil
        set_add(inner_def, rest_param)
      end
      walk_writes(body, scope_vars, inner_def, writes, true)
      if node.defaults != nil
        for d in node.defaults
          if d != nil
            walk_writes_node(d, scope_vars, inner_def, writes, true)
          end
        end
      end
    when {tag: "fn_def"}
      # Named fns are global — skip
    when {tag: "if", cond: cond, then: thens, else: el}
      walk_writes_node(cond, scope_vars, defined, writes, inside_anon)
      walk_writes(thens, scope_vars, defined, writes, inside_anon)
      if el != nil
        walk_writes(el, scope_vars, defined, writes, inside_anon)
      end
    when {tag: "while", cond: cond, body: body}
      walk_writes_node(cond, scope_vars, defined, writes, inside_anon)
      walk_writes(body, scope_vars, defined, writes, inside_anon)
    when {tag: "match", target: target, target_var: target_var, whens: whens, else: el}
      walk_writes_node(target, scope_vars, defined, writes, inside_anon)
      let match_def = set_union(defined, {})
      if target_var != nil
        set_add(match_def, target_var)
      end
      for i = 0, len(whens)
        let w = whens[i]
        walk_writes_node(w.value, scope_vars, match_def, writes, inside_anon)
        let d = set_union(match_def, {})
        if w.bindings != nil
          for bi = 0, len(w.bindings)
            walk_writes_node(w.bindings[bi], scope_vars, d, writes, inside_anon)
            if is_node(w.bindings[bi], "let")
              set_add(d, w.bindings[bi].name)
            end
          end
        end
        walk_writes(w.body, scope_vars, d, writes, inside_anon)
      end
      if el != nil
        walk_writes(el, scope_vars, defined, writes, inside_anon)
      end
    when {tag: "receive_match", arms: rm_arms, after_ms: rm_after_ms, after_body: rm_after_body}
      let recv_def = set_union(defined, {})
      if node.recv_var != nil
        set_add(recv_def, node.recv_var)
      end
      for i = 0, len(rm_arms)
        let arm = rm_arms[i]
        walk_writes_node(arm.pattern.condition, scope_vars, recv_def, writes, inside_anon)
        let d = set_union(recv_def, {})
        if arm.pattern.bindings != nil
          for bi = 0, len(arm.pattern.bindings)
            walk_writes_node(arm.pattern.bindings[bi], scope_vars, d, writes, inside_anon)
            if is_node(arm.pattern.bindings[bi], "let")
              set_add(d, arm.pattern.bindings[bi].name)
            end
          end
        end
        walk_writes(arm.body, scope_vars, d, writes, inside_anon)
      end
      if rm_after_ms != nil
        walk_writes_node(rm_after_ms, scope_vars, recv_def, writes, inside_anon)
      end
      if rm_after_body != nil
        walk_writes(rm_after_body, scope_vars, recv_def, writes, inside_anon)
      end
    when {tag: "table", entries: entries}
      for i = 0, len(entries)
        walk_writes_node(entries[i].value, scope_vars, defined, writes, inside_anon)
      end
    when {tag: "array", elements: elements}
      for i = 0, len(elements)
        walk_writes_node(elements[i], scope_vars, defined, writes, inside_anon)
      end
    when {tag: "block", stmts: stmts}
      walk_writes(stmts, scope_vars, defined, writes, inside_anon)
    when {tag: "return", value: value}
      if value != nil
        walk_writes_node(value, scope_vars, defined, writes, inside_anon)
      end
    else
      # Generic recursion
      for nk, v in node
        if nk != "tag"
          if type(v) == "table"
            let vks = keys(v)
            if len(vks) > 0 and type(vks[0]) == "int"
              let vi = 0
              while vi < len(v)
                if type(v[vi]) == "table"
                  walk_writes_node(v[vi], scope_vars, defined, writes, inside_anon)
                end
                vi += 1
              end
            else
              walk_writes_node(v, scope_vars, defined, writes, inside_anon)
            end
          end
        end
      end
    end
  end

  walk_writes = fn(stmts, scope_vars, defined, writes, inside_anon)
    let sv = set_union(defined, {})
    for i = 0, len(stmts)
      walk_writes_node(stmts[i], scope_vars, sv, writes, inside_anon)
      # Only growing `defined` when walking inside an anon: there, lets are
      # locals that shadow scope_vars (outer captures). At the outer scope
      # itself, lets are *the binding sites* of scope_vars — assigns that
      # follow them target those same bindings and must count as writes.
      if inside_anon
        if is_node(stmts[i], "let")
          set_add(sv, stmts[i].name)
        end
        collect_block_lets(stmts[i], sv)
      end
    end
  end

  # Outer-fn perspective: which scope_vars are written by any anon_fn within?
  let find_capture_writes_in_scope = fn(body, scope_vars)
    let writes = {}
    walk_writes(body, scope_vars, {}, writes, false)
    writes
  end

  # Closure-body perspective: which captures does this closure body itself
  # (or any anon_fn nested within) write to? `defined` is the closure's own
  # local scope (params + body lets) — assigns to those don't count.
  let find_writes_in_closure_body = fn(body, captures_set, defined)
    let writes = {}
    walk_writes(body, captures_set, defined, writes, true)
    writes
  end

  # ─── Non-escaping closure detection ──
  #
  # Mark anon_fn nodes that appear as the immediate argument of a call to an
  # allowlisted callee (currently `pcall`). Such closures are invoked
  # synchronously and discarded — they cannot outlive the C frame holding
  # their captures, so the enclosing function need not box those captures.
  # Conservative: we only mark closures whose own body contains no nested
  # anon_fns, sidestepping the case where a nested escaping closure could
  # smuggle outer captures past the synchronous call.

  let non_escape_callees = {}
  set_add(non_escape_callees, "pcall")
  set_add(non_escape_callees, "sort")

  let contains_anon_fn = nil
  contains_anon_fn = fn(node)
    if node == nil
      return false
    end
    if type(node) != "table"
      return false
    end
    if node.tag == nil
      return false
    end
    if node.tag == "anon_fn"
      return true
    end
    for nk, v in node
      if nk != "tag" and type(v) == "table"
        let vks = keys(v)
        if len(vks) > 0 and type(vks[0]) == "int"
          let vi = 0
          while vi < len(v)
            if type(v[vi]) == "table"
              if contains_anon_fn(v[vi])
                return true
              end
            end
            vi += 1
          end
        else
          if contains_anon_fn(v)
            return true
          end
        end
      end
    end
    false
  end

  let body_has_anon_fn = fn(stmts)
    for s in stmts
      if contains_anon_fn(s)
        return true
      end
    end
    false
  end

  let mark_non_escaping = nil
  mark_non_escaping = fn(node)
    if node == nil
      return nil
    end
    if type(node) != "table"
      return nil
    end
    if node.tag == nil
      return nil
    end

    if node.tag == "call" and node.func != nil and is_node(node.func, "var") and set_contains(non_escape_callees, node.func.name)
      if node.args != nil
        for a in node.args
          if is_node(a, "anon_fn") and not body_has_anon_fn(a.body)
            a.non_escaping = true
          end
        end
      end
    end

    for nk, v in node
      if nk != "tag" and type(v) == "table"
        let vks = keys(v)
        if len(vks) > 0 and type(vks[0]) == "int"
          let vi = 0
          while vi < len(v)
            if type(v[vi]) == "table"
              mark_non_escaping(v[vi])
            end
            vi += 1
          end
        else
          mark_non_escaping(v)
        end
      end
    end
  end

  let mark_non_escaping_stmts = fn(stmts)
    for s in stmts
      mark_non_escaping(s)
    end
  end

  # ─── Compilation ──

  let compile_expr = nil
  let compile_stmt = nil
  let compile_stmt_return = nil
  let compile_stmts = nil
  let compile_stmts_tail = nil
  let compile_if = nil
  let compile_while = nil
  let compile_match = nil
  let compile_receive_match = nil
  let compile_call = nil
  let compile_binop = nil
  let compile_anon_fn = nil
  let compile_closure_fn = nil
  let compile_table = nil
  let compile_array = nil
  let compile_extern_fn = nil
  let compile_blocking_extern_fn = nil
  let compile_fn = nil
  let is_self_tail_call = nil
  let has_self_tail_call = nil
  let emit_tco_continue = nil

  # ─── TCO (tail call optimization) ──

  is_self_tail_call = fn(fn_name, node)
    if node == nil
      return false
    end
    if type(node) != "table" or node.tag == nil
      return false
    end
    match node
    when {tag: "call", func: func}
      return is_node(func, "var") and func.name == fn_name
    when {tag: "return", value: value}
      if value != nil
        return is_self_tail_call(fn_name, value)
      end
      return false
    when {tag: "if", then: then_body, else: else_body}
      if has_self_tail_call(fn_name, then_body)
        return true
      end
      if else_body != nil
        return has_self_tail_call(fn_name, else_body)
      end
      return false
    when {tag: "match", whens: whens, else: else_body}
      for i = 0, len(whens)
        if has_self_tail_call(fn_name, whens[i].body)
          return true
        end
      end
      if else_body != nil
        return has_self_tail_call(fn_name, else_body)
      end
      return false
    when {tag: "receive_match", arms: arms, after_body: after_body}
      for i = 0, len(arms)
        if has_self_tail_call(fn_name, arms[i].body)
          return true
        end
      end
      if after_body != nil
        return has_self_tail_call(fn_name, after_body)
      end
      return false
    when {tag: "block", stmts: stmts}
      return has_self_tail_call(fn_name, stmts)
    end
    return false
  end

  has_self_tail_call = fn(fn_name, stmts)
    if len(stmts) == 0
      return false
    end
    is_self_tail_call(fn_name, stmts[-1])
  end

  # ─── Static process-tail analysis ──
  #
  # A function `f` is "process_tail" iff every static call-site of `f` in the
  # program is a tail call from another process_tail caller (or a process root).
  # Process roots: the top-level program; the body of any anon_fn passed as
  # arg[0] to spawn / spawn_link / spawn_monitor.
  #
  # When `f` is process_tail, the TCO arena reset at its self-tail back-edge
  # is safe to fire unconditionally (no caller above with live arena state),
  # so the runtime depth-2 fence at line ~830 is dropped for `f`.
  #
  # TCO functions not marked process_tail get a compile-time warning: their
  # arena will not reset at the back-edge, so a long-running process loop
  # that's not reachable via tail-only edges will not bound memory.

  let spawn_callees = {}
  set_add(spawn_callees, "spawn")
  set_add(spawn_callees, "spawn_link")
  set_add(spawn_callees, "spawn_monitor")

  let mark_process_tail = fn(fn_defs, top_stmts)
    # Reset accumulated state from any prior run.
    let _pt_keys = keys(process_tail_fns)
    for k in _pt_keys
      delete(process_tail_fns, k)
    end

    let caller_records = {}
    let name_to_fn = {}
    for fd in fn_defs
      name_to_fn[fd.name] = fd
    end

    let anon_id_counter = 0
    let next_anon_id = fn()
      let id = "anon:" + to_string(anon_id_counter)
      anon_id_counter += 1
      id
    end

    let new_caller_record = fn(caller_id, is_seed)
      caller_records[caller_id] = {tail_callees: {}, non_tail_callees: {}, is_seed: is_seed}
    end

    # A `return` with a trivial constant (or no value) exits the enclosing
    # function without reading any locals. A call immediately followed by such
    # a return is therefore tail-effective: even though textually non-last,
    # the C frame holds no live state at the point the call's reset would fire.
    # This recognizes the common early-exit pattern `f(); return nil`.
    let is_trivial_return = fn(s)
      if not is_node(s, "return")
        return false
      end
      if s.value == nil
        return true
      end
      if is_node(s.value, "nil")
        return true
      end
      if is_node(s.value, "int")
        return true
      end
      if is_node(s.value, "float")
        return true
      end
      if is_node(s.value, "bool")
        return true
      end
      if is_node(s.value, "string")
        return true
      end
      false
    end

    let collect_calls = nil
    let collect_calls_in_body = nil

    collect_calls = fn(node, is_tail_pos, caller_id)
      if node == nil
        return nil
      end
      if type(node) != "table"
        return nil
      end
      if node.tag == nil
        return nil
      end

      if node.tag == "call"
        # Spawn-family with anon_fn arg[0]: that anon body is a fresh process root.
        if is_node(node.func, "var") and set_contains(spawn_callees, node.func.name)
          if node.args != nil and len(node.args) > 0 and is_node(node.args[0], "anon_fn")
            let aid = next_anon_id()
            new_caller_record(aid, true)
            collect_calls_in_body(node.args[0].body, true, aid)
            if node.args[0].defaults != nil
              for d in node.args[0].defaults
                if d != nil
                  collect_calls(d, false, aid)
                end
              end
            end
            let i = 1
            while i < len(node.args)
              collect_calls(node.args[i], false, caller_id)
              i += 1
            end
            return nil
          end
        end

        # Regular call. Record edge if callee is a known fn_def name.
        if is_node(node.func, "var") and name_to_fn[node.func.name] != nil
          if is_tail_pos
            set_add(caller_records[caller_id].tail_callees, node.func.name)
          else
            set_add(caller_records[caller_id].non_tail_callees, node.func.name)
          end
        else
          collect_calls(node.func, false, caller_id)
        end
        if node.args != nil
          for a in node.args
            collect_calls(a, false, caller_id)
          end
        end
        return nil
      end

      if node.tag == "anon_fn"
        # Closure outside any spawn context — its body is a non-seed caller.
        # Calls from it can never be tail-from-process_tail, so callees of this
        # body get demoted (correct: the closure's invocation site holds C state).
        let aid = next_anon_id()
        new_caller_record(aid, false)
        collect_calls_in_body(node.body, true, aid)
        if node.defaults != nil
          for d in node.defaults
            if d != nil
              collect_calls(d, false, aid)
            end
          end
        end
        return nil
      end

      if node.tag == "if"
        collect_calls(node.cond, false, caller_id)
        collect_calls_in_body(node.then, is_tail_pos, caller_id)
        if node.else != nil
          collect_calls_in_body(node.else, is_tail_pos, caller_id)
        end
        return nil
      end

      if node.tag == "while"
        collect_calls(node.cond, false, caller_id)
        collect_calls_in_body(node.body, false, caller_id)
        return nil
      end

      if node.tag == "match"
        collect_calls(node.target, false, caller_id)
        for w in node.whens
          collect_calls_in_body(w.body, is_tail_pos, caller_id)
        end
        if node.else != nil
          collect_calls_in_body(node.else, is_tail_pos, caller_id)
        end
        return nil
      end

      if node.tag == "receive_match"
        for arm in node.arms
          collect_calls_in_body(arm.body, is_tail_pos, caller_id)
        end
        if node.after_body != nil
          collect_calls_in_body(node.after_body, is_tail_pos, caller_id)
        end
        return nil
      end

      if node.tag == "return"
        if node.value != nil
          collect_calls(node.value, true, caller_id)
        end
        return nil
      end

      if node.tag == "block"
        collect_calls_in_body(node.stmts, is_tail_pos, caller_id)
        return nil
      end

      if node.tag == "let" or node.tag == "assign"
        if node.value != nil
          collect_calls(node.value, false, caller_id)
        end
        return nil
      end

      if node.tag == "dot_assign"
        collect_calls(node.object, false, caller_id)
        collect_calls(node.value, false, caller_id)
        return nil
      end

      if node.tag == "index_assign"
        collect_calls(node.object, false, caller_id)
        collect_calls(node.key, false, caller_id)
        collect_calls(node.value, false, caller_id)
        return nil
      end

      if node.tag == "binop"
        collect_calls(node.left, false, caller_id)
        collect_calls(node.right, false, caller_id)
        return nil
      end

      if node.tag == "unop"
        collect_calls(node.expr, false, caller_id)
        return nil
      end

      if node.tag == "dot"
        collect_calls(node.object, false, caller_id)
        return nil
      end

      if node.tag == "index"
        collect_calls(node.object, false, caller_id)
        collect_calls(node.key, false, caller_id)
        return nil
      end

      if node.tag == "table"
        if node.entries != nil
          for e in node.entries
            collect_calls(e.key, false, caller_id)
            collect_calls(e.value, false, caller_id)
          end
        end
        return nil
      end

      if node.tag == "array"
        if node.elements != nil
          for el in node.elements
            collect_calls(el, false, caller_id)
          end
        end
        return nil
      end

      if node.tag == "interp"
        if node.parts != nil
          for p in node.parts
            collect_calls(p, false, caller_id)
          end
        end
        return nil
      end

      # Leaf nodes: int float string bool nil var break continue load export
      # extern_fn extern_include — no nested calls.
      nil
    end

    collect_calls_in_body = fn(stmts, is_tail_pos, caller_id)
      let n = len(stmts)
      let i = 0
      while i < n
        let stmt_is_tail = false
        if i == n - 1
          stmt_is_tail = is_tail_pos
        elif i + 1 < n and is_trivial_return(stmts[i + 1])
          stmt_is_tail = true
        end
        collect_calls(stmts[i], stmt_is_tail, caller_id)
        i += 1
      end
    end

    # Walk every fn_def body
    for fd in fn_defs
      let cid = "fn:" + fd.name
      new_caller_record(cid, false)
      collect_calls_in_body(fd.body, true, cid)
      if fd.defaults != nil
        for d in fd.defaults
          if d != nil
            collect_calls(d, false, cid)
          end
        end
      end
    end

    # Top-level program is a process root
    new_caller_record("<top>", true)
    collect_calls_in_body(top_stmts, true, "<top>")

    # Build incoming edges per fn_def name
    let incoming = {}
    let cids = keys(caller_records)
    for cid in cids
      let r = caller_records[cid]
      let tcs = keys(r.tail_callees)
      for callee in tcs
        if incoming[callee] == nil
          incoming[callee] = []
        end
        push(incoming[callee], {caller: cid, is_tail: true})
      end
      let ncs = keys(r.non_tail_callees)
      for callee in ncs
        if incoming[callee] == nil
          incoming[callee] = []
        end
        push(incoming[callee], {caller: cid, is_tail: false})
      end
    end

    # Greatest-fixed-point demotion. Soundness condition: f is process_tail
    # iff every C-stack chain from a process root to f's frame is all-tail.
    # Equivalent dual: f is process_tail iff every incoming edge to f is a
    # tail edge from a process_tail caller (or seed).
    #
    # We start with all called fns as candidates and demote any whose incoming
    # edges violate the rule. Iterate until stable. This handles self-recursion
    # and mutual tail-call cycles correctly: an isolated tail cycle survives
    # demotion but is filtered out in the seed-reachability pass below.

    let candidate_pt = {}
    for fd in fn_defs
      if incoming[fd.name] != nil and len(incoming[fd.name]) > 0
        set_add(candidate_pt, fd.name)
      end
    end

    # Step 1: demote candidates with any non-tail incoming edge (permanent).
    for fd in fn_defs
      if not set_contains(candidate_pt, fd.name)
        continue
      end
      let inc = incoming[fd.name]
      let bad = false
      for e in inc
        if not e.is_tail
          bad = true
          break
        end
      end
      if bad
        delete(candidate_pt, fd.name)
      end
    end

    # Step 2: iteratively demote candidates whose incoming has a non-candidate
    # non-seed caller. Cascades until stable.
    let changed = true
    while changed
      changed = false
      let cand_keys = keys(candidate_pt)
      for fname in cand_keys
        let inc = incoming[fname]
        let bad = false
        for e in inc
          let cr = caller_records[e.caller]
          if cr != nil and cr.is_seed
            continue
          end
          # Caller must be a candidate fn_def to keep us viable.
          if len(e.caller) >= 3
            let prefix = substr(e.caller, 0, 3)
            if prefix == "fn:"
              let cname = substr(e.caller, 3, len(e.caller) - 3)
              if not set_contains(candidate_pt, cname)
                bad = true
                break
              end
            else
              # anon non-seed or any other non-fn caller — disqualifies.
              bad = true
              break
            end
          else
            bad = true
            break
          end
        end
        if bad
          delete(candidate_pt, fname)
          changed = true
        end
      end
    end

    # Step 3: BFS from seeds via tail edges, traversing only candidates.
    # Final process_tail_fns = candidates reachable from a seed.
    let bfs_queue = []
    let seed_cids = keys(caller_records)
    for cid in seed_cids
      if caller_records[cid].is_seed
        push(bfs_queue, cid)
      end
    end
    while len(bfs_queue) > 0
      let head = bfs_queue[0]
      let next_q = []
      let qi = 1
      while qi < len(bfs_queue)
        push(next_q, bfs_queue[qi])
        qi += 1
      end
      bfs_queue = next_q
      let r = caller_records[head]
      if r == nil
        continue
      end
      let cs = keys(r.tail_callees)
      for callee in cs
        if set_contains(candidate_pt, callee) and not set_contains(process_tail_fns, callee)
          set_add(process_tail_fns, callee)
          push(bfs_queue, "fn:" + callee)
        end
      end
    end

    # Warn for TCO-eligible fns that didn't get marked
    for fd in fn_defs
      let scope_vars = sorted_array_to_set(fd.params)
      if fd.rest_param != nil
        set_add(scope_vars, fd.rest_param)
      end
      let has_defs = false
      if fd.defaults != nil
        for d in fd.defaults
          if d != nil
            has_defs = true
            break
          end
        end
      end
      let has_tco = false
      if fd.rest_param == nil and not has_defs and not set_contains(scope_vars, fd.name)
        has_tco = has_self_tail_call(fd.name, fd.body)
      end
      if has_tco and not set_contains(process_tail_fns, fd.name)
        let line_str = "?"
        if fd.line != nil
          line_str = to_string(fd.line)
        end
        eprint("warning: {source_name}:{line_str}: TCO function `{fd.name}` not reachable from a process root via tail calls only — per-process arena will not reset at its back-edge. Restructure callers to call `{fd.name}` in tail position from a spawn closure or main.\n")
      end
    end

    # Tag `while true` nodes inside process-tail contexts so compile_while can
    # emit the back-edge arena rescue+reset (mirroring TCO's reset).
    tag_process_tail_while_loops(fn_defs, top_stmts, process_tail_fns)

    # Attach per-loop liveness results to every PT-tagged while node, computed
    # with the loop's actual post-loop set. compile_while reads node.liveness_result
    # rather than recomputing on demand.
    for fd in fn_defs
      compute_live_for_pt_loops_in_stmts(fd.body)
    end
    compute_live_for_pt_loops_in_stmts(top_stmts)
  end

  emit_tco_continue = fn(call_node, indent)
    let p = pad_for(indent)
    let b = buf_new()
    let args = call_node.args
    let arg_temps = []
    for i = 0, len(args)
      let r = compile_expr(args[i])
      let t = tmp()
      buf_push(b, r.setup)
      buf_push(b, "{p}GemVal {t} = {r.expr};\n")
      push(arg_temps, t)
    end

    # Arena reset at the tail-call boundary. Skipped if any param is captured
    # (boxed in arena memory) — that would dangle the box pointer after reset.
    let any_captured = false
    for i = 0, len(tco_params)
      if set_contains(tco_captured, tco_params[i])
        any_captured = true
      end
    end
    if not any_captured and len(arg_temps) > 0
      # Reset only when safe. For functions statically proven `process_tail`
      # (every caller chain reaches this fn via tail calls only from a process
      # root), no caller above holds live arena state — reset unconditionally.
      # Otherwise fall back to the runtime depth-2 fence (covers cases where
      # static analysis can't see the call graph, e.g. dot/dynamic dispatch);
      # such fns also got a compile-time warning at codegen time.
      if tco_is_process_tail
        buf_push(b, "{p}if (gem_current_pid >= 0 && gem_current_arena()->bytes_allocated > GEM_ARENA_RESET_THRESHOLD) \{\n")
      else
        buf_push(b, "{p}if (gem_current_pid >= 0 && gem_call_depth - gem_proc_table[gem_current_pid].entry_call_depth <= 2 && gem_current_arena()->bytes_allocated > GEM_ARENA_RESET_THRESHOLD) \{\n")
      end
      buf_push(b, "{p}    GemVal *_tco_roots[] = \{")
      for i = 0, len(arg_temps)
        if i > 0
          buf_push(b, ", ")
        end
        buf_push(b, "&{arg_temps[i]}")
      end
      buf_push(b, "};\n")
      buf_push(b, "{p}    gem_arena_reset_with_roots(_tco_roots, {len(arg_temps)});\n")
      buf_push(b, "{p}}\n")
    end

    for i = 0, len(tco_params)
      let mp = mangle(tco_params[i])
      let val = "GEM_NIL"
      if i < len(arg_temps)
        val = arg_temps[i]
      end
      if set_contains(tco_captured, tco_params[i])
        buf_push(b, "{p}*{mp} = {val};\n")
      else
        buf_push(b, "{p}{mp} = {val};\n")
      end
    end
    buf_push(b, "{p}continue;")
    buf_str(b)
  end

  # ─── append optimization helpers ──

  let decompose_concat = nil
  decompose_concat = fn(name, node)
    if not is_node(node, "binop") or node.op != "+"
      return nil
    end
    if is_node(node.left, "var") and node.left.name == name
      return [node.right]
    end
    let left_parts = decompose_concat(name, node.left)
    if left_parts != nil
      push(left_parts, node.right)
      return left_parts
    end
    nil
  end

  let expr_has_var = nil
  expr_has_var = fn(node, name)
    if node == nil
      return false
    end
    if type(node) != "table"
      return false
    end
    if node.tag == nil
      return false
    end
    if node.tag == "var"
      return node.name == name
    end
    if node.tag == "int" or node.tag == "float" or node.tag == "bool" or node.tag == "nil"
      return false
    end
    if node.tag == "string"
      return false
    end
    if node.tag == "interp"
      if node.parts != nil
        for p in node.parts
          if expr_has_var(p, name)
            return true
          end
        end
      end
      return false
    end
    if node.tag == "binop"
      return expr_has_var(node.left, name) or expr_has_var(node.right, name)
    end
    if node.tag == "unop"
      return expr_has_var(node.expr, name)
    end
    if node.tag == "call"
      if expr_has_var(node.func, name)
        return true
      end
      if node.args != nil
        for a in node.args
          if expr_has_var(a, name)
            return true
          end
        end
      end
      return false
    end
    if node.tag == "dot"
      return expr_has_var(node.object, name)
    end
    if node.tag == "index"
      return expr_has_var(node.object, name) or expr_has_var(node.key, name)
    end
    if node.tag == "table"
      if node.entries != nil
        for e in node.entries
          if expr_has_var(e.value, name)
            return true
          end
        end
      end
      return false
    end
    if node.tag == "array"
      if node.elements != nil
        for e in node.elements
          if expr_has_var(e, name)
            return true
          end
        end
      end
      return false
    end
    if node.tag == "anon_fn"
      return true
    end
    true
  end

  let stmts_have_non_append_ref = nil
  let stmt_has_non_append_ref = nil

  stmts_have_non_append_ref = fn(stmts, name)
    for s in stmts
      if stmt_has_non_append_ref(s, name)
        return true
      end
    end
    false
  end

  stmt_has_non_append_ref = fn(stmt, name)
    if stmt == nil
      return false
    end
    if type(stmt) != "table"
      return false
    end
    if stmt.tag == "assign"
      if stmt.name == name
        let parts = decompose_concat(name, stmt.value)
        if parts != nil
          for p in parts
            if expr_has_var(p, name)
              return true
            end
          end
          return false
        end
        return true
      end
      return expr_has_var(stmt.value, name)
    end
    if stmt.tag == "let"
      return expr_has_var(stmt.value, name)
    end
    if stmt.tag == "dot_assign"
      return expr_has_var(stmt.object, name) or expr_has_var(stmt.value, name)
    end
    if stmt.tag == "index_assign"
      return expr_has_var(stmt.object, name) or expr_has_var(stmt.key, name) or expr_has_var(stmt.value, name)
    end
    if stmt.tag == "if"
      if expr_has_var(stmt.cond, name)
        return true
      end
      if stmts_have_non_append_ref(stmt.then, name)
        return true
      end
      if stmt.else != nil
        return stmts_have_non_append_ref(stmt.else, name)
      end
      return false
    end
    if stmt.tag == "while"
      if expr_has_var(stmt.cond, name)
        return true
      end
      return stmts_have_non_append_ref(stmt.body, name)
    end
    if stmt.tag == "match"
      if expr_has_var(stmt.target, name)
        return true
      end
      if stmt.whens != nil
        for w in stmt.whens
          if w.value != nil
            if expr_has_var(w.value, name)
              return true
            end
          end
          if w.body != nil
            if stmts_have_non_append_ref(w.body, name)
              return true
            end
          end
        end
      end
      if stmt.else != nil
        return stmts_have_non_append_ref(stmt.else, name)
      end
      return false
    end
    if stmt.tag == "return"
      if stmt.value != nil
        return expr_has_var(stmt.value, name)
      end
      return false
    end
    if stmt.tag == "break" or stmt.tag == "continue" or stmt.tag == "fn_def"
      return false
    end
    if stmt.tag == "block"
      return stmts_have_non_append_ref(stmt.stmts, name)
    end
    if stmt.tag == "call"
      return expr_has_var(stmt, name)
    end
    if stmt.tag == "receive_match"
      return true
    end
    true
  end

  let scan_append_candidates = nil
  scan_append_candidates = fn(stmts, candidates)
    for s in stmts
      if is_node(s, "assign")
        let parts = decompose_concat(s.name, s.value)
        if parts != nil
          let safe = true
          for p in parts
            if expr_has_var(p, s.name)
              safe = false
            end
          end
          if safe
            set_add(candidates, s.name)
          end
        end
      elif is_node(s, "if")
        scan_append_candidates(s.then, candidates)
        if s.else != nil
          scan_append_candidates(s.else, candidates)
        end
      elif is_node(s, "match")
        if s.whens != nil
          for w in s.whens
            if w.body != nil
              scan_append_candidates(w.body, candidates)
            end
          end
        end
        if s.else != nil
          scan_append_candidates(s.else, candidates)
        end
      elif is_node(s, "block")
        scan_append_candidates(s.stmts, candidates)
      end
    end
  end

  let find_append_vars = fn(body)
    let candidates = {}
    scan_append_candidates(body, candidates)
    let eligible = {}
    for name, _ in candidates
      if not stmts_have_non_append_ref(body, name)
        set_add(eligible, name)
      end
    end
    eligible
  end

  # ─── compile_expr ──

  compile_expr = fn(node)
    match node
    when {tag: "int", value: value}
      return {expr: "gem_int({value})", setup: ""}
    when {tag: "float", value: value}
      return {expr: "gem_float({format_float(value)})", setup: ""}
    when {tag: "string", value: value}
      let escaped = escape_c_string(value)
      return {expr: "gem_string(\"{escaped}\")", setup: ""}
    when {tag: "interp", parts: parts}
      if len(parts) == 0
        return {expr: "gem_string(\"\")", setup: ""}
      end
      let setup = ""
      let compiled = []
      for i = 0, len(parts)
        let part = parts[i]
        let r = compile_expr(part)
        setup = setup + r.setup
        push(compiled, r.expr)
      end
      let arr_tmp = tmp()
      let items = compiled[0]
      for i = 1, len(compiled)
        items = items + ", " + compiled[i]
      end
      setup = setup + "    GemVal {arr_tmp}[] = \{{items}};\n"
      return {expr: "gem_interp({len(compiled)}, {arr_tmp})", setup: setup}
    when {tag: "bool", value: value}
      if value
        return {expr: "gem_bool(1)", setup: ""}
      end
      return {expr: "gem_bool(0)", setup: ""}
    when {tag: "nil"}
      return {expr: "GEM_NIL", setup: ""}
    when {tag: "var", name: name}
      if not set_contains(local_names, name)
        if has_key(builtin_fns, name)
          return {expr: "gem_make_fn({builtin_fns[name]}, NULL)", setup: ""}
        elif set_contains(defined_fns, name)
          return {expr: "gem_make_fn(gem_fn_{name}, NULL)", setup: ""}
        end
      end
      let mname = mangle(name)
      # A top-level boxed var (`gem_v_x` is `GemVal *`) must be dereffed at
      # any read site, including inside fn_def bodies that reference it as
      # a global. Skip when the current scope has a let/param shadowing the
      # name — that local is `GemVal`, not `GemVal *`. `local_names` is
      # populated by collect_shadow_lets_in_fn, which descends through all
      # control-flow constructs (but not into nested fns).
      let is_top_box = set_contains(top_level_vars, name) and set_contains(top_level_boxed, name) and not set_contains(local_names, name)
      if set_contains(boxed_vars, name) or (in_top_level and set_contains(top_level_boxed, name)) or is_top_box
        return {expr: "(*{mname})", setup: ""}
      end
      return {expr: mname, setup: ""}
    when {tag: "call"}
      return compile_call(node)
    when {tag: "binop"}
      return compile_binop(node)
    when {tag: "unop", expr: uexpr, op: op}
      let r = compile_expr(uexpr)
      if op == "-"
        return {expr: "gem_neg({r.expr})", setup: r.setup}
      elif op == "not"
        return {expr: "gem_not({r.expr})", setup: r.setup}
      end
      error("unknown unary operator: {op}")
    when {tag: "anon_fn"}
      return compile_anon_fn(node)
    when {tag: "table"}
      return compile_table(node)
    when {tag: "array"}
      return compile_array(node)
    when {tag: "dot", object: object, field: field}
      let r = compile_expr(object)
      let t = tmp()
      ic_counter += 1
      let ic = ic_counter
      let escaped = escape_c_string(field)
      let setup = r.setup + "    GemVal {t} = {r.expr};\n    static GemICacheSlot _ic_{ic} = {ic_init};\n"
      return {expr: "gem_table_get_cached({t}, \"{escaped}\", &_ic_{ic})", setup: setup}
    when {tag: "index", object: object, key: key}
      let obj_r = compile_expr(object)
      let key_r = compile_expr(key)
      return {expr: "gem_table_get({obj_r.expr}, {key_r.expr})", setup: obj_r.setup + key_r.setup}
    end

    error("unknown expression node: {node.tag}")
  end

  # ─── compile_table ──

  let is_int_key = fn(s)
    let slen = len(s)
    if slen == 0
      return false
    end
    let start = 0
    if s[0] == "-"
      start = 1
      if slen == 1
        return false
      end
    end
    let i = start
    while i < slen
      let c = ord(s, i)
      if c < 48 or c > 57
        return false
      end
      i += 1
    end
    true
  end

  compile_table = fn(node)
    let entries = node.entries
    let t = tmp()
    let b = buf_new()
    buf_push(b, "    GemVal {t} = gem_table_new();\n")
    for entry in entries
      let val_r = compile_expr(entry.value)
      buf_push(b, val_r.setup)
      if is_int_key(entry.key)
        buf_push(b, "    gem_table_set({t}, gem_int({entry.key}), {val_r.expr});\n")
      else
        let escaped = escape_c_string(entry.key)
        buf_push(b, "    gem_table_set({t}, gem_string(\"{escaped}\"), {val_r.expr});\n")
      end
    end
    if node.frozen == true
      buf_push(b, "    gem_table_freeze({t});\n")
    end
    {expr: t, setup: buf_str(b)}
  end

  # ─── compile_array ──

  compile_array = fn(node)
    let elements = node.elements
    let t = tmp()
    let b = buf_new()
    buf_push(b, "    GemVal {t} = gem_table_new();\n")
    for i = 0, len(elements)
      let elem_r = compile_expr(elements[i])
      buf_push(b, elem_r.setup)
      buf_push(b, "    gem_table_set({t}, gem_int({i}), {elem_r.expr});\n")
    end
    {expr: t, setup: buf_str(b)}
  end

  # ─── compile_anon_fn ──

  compile_anon_fn = fn(node)
    let inner_defined = sorted_array_to_set(node.params)
    if node.rest_param != nil
      set_add(inner_defined, node.rest_param)
    end
    let free = collect_free_vars(node.body, inner_defined)
    if node.defaults != nil
      for d in node.defaults
        if d != nil
          collect_free_node(d, inner_defined, free)
        end
      end
    end
    let captures = sort(keys(free))

    if len(captures) == 0
      let result = compile_closure_fn(node, [])
      return {expr: "gem_make_fn({result.fn_name}, NULL)", setup: ""}
    end

    let result = compile_closure_fn(node, captures)

    let b = buf_new()
    let env_tmp = tmp()
    if node.non_escaping == true
      # Stack-allocate the env: the closure cannot outlive this C frame.
      buf_push(b, "    struct {result.struct_name} {env_tmp};\n")
      buf_push(b, "    {env_tmp}._num_captures = {len(captures)};\n")
      for cap in captures
        let mc = mangle(cap)
        let is_top_box = set_contains(top_level_vars, cap) and set_contains(top_level_boxed, cap) and not set_contains(local_names, cap)
        let outer_is_box = set_contains(boxed_vars, cap) or (in_top_level and set_contains(top_level_boxed, cap)) or is_top_box
        # Env field is always `GemVal *`. If outer holds a box ptr, copy it
        # (closure shares the box). Otherwise outer's local is an unboxed
        # `GemVal` — for a non-escaping closure we can take its address since
        # the closure cannot outlive the C frame.
        if outer_is_box
          buf_push(b, "    {env_tmp}.{mc} = {mc};\n")
        else
          buf_push(b, "    {env_tmp}.{mc} = &{mc};\n")
        end
      end
      return {expr: "gem_make_fn({result.fn_name}, &{env_tmp})", setup: buf_str(b)}
    end
    buf_push(b, "    struct {result.struct_name} *{env_tmp} = GC_MALLOC(sizeof(struct {result.struct_name}));\n")
    buf_push(b, "    {env_tmp}->_num_captures = {len(captures)};\n")
    for cap in captures
      let mc = mangle(cap)
      let is_top_box = set_contains(top_level_vars, cap) and set_contains(top_level_boxed, cap) and not set_contains(local_names, cap)
      let outer_is_box = set_contains(boxed_vars, cap) or (in_top_level and set_contains(top_level_boxed, cap)) or is_top_box
      # Env field is always `GemVal *`. Outer-boxed → ptr copy. Outer-unboxed
      # (no closure mutates this name, so outer skipped boxing) → allocate a
      # fresh box snapshotting the current value, since this closure may
      # outlive the frame.
      if outer_is_box
        buf_push(b, "    {env_tmp}->{mc} = {mc};\n")
      else
        let box_tmp = tmp()
        buf_push(b, "    GemVal *{box_tmp} = GC_MALLOC(sizeof(GemVal));\n")
        buf_push(b, "    *{box_tmp} = {mc};\n")
        buf_push(b, "    {env_tmp}->{mc} = {box_tmp};\n")
      end
    end
    {expr: "gem_make_fn({result.fn_name}, {env_tmp})", setup: buf_str(b)}
  end

  # ─── compile_args: compile an argument list into setup + array name ──
  # Returns {setup, arr_name, argc}. arr_name is nil when argc == 0.

  let compile_args = fn(args)
    let b = buf_new()
    let arg_exprs = []
    for i = 0, len(args)
      let r = compile_expr(args[i])
      buf_push(b, r.setup)
      push(arg_exprs, r.expr)
    end
    let argc = len(args)
    if argc == 0
      return {setup: buf_str(b), arr_name: nil, argc: 0}
    end
    let t = tmp()
    let arr = arg_exprs[0]
    for i = 1, argc
      arr = arr + ", " + arg_exprs[i]
    end
    {setup: buf_str(b) + "    GemVal {t}[] = \{{arr}};\n", arr_name: t, argc: argc}
  end

  # Emit a direct call: fn_name(env, args, argc)
  let emit_direct_call = fn(fn_name, env, ca)
    if ca.argc == 0
      return {expr: "{fn_name}({env}, NULL, 0)", setup: ca.setup}
    end
    {expr: "{fn_name}({env}, {ca.arr_name}, {ca.argc})", setup: ca.setup}
  end

  # ─── compile_call ──

  compile_call = fn(node)
    let {func, args} = node

    # Method call: obj.len() → gem_len_val(obj)
    if func.tag == "dot" and func.field == "len" and len(args) == 0
      let obj_r = compile_expr(func.object)
      return {expr: "gem_len_val({obj_r.expr})", setup: obj_r.setup}
    end

    # Direct call optimization for known functions
    if func.tag == "var"
      let name = func.name

      if name == "error"
        let line = node.line
        if line == nil
          line = 0
        end
        let escaped_file = escape_c_string(source_name)
        let ca = compile_args(args)
        if ca.argc == 0
          return {expr: "gem_error_at_fn(\"{escaped_file}\", {line}, NULL, 0)", setup: ca.setup}
        end
        return {expr: "gem_error_at_fn(\"{escaped_file}\", {line}, {ca.arr_name}, {ca.argc})", setup: ca.setup}
      elif has_key(builtin_fns, name) and not set_contains(local_names, name)
        return emit_direct_call(builtin_fns[name], "NULL", compile_args(args))
      elif set_contains(defined_fns, name) and not set_contains(local_names, name)
        return emit_direct_call("gem_fn_{name}", "NULL", compile_args(args))
      end
    end

    # General case: call through function value
    let func_r = compile_expr(func)
    let ca = compile_args(args)
    let tmp_fn = tmp()
    let setup = func_r.setup + ca.setup + "    GemVal {tmp_fn} = {func_r.expr};\n"
    if ca.argc == 0
      return {expr: "{tmp_fn}.fn({tmp_fn}.env, NULL, 0)", setup: setup}
    end
    {expr: "{tmp_fn}.fn({tmp_fn}.env, {ca.arr_name}, {ca.argc})", setup: setup}
  end

  # ─── compile_binop ──

  compile_binop = fn(node)
    let op = node.op
    let lc_r = compile_expr(node.left)
    let lc = lc_r.expr
    let ls = lc_r.setup

    if op == "+"
      let rc_r = compile_expr(node.right)
      return {expr: "gem_add({lc}, {rc_r.expr})", setup: ls + rc_r.setup}
    elif op == "-"
      let rc_r = compile_expr(node.right)
      return {expr: "gem_sub({lc}, {rc_r.expr})", setup: ls + rc_r.setup}
    elif op == "*"
      let rc_r = compile_expr(node.right)
      return {expr: "gem_mul({lc}, {rc_r.expr})", setup: ls + rc_r.setup}
    elif op == "/"
      let rc_r = compile_expr(node.right)
      return {expr: "gem_div({lc}, {rc_r.expr})", setup: ls + rc_r.setup}
    elif op == "%"
      let rc_r = compile_expr(node.right)
      return {expr: "gem_mod({lc}, {rc_r.expr})", setup: ls + rc_r.setup}
    elif op == "in"
      let rc_r = compile_expr(node.right)
      let t = tmp()
      let setup = ls + rc_r.setup + "    GemVal {t}[] = \{{rc_r.expr}, {lc}};\n"
      return {expr: "gem_in_fn(NULL, {t}, 2)", setup: setup}
    elif op == "=="
      let rc_r = compile_expr(node.right)
      return {expr: "gem_eq({lc}, {rc_r.expr})", setup: ls + rc_r.setup}
    elif op == "!="
      let rc_r = compile_expr(node.right)
      return {expr: "gem_neq({lc}, {rc_r.expr})", setup: ls + rc_r.setup}
    elif op == "<"
      let rc_r = compile_expr(node.right)
      return {expr: "gem_lt({lc}, {rc_r.expr})", setup: ls + rc_r.setup}
    elif op == ">"
      let rc_r = compile_expr(node.right)
      return {expr: "gem_gt({lc}, {rc_r.expr})", setup: ls + rc_r.setup}
    elif op == "<="
      let rc_r = compile_expr(node.right)
      return {expr: "gem_le({lc}, {rc_r.expr})", setup: ls + rc_r.setup}
    elif op == ">="
      let rc_r = compile_expr(node.right)
      return {expr: "gem_ge({lc}, {rc_r.expr})", setup: ls + rc_r.setup}
    elif op == "and"
      let rc_r = compile_expr(node.right)
      let t = tmp()
      let b = buf_new()
      buf_push(b, ls)
      buf_push(b, "    GemVal {t};\n")
      buf_push(b, "    if (!gem_truthy({lc})) \{\n")
      buf_push(b, "        {t} = {lc};\n")
      buf_push(b, "    } else \{\n")
      if rc_r.setup != ""
        buf_push(b, str_replace(rc_r.setup, "    ", "        "))
      end
      buf_push(b, "        {t} = {rc_r.expr};\n")
      buf_push(b, "    }\n")
      return {expr: t, setup: buf_str(b)}
    elif op == "or"
      let rc_r = compile_expr(node.right)
      let t = tmp()
      let b = buf_new()
      buf_push(b, ls)
      buf_push(b, "    GemVal {t};\n")
      buf_push(b, "    if (gem_truthy({lc})) \{\n")
      buf_push(b, "        {t} = {lc};\n")
      buf_push(b, "    } else \{\n")
      if rc_r.setup != ""
        buf_push(b, str_replace(rc_r.setup, "    ", "        "))
      end
      buf_push(b, "        {t} = {rc_r.expr};\n")
      buf_push(b, "    }\n")
      return {expr: t, setup: buf_str(b)}
    end

    error("unknown binary operator: {op}")
  end

  # ─── compile_stmts ──

  compile_stmts = fn(stmts, indent)
    let b = buf_new()
    for stmt in stmts
      buf_push(b, compile_stmt(stmt, indent))
      buf_push(b, "\n")
    end
    buf_str(b)
  end

  compile_stmts_tail = fn(stmts, indent, return_pos)
    if not return_pos
      return compile_stmts(stmts, indent)
    end
    let b = buf_new()
    if len(stmts) > 0
      for i = 0, len(stmts) - 1
        buf_push(b, compile_stmt(stmts[i], indent))
        buf_push(b, "\n")
      end
      buf_push(b, compile_stmt_return(stmts[-1], indent))
      buf_push(b, "\n")
    else
      let p = pad_for(indent)
      buf_push(b, "{p}gem_pop_frame();\n{p}return GEM_NIL;\n")
    end
    buf_str(b)
  end

  # ─── compile_stmt ──

  compile_stmt = fn(node, indent)
    let p = pad_for(indent)
    let line_dir = ""
    if node.line != nil
      line_dir = "#line {node.line} \"{escape_c_string(source_name)}\"\n"
    end

    match node
    when {tag: "let", name: name, value: value}
      # Track dynamic C scope: this let's local is in scope for any nested
      # process-tail loop's back-edge until its enclosing C `{}` closes.
      # Snapshot/restore at C-scope boundaries (compile_while body,
      # compile_if/match/receive_match arms, compile_stmt_return block) pops
      # arm-local additions when the scope closes.
      set_add(fn_scope_locals, name)
      let r = compile_expr(value)
      let mname = mangle(name)
      if in_top_level and set_contains(top_level_vars, name)
        if set_contains(boxed_vars, name)
          # Box storage is BSS-backed (declared at file scope as `gem_box_<name>`
          # with `gem_v_<name>` pre-initialised to its address). Just write the
          # initial value into the box.
          return "{line_dir}{r.setup}{p}*{mname} = {r.expr};"
        end
        return "{line_dir}{r.setup}{p}{mname} = {r.expr};"
      end
      if set_contains(boxed_vars, name)
        return "{line_dir}{r.setup}{p}GemVal *{mname} = GC_MALLOC(sizeof(GemVal));\n{p}*{mname} = {r.expr};"
      end
      return "{line_dir}{r.setup}{p}GemVal {mname} = {r.expr};"
    when {tag: "assign", name: name, value: value}
      if set_contains(append_buf_vars, name)
        let parts = decompose_concat(name, value)
        if parts != nil
          let mname = mangle(name)
          let b = buf_new()
          buf_push(b, line_dir)
          for part in parts
            let r = compile_expr(part)
            buf_push(b, r.setup)
            buf_push(b, "{p}gem_string_append(&{mname}, {r.expr});\n")
          end
          return buf_str(b)
        end
      end
      let r = compile_expr(value)
      let mname = mangle(name)
      # Mirror compile_var: deref top-level boxed even from fn_def bodies,
      # but skip when shadowed by a local in this scope.
      let is_top_box = set_contains(top_level_vars, name) and set_contains(top_level_boxed, name) and not set_contains(local_names, name)
      if set_contains(boxed_vars, name) or (in_top_level and set_contains(top_level_boxed, name)) or is_top_box
        return "{line_dir}{r.setup}{p}*{mname} = {r.expr};"
      end
      return "{line_dir}{r.setup}{p}{mname} = {r.expr};"
    when {tag: "dot_assign", object: object, value: value, field: field}
      let obj_r = compile_expr(object)
      let val_r = compile_expr(value)
      let escaped = escape_c_string(field)
      return "{line_dir}{obj_r.setup}{val_r.setup}{p}gem_table_set({obj_r.expr}, gem_string(\"{escaped}\"), {val_r.expr});"
    when {tag: "index_assign", object: object, key: key, value: value}
      let obj_r = compile_expr(object)
      let key_r = compile_expr(key)
      let val_r = compile_expr(value)
      return "{line_dir}{obj_r.setup}{key_r.setup}{val_r.setup}{p}gem_table_set({obj_r.expr}, {key_r.expr}, {val_r.expr});"
    when {tag: "if"}
      return "{line_dir}" + compile_if(node, indent, false)
    when {tag: "while"}
      return "{line_dir}" + compile_while(node, indent)
    when {tag: "match"}
      return "{line_dir}" + compile_match(node, indent, false)
    when {tag: "receive_match"}
      return "{line_dir}" + compile_receive_match(node, indent, false)
    when {tag: "break"}
      return p + "break;"
    when {tag: "continue"}
      return p + "continue;"
    when {tag: "return", value: value}
      if value != nil
        let r = compile_expr(value)
        let t = tmp()
        return "{line_dir}{r.setup}{p}GemVal {t} = {r.expr};\n{p}gem_pop_frame();\n{p}return {t};"
      end
      return "{line_dir}{p}gem_pop_frame();\n{p}return GEM_NIL;"
    when {tag: "call"}
      let r = compile_expr(node)
      return "{line_dir}{r.setup}{p}(void)({r.expr});"
    when {tag: "fn_def"}
      return ""
    when {tag: "block", stmts: stmts}
      let b = buf_new()
      for stmt in stmts
        buf_push(b, compile_stmt(stmt, indent))
        buf_push(b, "\n")
      end
      return buf_str(b)
    end

    let r = compile_expr(node)
    "{line_dir}{r.setup}{p}(void)({r.expr});"
  end

  # ─── compile_stmt_return ──

  compile_stmt_return = fn(node, indent)
    let p = pad_for(indent)
    let line_dir = ""
    if node.line != nil
      line_dir = "#line {node.line} \"{escape_c_string(source_name)}\"\n"
    end

    if tco_fn_name != nil
      if is_node(node, "call") and is_node(node.func, "var") and node.func.name == tco_fn_name and not set_contains(local_names, tco_fn_name)
        return line_dir + emit_tco_continue(node, indent)
      end
      if is_node(node, "return") and node.value != nil and is_node(node.value, "call") and is_node(node.value.func, "var") and node.value.func.name == tco_fn_name and not set_contains(local_names, tco_fn_name)
        return line_dir + emit_tco_continue(node.value, indent)
      end
    end

    match node
    when {tag: "let", name: name, value: value}
      set_add(fn_scope_locals, name)
      let r = compile_expr(value)
      let mname = mangle(name)
      if set_contains(boxed_vars, name)
        return "{line_dir}{r.setup}{p}GemVal *{mname} = GC_MALLOC(sizeof(GemVal));\n{p}*{mname} = {r.expr};\n{p}gem_pop_frame();\n{p}return GEM_NIL;"
      end
      return "{line_dir}{r.setup}{p}GemVal {mname} = {r.expr};\n{p}gem_pop_frame();\n{p}return GEM_NIL;"
    when {tag: "assign", name: name, value: value}
      let r = compile_expr(value)
      let t = tmp()
      let mname = mangle(name)
      if set_contains(boxed_vars, name) or (in_top_level and set_contains(top_level_boxed, name))
        return "{line_dir}{r.setup}{p}GemVal {t} = {r.expr};\n{p}*{mname} = {t};\n{p}gem_pop_frame();\n{p}return {t};"
      end
      return "{line_dir}{r.setup}{p}GemVal {t} = {r.expr};\n{p}{mname} = {t};\n{p}gem_pop_frame();\n{p}return {t};"
    when {tag: "return", value: value}
      if value != nil
        let r = compile_expr(value)
        let t = tmp()
        return "{line_dir}{r.setup}{p}GemVal {t} = {r.expr};\n{p}gem_pop_frame();\n{p}return {t};"
      end
      return "{line_dir}{p}gem_pop_frame();\n{p}return GEM_NIL;"
    when {tag: "if"}
      return "{line_dir}" + compile_if(node, indent, true)
    when {tag: "while"}
      return "{line_dir}{compile_while(node, indent)}\n{p}gem_pop_frame();\n{p}return GEM_NIL;"
    when {tag: "match"}
      return "{line_dir}" + compile_match(node, indent, true)
    when {tag: "receive_match"}
      return "{line_dir}" + compile_receive_match(node, indent, true)
    when {tag: "block", stmts: stmts}
      let b = buf_new()
      buf_push(b, "{p}\{\n")
      let saved_block = set_union(fn_scope_locals, {})
      for i = 0, len(stmts) - 1
        buf_push(b, compile_stmt(stmts[i], indent + 1))
        buf_push(b, "\n")
      end
      if len(stmts) > 0
        buf_push(b, compile_stmt_return(stmts[-1], indent + 1))
        buf_push(b, "\n")
      end
      fn_scope_locals = saved_block
      buf_push(b, "{p}}")
      return buf_str(b)
    when {tag: "dot_assign"}
      return "{compile_stmt(node, indent)}\n{p}gem_pop_frame();\n{p}return GEM_NIL;"
    when {tag: "index_assign"}
      return "{compile_stmt(node, indent)}\n{p}gem_pop_frame();\n{p}return GEM_NIL;"
    when {tag: "break"}
      return "{compile_stmt(node, indent)}\n{p}gem_pop_frame();\n{p}return GEM_NIL;"
    when {tag: "continue"}
      return "{compile_stmt(node, indent)}\n{p}gem_pop_frame();\n{p}return GEM_NIL;"
    when {tag: "fn_def"}
      return "{compile_stmt(node, indent)}\n{p}gem_pop_frame();\n{p}return GEM_NIL;"
    end

    let r = compile_expr(node)
    let t = tmp()
    "{line_dir}{r.setup}{p}GemVal {t} = {r.expr};\n{p}gem_pop_frame();\n{p}return {t};"
  end

  # ─── compile_if ──

  compile_if = fn(node, indent, return_pos)
    let p = pad_for(indent)
    let cond_r = compile_expr(node.cond)
    let b = buf_new()
    buf_push(b, cond_r.setup)
    buf_push(b, "{p}if (gem_truthy({cond_r.expr})) \{\n")
    let saved_then = set_union(fn_scope_locals, {})
    buf_push(b, compile_stmts_tail(node.then, indent + 1, return_pos))
    fn_scope_locals = saved_then
    if node.else != nil
      buf_push(b, "{p}} else \{\n")
      let saved_else = set_union(fn_scope_locals, {})
      buf_push(b, compile_stmts_tail(node.else, indent + 1, return_pos))
      fn_scope_locals = saved_else
    elif return_pos
      buf_push(b, "{p}} else \{\n")
      buf_push(b, compile_stmts_tail([], indent + 1, true))
    end
    buf_push(b, "{p}}")
    buf_str(b)
  end

  # ─── compile_while ──

  # Filter the live-at-back-edge set for arena rescue: keep names that map to
  # an addressable C local at the back-edge (`&gem_v_<name>` is a `GemVal *`),
  # drop names whose values are stable across an arena reset (builtins, top-
  # level fn refs, top-level globals read from a non-pid-0 process), and
  # refuse when a name is captured-into-a-closure box (the box itself lives
  # in the per-process arena and would dangle on reset) or when a name has
  # no known C local declaration at this loop's back-edge (let in a nested
  # if/match arm — `collect_top_let_names` does not descend through those).
  let filter_live_for_rescue = fn(live_set)
    let roots = []
    let lk = keys(live_set)
    for name in lk
      if set_contains(local_names, name)
        # In top-level scope, top_level_vars are mirrored into local_names
        # (see compile main setup). Boxed top-level vars are BSS-backed at
        # file scope, so the "box lives in arena" refusal does not apply —
        # those slots survive arena reset directly. The rescue list emits
        # them via `gem_v_<name>` (already a `GemVal *`) below.
        if in_top_level and set_contains(top_level_vars, name)
          push(roots, name)
        elif set_contains(boxed_vars, name) or (in_top_level and set_contains(top_level_boxed, name))
          return {ok: false, reason: "live var `{name}` is captured by a closure (box lives in arena memory)"}
        elif not set_contains(fn_scope_locals, name)
          return {ok: false, reason: "live var `{name}` has no C local at this loop's back-edge (declared in a nested if/match arm?)"}
        else
          push(roots, name)
        end
      elif set_contains(builtins, name)
        # builtin name resolves to a fn pointer; no rescue needed.
      elif set_contains(defined_fns, name)
        # top-level user fn; fn pointer, no rescue needed.
      elif set_contains(top_level_vars, name)
        # global accessed from a non-top-level (spawned) scope — global lives
        # in pid 0's arena, independent of the per-process arena reset here.
      else
        return {ok: false, reason: "live var `{name}` has no C local at this loop's back-edge (declared in a nested if/match arm?)"}
      end
    end
    {ok: true, roots: roots}
  end

  compile_while = fn(node, indent)
    let p = pad_for(indent)
    let is_pt_while = node.process_tail == true

    let do_rescue = false
    let rescue_roots = []
    let refuse_reason = nil
    if is_pt_while
      # Pre-pass `compute_live_for_pt_loops_in_stmts` attached the result during
      # AST setup. Fall back to a cond-true / no-break recompute only if a node
      # slipped past the pre-pass (defensive — keeps compile_while well-defined
      # if a future caller forgets to invoke the pre-pass).
      let lr = node.liveness_result
      if lr == nil
        lr = compute_live_at_backedge(node)
      end
      if lr.ok
        let fr = filter_live_for_rescue(lr.live)
        if fr.ok
          do_rescue = true
          rescue_roots = fr.roots
          # Top-level PT loop: indirect call chains from the loop body can
          # read any top-level binding (e.g. `_is_stc`-style fwd-declared
          # closures defined in a loaded module). Liveness only sees direct
          # references, so splice in *every* remaining top-level var as a
          # rescue root — boxed slots are BSS so this is cheap and uniformly
          # correct.
          if in_top_level
            let already = {}
            for n in rescue_roots
              already[n] = true
            end
            let tlv = keys(top_level_vars)
            for n in tlv
              if not already[n] == true
                push(rescue_roots, n)
              end
            end
          end
        else
          refuse_reason = fr.reason
        end
      else
        refuse_reason = lr.reason
      end
      if not do_rescue
        let line_str = "?"
        if node.line != nil
          line_str = to_string(node.line)
        end
        eprint("warning: {source_name}:{line_str}: cannot reset per-process arena at this loop's back-edge: {refuse_reason}. Memory will grow unbounded across iterations. This pattern is not yet supported in long-running loops — please file an issue with your case if it blocks you.\n")
      end
    end

    let cond_r = compile_expr(node.cond)

    let eligible = find_append_vars(node.body)
    for name, _ in eligible
      if expr_has_var(node.cond, name)
        delete(eligible, name)
      end
      if set_contains(boxed_vars, name) or (in_top_level and set_contains(top_level_boxed, name))
        delete(eligible, name)
      end
    end

    let saved_append = {}
    for k, v in append_buf_vars
      saved_append[k] = v
    end
    for name, _ in eligible
      set_add(append_buf_vars, name)
    end

    let b = buf_new()
    buf_push(b, "{p}while (1) \{\n")
    buf_push(b, "{p}    gem_yield_check();\n")
    if do_rescue
      buf_push(b, "{p}    if (gem_current_pid >= 0 && gem_current_arena()->bytes_allocated > GEM_ARENA_RESET_THRESHOLD) \{\n")
      if len(rescue_roots) == 0
        buf_push(b, "{p}        gem_arena_reset_with_roots(NULL, 0);\n")
      else
        buf_push(b, "{p}        GemVal *_loop_roots[] = \{")
        for i = 0, len(rescue_roots)
          if i > 0
            buf_push(b, ", ")
          end
          let rname = rescue_roots[i]
          # Boxed top-level vars: `gem_v_<name>` is already `GemVal *`
          # (points at the BSS-backed `gem_box_<name>`); locals & non-boxed
          # top-levels need the `&` to form a `GemVal *`.
          if set_contains(top_level_boxed, rname)
            buf_push(b, "{mangle(rname)}")
          else
            buf_push(b, "&{mangle(rname)}")
          end
        end
        buf_push(b, "};\n")
        buf_push(b, "{p}        gem_arena_reset_with_roots(_loop_roots, {len(rescue_roots)});\n")
      end
      buf_push(b, "{p}    }\n")
    end
    if cond_r.setup != ""
      buf_push(b, str_replace(cond_r.setup, "    ", "{p}    "))
    end
    buf_push(b, "{p}    if (!gem_truthy({cond_r.expr})) break;\n")
    let saved_while_scope = set_union(fn_scope_locals, {})
    buf_push(b, compile_stmts(node.body, indent + 1))
    fn_scope_locals = saved_while_scope
    buf_push(b, "{p}}")

    for name, _ in eligible
      let mname = mangle(name)
      buf_push(b, "\n{p}{mname} = gem_string_finish({mname});")
    end

    append_buf_vars = saved_append
    buf_str(b)
  end

  # ─── compile_match ──

  compile_match = fn(node, indent, return_pos)
    let p = pad_for(indent)
    let target_r = compile_expr(node.target)
    let t = nil
    if node.target_var != nil
      t = mangle(node.target_var)
    else
      t = tmp()
    end
    let b = buf_new()
    buf_push(b, target_r.setup)
    buf_push(b, "{p}GemVal {t} = {target_r.expr};\n")
    if len(node.whens) == 0
      if node.else != nil
        buf_push(b, compile_stmts_tail(node.else, indent, return_pos))
      elif return_pos
        buf_push(b, "{p}gem_pop_frame();\n{p}return GEM_NIL;\n")
      end
      buf_push(b, "{p}(void){t};")
      return buf_str(b)
    end
    for i = 0, len(node.whens)
      let w = node.whens[i]
      let val_r = compile_expr(w.value)
      if i == 0
        buf_push(b, val_r.setup)
        buf_push(b, "{p}if (gem_truthy({val_r.expr})) \{\n")
      else
        buf_push(b, "{p}} else \{\n")
        buf_push(b, val_r.setup)
        buf_push(b, "{p}if (gem_truthy({val_r.expr})) \{\n")
      end
      let saved_arm = set_union(fn_scope_locals, {})
      if w.bindings != nil
        for binding in w.bindings
          buf_push(b, compile_stmt(binding, indent + 1))
          buf_push(b, "\n")
        end
      end
      buf_push(b, compile_stmts_tail(w.body, indent + 1, return_pos))
      fn_scope_locals = saved_arm
    end
    if node.else != nil
      buf_push(b, "{p}} else \{\n")
      let saved_else = set_union(fn_scope_locals, {})
      buf_push(b, compile_stmts_tail(node.else, indent + 1, return_pos))
      fn_scope_locals = saved_else
    elif return_pos
      buf_push(b, "{p}} else \{\n")
      buf_push(b, compile_stmts_tail([], indent + 1, true))
    end
    buf_push(b, "{p}}")
    for i = 1, len(node.whens)
      buf_push(b, "\n{p}}")
    end
    buf_str(b)
  end

  # ─── compile_receive_match ──

  compile_receive_match = fn(node, indent, return_pos)
    let p = pad_for(indent)
    let arms = node.arms
    let after_ms = node.after_ms
    let after_body = node.after_body

    let recv_tmp = mangle(node.recv_var)
    let matched_tmp = tmp()
    let prev_tmp = tmp()
    let cur_tmp = tmp()
    let deadline_tmp = tmp()
    let proc_tmp = tmp()

    let b = buf_new()

    buf_push(b, "{p}GemVal {recv_tmp} = GEM_NIL;\n")
    buf_push(b, "{p}int {matched_tmp} = -1;\n")

    if after_ms != nil
      let ms_r = compile_expr(after_ms)
      buf_push(b, ms_r.setup)
      buf_push(b, "{p}int64_t {deadline_tmp} = gem_now_ms() + (int64_t)({ms_r.expr}).ival;\n")
    end

    buf_push(b, "{p}while (1) \{\n")
    let p2 = pad_for(indent + 1)

    buf_push(b, "{p2}GemProcess *{proc_tmp} = &gem_proc_table[gem_current_pid];\n")
    buf_push(b, "{p2}GemMsgNode *{prev_tmp} = NULL;\n")
    buf_push(b, "{p2}GemMsgNode *{cur_tmp} = {proc_tmp}->mailbox.head;\n")
    buf_push(b, "{p2}{matched_tmp} = -1;\n")
    buf_push(b, "{p2}while ({cur_tmp}) \{\n")
    let p3 = pad_for(indent + 2)
    buf_push(b, "{p3}{recv_tmp} = {cur_tmp}->value;\n")

    for i = 0, len(arms)
      let arm = arms[i]
      let cond_r = compile_expr(arm.pattern.condition)
      if i == 0
        buf_push(b, cond_r.setup)
        buf_push(b, "{p3}if (gem_truthy({cond_r.expr})) \{\n")
      else
        buf_push(b, "{p3}} else \{\n")
        buf_push(b, cond_r.setup)
        buf_push(b, "{p3}if (gem_truthy({cond_r.expr})) \{\n")
      end
      buf_push(b, "{pad_for(indent + 3)}{matched_tmp} = {i};\n")
    end
    for i = 0, len(arms)
      buf_push(b, "{p3}}")
      if i < len(arms) - 1
        buf_push(b, "\n")
      end
    end
    buf_push(b, "\n")

    buf_push(b, "{p3}if ({matched_tmp} >= 0) \{\n")
    let p4 = pad_for(indent + 3)
    buf_push(b, "{p4}gem_mailbox_remove(&{proc_tmp}->mailbox, {prev_tmp}, {cur_tmp});\n")
    buf_push(b, "{p4}break;\n")
    buf_push(b, "{p3}}\n")

    buf_push(b, "{p3}{prev_tmp} = {cur_tmp};\n")
    buf_push(b, "{p3}{cur_tmp} = {cur_tmp}->next;\n")
    buf_push(b, "{p2}}\n")

    buf_push(b, "{p2}if ({matched_tmp} >= 0) break;\n")
    if after_ms != nil
      buf_push(b, "{p2}if (gem_now_ms() >= {deadline_tmp}) \{\n")
      buf_push(b, "{p2}    {matched_tmp} = -2;\n")
      buf_push(b, "{p2}    break;\n")
      buf_push(b, "{p2}}\n")
      buf_push(b, "{p2}gem_selective_yield({deadline_tmp});\n")
      buf_push(b, "{p2}if ({proc_tmp}->timed_out) \{\n")
      buf_push(b, "{p2}    {matched_tmp} = -2;\n")
      buf_push(b, "{p2}    break;\n")
      buf_push(b, "{p2}}\n")
    else
      buf_push(b, "{p2}gem_selective_yield(-1);\n")
    end

    buf_push(b, "{p}}\n")

    # Dispatch based on matched arm
    for i = 0, len(arms)
      let arm = arms[i]
      if i == 0
        buf_push(b, "{p}if ({matched_tmp} == {i}) \{\n")
      else
        buf_push(b, "{p}} else if ({matched_tmp} == {i}) \{\n")
      end
      let saved_arm = set_union(fn_scope_locals, {})
      if arm.pattern.bindings != nil
        for binding in arm.pattern.bindings
          buf_push(b, compile_stmt(binding, indent + 1))
          buf_push(b, "\n")
        end
      end
      buf_push(b, compile_stmts_tail(arm.body, indent + 1, return_pos))
      fn_scope_locals = saved_arm
    end

    # After clause
    if after_ms != nil
      buf_push(b, "{p}} else if ({matched_tmp} == -2) \{\n")
      if after_body != nil
        let saved_after = set_union(fn_scope_locals, {})
        buf_push(b, compile_stmts_tail(after_body, indent + 1, return_pos))
        fn_scope_locals = saved_after
      elif return_pos
        buf_push(b, compile_stmts_tail([], indent + 1, true))
      end
    elif return_pos
      buf_push(b, "{p}} else \{\n")
      buf_push(b, compile_stmts_tail([], indent + 1, true))
    end

    buf_push(b, "{p}}")
    buf_str(b)
  end

  # ─── compile_extern_fn ──

  # Helper: emit C forward declaration for an extern function
  let emit_extern_c_decl = fn(name, params, ret_type)
    let c_ret = "void"
    if ret_type == "Int"
      c_ret = "int64_t"
    elif ret_type == "Float"
      c_ret = "double"
    elif ret_type == "String"
      c_ret = "char*"
    elif ret_type == "Bool"
      c_ret = "int"
    elif ret_type == "Ptr"
      c_ret = "void*"
    elif ret_type == "Table"
      c_ret = "GemVal"
    end

    let c_params = ""
    if len(params) == 0
      c_params = "void"
    else
      for i = 0, len(params)
        if i > 0
          c_params = c_params + ", "
        end
        let pt = params[i]["type"]
        if pt == "Int"
          c_params = c_params + "int64_t"
        elif pt == "Float"
          c_params = c_params + "double"
        elif pt == "String"
          c_params = c_params + "const char*"
        elif pt == "Bool"
          c_params = c_params + "int"
        elif pt == "Ptr"
          c_params = c_params + "void*"
        elif pt == "Table"
          c_params = c_params + "GemVal"
        else
          c_params = c_params + "GemVal"
        end
      end
    end

    push(extern_c_decls, "{c_ret} {name}({c_params});")
  end

  compile_extern_fn = fn(node)
    let {name, params, ret_type} = node

    if node.blocking
      return compile_blocking_extern_fn(node)
    end

    let b = buf_new()
    buf_push(b, "static GemVal gem_fn_{name}(void *_env, GemVal *args, int argc) \{\n")

    let c_args = []
    for i = 0, len(params)
      let p = params[i]
      let ptype = p["type"]
      if ptype == "Int"
        buf_push(b, "    int64_t _p{i} = args[{i}].ival;\n")
        push(c_args, "_p{i}")
      elif ptype == "Float"
        buf_push(b, "    double _p{i} = args[{i}].fval;\n")
        push(c_args, "_p{i}")
      elif ptype == "String"
        buf_push(b, "    char* _p{i} = args[{i}].sval;\n")
        push(c_args, "_p{i}")
      elif ptype == "Bool"
        buf_push(b, "    int _p{i} = args[{i}].bval;\n")
        push(c_args, "_p{i}")
      elif ptype == "Ptr"
        buf_push(b, "    void* _p{i} = (void*)(intptr_t)args[{i}].ival;\n")
        push(c_args, "_p{i}")
      elif ptype == "Table"
        push(c_args, "args[{i}]")
      else
        push(c_args, "args[{i}]")
      end
    end

    # Build call arg list
    let call_args = ""
    for i = 0, len(c_args)
      if i > 0
        call_args = call_args + ", "
      end
      call_args = call_args + c_args[i]
    end

    let call_expr = "{name}({call_args})"

    if ret_type == "Nil"
      buf_push(b, "    {call_expr};\n")
      buf_push(b, "    return GEM_NIL;\n")
    elif ret_type == "Table"
      buf_push(b, "    return {call_expr};\n")
    elif ret_type == "Int"
      buf_push(b, "    int64_t _ret = {call_expr};\n")
      buf_push(b, "    return gem_int(_ret);\n")
    elif ret_type == "Float"
      buf_push(b, "    double _ret = {call_expr};\n")
      buf_push(b, "    return gem_float(_ret);\n")
    elif ret_type == "String"
      buf_push(b, "    char* _ret = {call_expr};\n")
      buf_push(b, "    return gem_string(_ret);\n")
    elif ret_type == "Bool"
      buf_push(b, "    int _ret = {call_expr};\n")
      buf_push(b, "    return gem_bool(_ret);\n")
    elif ret_type == "Ptr"
      buf_push(b, "    void *_ret = {call_expr};\n")
      buf_push(b, "    GemVal _r; _r.type = VAL_INT; _r.ival = (int64_t)(intptr_t)_ret; return _r;\n")
    else
      buf_push(b, "    {call_expr};\n")
      buf_push(b, "    return GEM_NIL;\n")
    end

    buf_push(b, "}")

    push(forward_decls, "static GemVal gem_fn_{name}(void *_env, GemVal *args, int argc);")
    emit_extern_c_decl(name, params, ret_type)

    buf_str(b)
  end

  # ─── compile_blocking_extern_fn ──
  # Emits: args struct, worker function, Gem wrapper with thread pool path

  compile_blocking_extern_fn = fn(node)
    let {name, params, ret_type} = node
    let b = buf_new()

    # 1. Args struct
    buf_push(b, "struct _blk_{name}_args \{\n")
    for i = 0, len(params)
      let ptype = params[i]["type"]
      if ptype == "Int"
        buf_push(b, "    int64_t _p{i};\n")
      elif ptype == "Float"
        buf_push(b, "    double _p{i};\n")
      elif ptype == "String"
        buf_push(b, "    char *_p{i};\n")
      elif ptype == "Bool"
        buf_push(b, "    int _p{i};\n")
      elif ptype == "Ptr"
        buf_push(b, "    void *_p{i};\n")
      end
    end
    if ret_type == "Int"
      buf_push(b, "    int64_t _result;\n")
    elif ret_type == "Float"
      buf_push(b, "    double _result;\n")
    elif ret_type == "String"
      buf_push(b, "    char *_result;\n")
    elif ret_type == "Bool"
      buf_push(b, "    int _result;\n")
    elif ret_type == "Ptr"
      buf_push(b, "    void *_result;\n")
    end
    buf_push(b, "};\n\n")

    # 2. Worker function (called on thread pool)
    buf_push(b, "static void _blk_{name}_worker(void *_a) \{\n")
    buf_push(b, "    struct _blk_{name}_args *a = (struct _blk_{name}_args *)_a;\n")

    let w_args = ""
    for i = 0, len(params)
      if i > 0
        w_args = w_args + ", "
      end
      w_args = w_args + "a->_p{i}"
    end
    let w_call = "{name}({w_args})"

    if ret_type == "Nil"
      buf_push(b, "    {w_call};\n")
    else
      buf_push(b, "    a->_result = {w_call};\n")
    end
    buf_push(b, "}\n\n")

    # 3. Gem wrapper function
    buf_push(b, "static GemVal gem_fn_{name}(void *_env, GemVal *args, int argc) \{\n")

    # Extract args from GemVal
    for i = 0, len(params)
      let ptype = params[i]["type"]
      if ptype == "Int"
        buf_push(b, "    int64_t _p{i} = args[{i}].ival;\n")
      elif ptype == "Float"
        buf_push(b, "    double _p{i} = args[{i}].fval;\n")
      elif ptype == "String"
        buf_push(b, "    char* _p{i} = args[{i}].sval;\n")
      elif ptype == "Bool"
        buf_push(b, "    int _p{i} = args[{i}].bval;\n")
      elif ptype == "Ptr"
        buf_push(b, "    void* _p{i} = (void*)(intptr_t)args[{i}].ival;\n")
      end
    end

    # Blocking path: submit to thread pool, yield, resume with result
    buf_push(b, "    if (gem_current_pid >= 0) \{\n")
    buf_push(b, "        struct _blk_{name}_args *_ba = (struct _blk_{name}_args *)malloc(sizeof(struct _blk_{name}_args));\n")

    # Copy args into struct (strdup strings for thread safety)
    for i = 0, len(params)
      let ptype = params[i]["type"]
      if ptype == "String"
        buf_push(b, "        _ba->_p{i} = strdup(_p{i});\n")
      else
        buf_push(b, "        _ba->_p{i} = _p{i};\n")
      end
    end

    buf_push(b, "        GemIORequest *_req = gem_io_submit_extern(_blk_{name}_worker, _ba);\n")
    buf_push(b, "        if (!_req) \{ free(_ba); gem_error(\"{name}: I/O queue full\"); }\n")
    buf_push(b, "        GemProcess *_proc = &gem_proc_table[gem_current_pid];\n")
    buf_push(b, "        _proc->io_request = _req;\n")
    buf_push(b, "        gem_io_pool_yield();\n")
    buf_push(b, "        _proc->io_request = NULL;\n")

    # Read result, free strdup'd strings, free args struct, free IO request
    if ret_type == "String"
      buf_push(b, "        char *_raw = _ba->_result;\n")
    elif ret_type != "Nil"
      let c_type = "int64_t"
      if ret_type == "Float"
        c_type = "double"
      elif ret_type == "Bool"
        c_type = "int"
      elif ret_type == "Ptr"
        c_type = "void *"
      end
      buf_push(b, "        {c_type} _ret = _ba->_result;\n")
    end

    # Free strdup'd string inputs
    for i = 0, len(params)
      if params[i]["type"] == "String"
        buf_push(b, "        free(_ba->_p{i});\n")
      end
    end

    buf_push(b, "        free(_ba);\n")
    buf_push(b, "        gem_io_free_request(_req);\n")

    # Return result
    if ret_type == "Int"
      buf_push(b, "        return gem_int(_ret);\n")
    elif ret_type == "Float"
      buf_push(b, "        return gem_float(_ret);\n")
    elif ret_type == "String"
      buf_push(b, "        size_t _len = _raw ? strlen(_raw) : 0;\n")
      buf_push(b, "        char *_gc = (char *)GC_MALLOC_ATOMIC(_len + 1);\n")
      buf_push(b, "        if (_raw) \{ memcpy(_gc, _raw, _len + 1); free(_raw); } else \{ _gc[0] = '\\0'; }\n")
      buf_push(b, "        return gem_string(_gc);\n")
    elif ret_type == "Bool"
      buf_push(b, "        return gem_bool(_ret);\n")
    elif ret_type == "Ptr"
      buf_push(b, "        GemVal _r; _r.type = VAL_INT; _r.ival = (int64_t)(intptr_t)_ret; return _r;\n")
    else
      buf_push(b, "        return GEM_NIL;\n")
    end
    buf_push(b, "    }\n")

    # Direct call path (not in a coroutine)
    let d_args = ""
    for i = 0, len(params)
      if i > 0
        d_args = d_args + ", "
      end
      d_args = d_args + "_p{i}"
    end
    let d_call = "{name}({d_args})"

    if ret_type == "Nil"
      buf_push(b, "    {d_call};\n")
      buf_push(b, "    return GEM_NIL;\n")
    elif ret_type == "Int"
      buf_push(b, "    int64_t _ret = {d_call};\n")
      buf_push(b, "    return gem_int(_ret);\n")
    elif ret_type == "Float"
      buf_push(b, "    double _ret = {d_call};\n")
      buf_push(b, "    return gem_float(_ret);\n")
    elif ret_type == "String"
      buf_push(b, "    char* _ret = {d_call};\n")
      buf_push(b, "    return gem_string(_ret);\n")
    elif ret_type == "Bool"
      buf_push(b, "    int _ret = {d_call};\n")
      buf_push(b, "    return gem_bool(_ret);\n")
    elif ret_type == "Ptr"
      buf_push(b, "    void *_ret = {d_call};\n")
      buf_push(b, "    GemVal _r; _r.type = VAL_INT; _r.ival = (int64_t)(intptr_t)_ret; return _r;\n")
    else
      buf_push(b, "    {d_call};\n")
      buf_push(b, "    return GEM_NIL;\n")
    end

    buf_push(b, "}")

    push(forward_decls, "static GemVal gem_fn_{name}(void *_env, GemVal *args, int argc);")
    emit_extern_c_decl(name, params, ret_type)

    buf_str(b)
  end

  # ─── emit_param_bindings: generate C code to bind params, rest, block ──

  let emit_param_bindings = fn(node, params, cap_set)
    let b = buf_new()
    let defaults = node.defaults
    if defaults == nil
      defaults = []
    end
    for i = 0, len(params)
      let mp = mangle(params[i])
      let has_def = i < len(defaults) and defaults[i] != nil
      if has_def
        let r = compile_expr(defaults[i])
        if set_contains(cap_set, params[i])
          buf_push(b, "    GemVal *{mp} = GC_MALLOC(sizeof(GemVal));\n")
          buf_push(b, "    if (argc > {i}) \{ *{mp} = args[{i}]; } else \{\n")
          buf_push(b, r.setup)
          buf_push(b, "    *{mp} = {r.expr};\n    }\n")
        else
          buf_push(b, "    GemVal {mp};\n")
          buf_push(b, "    if (argc > {i}) \{ {mp} = args[{i}]; } else \{\n")
          buf_push(b, r.setup)
          buf_push(b, "    {mp} = {r.expr};\n    }\n")
        end
      else
        if set_contains(cap_set, params[i])
          buf_push(b, "    GemVal *{mp} = GC_MALLOC(sizeof(GemVal));\n")
          buf_push(b, "    *{mp} = (argc > {i}) ? args[{i}] : GEM_NIL;\n")
        else
          buf_push(b, "    GemVal {mp} = (argc > {i}) ? args[{i}] : GEM_NIL;\n")
        end
      end
    end

    # Bind rest param: pack args[N .. argc-end_count-1] into an array
    if node.rest_param != nil
      let N = len(params)
      let mp_rest = mangle(node.rest_param)
      if set_contains(cap_set, node.rest_param)
        buf_push(b, "    GemVal *{mp_rest} = GC_MALLOC(sizeof(GemVal));\n")
        buf_push(b, "    *{mp_rest} = gem_table_new();\n")
        buf_push(b, "    for (int _ri = {N}; _ri < argc; _ri++) gem_table_set(*{mp_rest}, gem_int(_ri - {N}), args[_ri]);\n")
      else
        buf_push(b, "    GemVal {mp_rest} = gem_table_new();\n")
        buf_push(b, "    for (int _ri = {N}; _ri < argc; _ri++) gem_table_set({mp_rest}, gem_int(_ri - {N}), args[_ri]);\n")
      end
    end
    buf_str(b)
  end

  # ─── emit_fn_body: compile body stmts with implicit return ──

  let emit_fn_body = fn(body)
    let b = buf_new()
    if len(body) > 0
      for i = 0, len(body) - 1
        buf_push(b, compile_stmt(body[i], 1))
        buf_push(b, "\n")
      end
      buf_push(b, compile_stmt_return(body[-1], 1))
      buf_push(b, "\n")
    else
      buf_push(b, "    gem_pop_frame();\n    return GEM_NIL;\n")
    end
    buf_str(b)
  end

  # ─── compile_fn ──

  compile_fn = fn(node)
    let {params, body, name} = node

    # Determine which variables are captured by nested closures
    let scope_vars = sorted_array_to_set(params)
    if node.rest_param != nil
      set_add(scope_vars, node.rest_param)
    end
    collect_top_let_names(body, scope_vars)

    # Build a separate set including lets nested in any control-flow arm,
    # used to suppress top-level-boxed deref when a shadowing local exists.
    let shadowed_locals = set_union(scope_vars, {})
    collect_shadow_lets_in_fn(body, shadowed_locals)

    let saved_boxed = boxed_vars
    let saved_top = in_top_level
    let saved_local = local_names
    let saved_fn_scope = fn_scope_locals
    local_names = shadowed_locals
    fn_scope_locals = scope_vars

    let captured = find_captured_in_scope(body, scope_vars)
    if node.defaults != nil
      for d in node.defaults
        if d != nil
          walk_captures_node(d, scope_vars, captured)
        end
      end
    end

    # Mutation-aware boxing: only captures that some nested anon_fn writes
    # need a heap box. Read-only captures (captured \ writes) live as plain
    # locals; closure envs receive them as `GemVal` value snapshots.
    let cap_writes = find_capture_writes_in_scope(body, scope_vars)
    if node.defaults != nil
      for d in node.defaults
        if d != nil
          walk_writes_node(d, scope_vars, {}, cap_writes, false)
        end
      end
    end
    boxed_vars = set_intersect(captured, cap_writes)
    in_top_level = false

    let has_defs = false
    if node.defaults != nil
      for d in node.defaults
        if d != nil
          has_defs = true
          break
        end
      end
    end
    let use_tco = false
    if node.rest_param == nil and not has_defs and not set_contains(scope_vars, name)
      use_tco = has_self_tail_call(name, body)
    end
    if use_tco
      tco_fn_name = name
      tco_params = params
      tco_captured = captured
      tco_is_process_tail = set_contains(process_tail_fns, name)
    end

    let b = buf_new()
    buf_push(b, "static GemVal gem_fn_{name}(void *_env, GemVal *args, int argc) \{\n")

    if node.line != nil
      buf_push(b, "#line {node.line} \"{escape_c_string(source_name)}\"\n")
    end

    buf_push(b, emit_param_bindings(node, params, boxed_vars))

    let fn_line = 0
    if node.line != nil
      fn_line = node.line
    end
    buf_push(b, "    gem_push_frame(\"{escape_c_string(name)}\", \"{escape_c_string(source_name)}\", {fn_line});\n")

    if use_tco
      buf_push(b, "    while(1) \{\n")
      buf_push(b, "        gem_yield_check();\n")
      if len(body) > 0
        for i = 0, len(body) - 1
          buf_push(b, compile_stmt(body[i], 2))
          buf_push(b, "\n")
        end
        buf_push(b, compile_stmt_return(body[-1], 2))
        buf_push(b, "\n")
      else
        buf_push(b, "        gem_pop_frame();\n        return GEM_NIL;\n")
      end
      buf_push(b, "    \}\n")
    else
      buf_push(b, emit_fn_body(body))
    end

    buf_push(b, "}")

    if use_tco
      tco_fn_name = nil
      tco_params = nil
      tco_captured = nil
      tco_is_process_tail = false
    end

    boxed_vars = saved_boxed
    in_top_level = saved_top
    local_names = saved_local
    fn_scope_locals = saved_fn_scope
    buf_str(b)
  end

  # ─── compile_closure_fn ──

  compile_closure_fn = fn(node, captures)
    let {params, body} = node
    let name = anon_name()

    # Find which vars inside THIS closure are captured by nested closures
    let inner_scope = sorted_array_to_set(params)
    if node.rest_param != nil
      set_add(inner_scope, node.rest_param)
    end
    collect_top_let_names(body, inner_scope)

    # Build a shadowing-locals set including lets nested in control-flow.
    let shadowed_locals = set_union(inner_scope, {})
    collect_shadow_lets_in_fn(body, shadowed_locals)

    let saved_boxed = boxed_vars
    let saved_top = in_top_level
    let saved_local = local_names
    let saved_fn_scope = fn_scope_locals
    local_names = set_union(shadowed_locals, sorted_array_to_set(captures))
    fn_scope_locals = inner_scope

    let inner_captured = find_captured_in_scope(body, inner_scope)
    if node.defaults != nil
      for d in node.defaults
        if d != nil
          walk_captures_node(d, inner_scope, inner_captured)
        end
      end
    end

    # Mutation-aware boxing for vars in this closure's local scope captured
    # by nested anon_fns: only box those that those nested anons mutate.
    let inner_writes = find_capture_writes_in_scope(body, inner_scope)
    if node.defaults != nil
      for d in node.defaults
        if d != nil
          walk_writes_node(d, inner_scope, {}, inner_writes, false)
        end
      end
    end
    let inner_boxed = set_intersect(inner_captured, inner_writes)

    # Env captures are always passed in by `GemVal *` so the runtime's
    # spawn deep-copy can walk them uniformly. The closure body therefore
    # treats every capture as boxed (reads/writes deref via boxed_vars).
    boxed_vars = set_union(inner_boxed, sorted_array_to_set(captures))
    in_top_level = false

    # Generate struct
    let struct_name = "_closure_{name}"
    let sb = buf_new()
    buf_push(sb, "struct {struct_name} \{\n")
    buf_push(sb, "    intptr_t _num_captures;\n")
    for cap in captures
      buf_push(sb, "    GemVal *{mangle(cap)};\n")
    end
    buf_push(sb, "};\n")
    let struct_def = buf_str(sb)

    # Generate function
    let fb = buf_new()
    buf_push(fb, "static GemVal {name}(void *_env, GemVal *args, int argc) \{\n")
    if len(captures) > 0
      buf_push(fb, "    struct {struct_name} *_cls = (struct {struct_name} *)_env;\n")
      for cap in captures
        let mc = mangle(cap)
        buf_push(fb, "    GemVal *{mc} = _cls->{mc};\n")
      end
    end

    buf_push(fb, emit_param_bindings(node, params, inner_boxed))
    buf_push(fb, "    gem_push_frame(\"{escape_c_string(name)}\", \"{escape_c_string(source_name)}\", 0);\n")
    buf_push(fb, emit_fn_body(body))
    buf_push(fb, "}")

    boxed_vars = saved_boxed
    in_top_level = saved_top
    local_names = saved_local
    fn_scope_locals = saved_fn_scope

    # Add struct + function to functions list
    push(functions, struct_def + buf_str(fb))

    {fn_name: name, struct_name: struct_name, captures: captures}
  end

  # ─── compile (top-level) ──

  let compile = fn(ast)
    # Separate different statement types
    let fn_defs = []
    let extern_fns_list = []
    let extern_includes = []
    let top_stmts = []

    for s in ast.stmts
      if s.tag == "fn_def"
        push(fn_defs, s)
      elif s.tag == "extern_fn"
        push(extern_fns_list, s)
      elif s.tag == "extern_include"
        push(extern_includes, s)
      elif s.tag == "export"
        # handled during load resolution
      else
        push(top_stmts, s)
      end
    end

    # Lift arm-merged lets to the enclosing block so that names introduced
    # in every arm of an `if`/`match`/`receive_match` have a stable C local
    # at the back-edge of any enclosing process-tail loop. Must run before
    # any analysis pass that walks the AST (collect_top_let_names,
    # find_captured_in_scope, mark_process_tail, liveness, …).
    for fd in fn_defs
      lift_arm_lets_in_fn(fd)
    end
    lift_arm_lets_top_stmts(top_stmts)

    # Mark non-escaping closures (immediate-call-site args to allowlisted
    # callees like pcall/sort). Must run before any capture analysis below
    # — find_captured_in_scope reads the non_escaping flag.
    for fd in fn_defs
      mark_non_escaping_stmts(fd.body)
    end
    mark_non_escaping_stmts(top_stmts)

    # Static process-tail analysis: marks fns whose TCO back-edge can reset the
    # arena unconditionally (skipping the runtime depth-2 fence). Fills
    # `process_tail_fns`. Emits warnings for unmarked TCO fns.
    mark_process_tail(fn_defs, top_stmts)

    # Register extern fns as defined (callable)
    for ef in extern_fns_list
      set_add(defined_fns, ef.name)
    end

    # Forward declarations for user-defined functions
    for fd in fn_defs
      set_add(defined_fns, fd.name)
      let decl = "static GemVal gem_fn_{fd.name}(void *_env, GemVal *args, int argc);"
      push(forward_decls, decl)
    end

    # Collect top-level variable names and compute which are captured.
    # Only captured-AND-mutated vars need a heap box at module load — pure
    # read-only captures live as plain `GemVal` globals, with closures
    # receiving value snapshots in their env.
    collect_top_let_names(top_stmts, top_level_vars)
    let top_captured = find_captured_in_scope(top_stmts, {})
    let top_writes = find_capture_writes_in_scope(top_stmts, top_level_vars)
    top_level_boxed = set_intersect(top_captured, top_writes)

    # Emit extern fn wrappers
    for ef in extern_fns_list
      push(functions, compile_extern_fn(ef))
    end

    # Emit function definitions
    for fd in fn_defs
      push(functions, compile_fn(fd))
    end

    # Build main
    let saved_boxed = boxed_vars
    let saved_local = local_names
    let saved_fn_scope = fn_scope_locals
    boxed_vars = top_level_boxed
    in_top_level = true
    # local_names: over-approximation including arm-lets and nested-scope lets,
    # used as the outer guard in `filter_live_for_rescue`. Mirrors what
    # compile_fn does for user fns (shadow walk).
    local_names = {}
    for k, _ in top_level_vars
      set_add(local_names, k)
    end
    collect_shadow_lets_in_fn(top_stmts, local_names)
    # fn_scope_locals: precise dynamic set tracking C locals addressable at the
    # current point. Starts as top-level vars; compile_stmt adds lets; C-scope
    # introducers (compile_while body, compile_if/match/receive_match arms,
    # compile_stmt_return block) snapshot/restore around their bodies.
    fn_scope_locals = {}
    for k, _ in top_level_vars
      set_add(fn_scope_locals, k)
    end
    let main_body = compile_stmts(top_stmts, 1)
    in_top_level = false
    boxed_vars = saved_boxed
    local_names = saved_local
    fn_scope_locals = saved_fn_scope

    let has_main = false
    for fd in fn_defs
      if fd.name == "main"
        has_main = true
      end
    end

    let mb = buf_new()
    buf_push(mb, "static GemVal gem_user_main(void *_env, GemVal *_args, int _argc) \{\n")
    buf_push(mb, "    (void)_env; (void)_args; (void)_argc;\n")
    buf_push(mb, "    gem_push_frame(\"main\", \"{escape_c_string(source_name)}\", 0);\n")
    if main_body != ""
      buf_push(mb, main_body)
    end
    if has_main
      buf_push(mb, "    GemVal _margs[1] = \{GEM_NIL};\n")
      buf_push(mb, "    gem_fn_main(NULL, _margs, 0);\n")
    end
    buf_push(mb, "    gem_pop_frame();\n    return GEM_NIL;\n}\n\n")
    buf_push(mb, "int main(int argc, char **argv) \{\n")
    buf_push(mb, "    gem_init(argc, argv);\n")
    buf_push(mb, "    gem_scheduler_init();\n")
    buf_push(mb, "    gem_run_main(gem_user_main, NULL);\n")
    buf_push(mb, "    return 0;\n}\n")
    let main_c = buf_str(mb)

    # Assemble
    let ob = buf_new()
    for ei in extern_includes
      buf_push(ob, "#include \"{ei.path}\"\n")
    end
    buf_push(ob, "#include \"gem.h\"\n")

    # Extern C forward declarations (auto-generated from extern fn signatures)
    # Skip when extern include is present — the user manages declarations via headers
    if len(extern_includes) == 0
      for i = 0, len(extern_c_decls)
        buf_push(ob, extern_c_decls[i])
        buf_push(ob, "\n")
      end
    end

    # Forward declarations
    for i = 0, len(forward_decls)
      buf_push(ob, forward_decls[i])
      if i < len(forward_decls) - 1
        buf_push(ob, "\n")
      end
    end
    buf_push(ob, "\n")

    # Top-level variable globals. Boxed vars get their backing GemVal in
    # static storage (BSS) with `gem_v_<name>` pointing at it; the pointer
    # never changes, so closures that captured it observe assignments from
    # main even after a top-level PT loop's arena reset (the reset rescues
    # the BSS slot's *contents* via the roots list).
    let tlv_keys = keys(top_level_vars)
    for i = 0, len(tlv_keys)
      let vname = tlv_keys[i]
      if set_contains(top_level_boxed, vname)
        buf_push(ob, "GemVal gem_box_{vname};\n")
        buf_push(ob, "GemVal *gem_v_{vname} = &gem_box_{vname};\n")
      else
        buf_push(ob, "GemVal gem_v_{vname};\n")
      end
    end
    buf_push(ob, "\n")

    # Functions
    for i = 0, len(functions)
      buf_push(ob, functions[i])
      if i < len(functions) - 1
        buf_push(ob, "\n\n")
      end
    end
    buf_push(ob, "\n\n")

    buf_push(ob, main_c)
    buf_str(ob)
  end

  {compile: compile}
end

export make_codegen
