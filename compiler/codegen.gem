# Code generator — compiles AST to C source code.
# Faithful port of bootstrap/gem.py CodeGen class.
# Uses closure-based pattern: fn make_codegen() returns a table of methods.

load "ast"

# ─── String helpers ─────────────────────────────────────────────

fn escape_c_string(s)
  let cr = chr(13)
  let result = ""
  for i = 0, len(s)
    let ch = s[i]
    if ch == "\\"
      result = result + "\\\\"
    elif ch == "\""
      result = result + "\\\""
    elif ch == "\n"
      result = result + "\\n"
    elif ch == cr
      result = result + "\\r"
    elif ch == "\t"
      result = result + "\\t"
    elif ord(ch) == 0
      result = result + "\\0"
    else
      result = result + ch
    end
  end
  result
end

fn repeat_str(s, n)
  let result = ""
  for i = 0, n
    result = result + s
  end
  result
end

fn pad_for(indent)
  repeat_str("    ", indent)
end

fn format_float(val)
  let s = to_string(val)
  # Ensure the string has a decimal point
  let has_dot = false
  for i = 0, len(s)
    if s[i] == "."
      has_dot = true
    end
  end
  if not has_dot
    s = s + ".0"
  end
  s
end

# ─── Array/set helpers ────────��─────────────────────────────────

fn set_add(s, val)
  if s[val] != true
    s[val] = true
  end
end

fn set_contains(s, val)
  s[val] == true
end

fn set_union(a, b)
  let result = {}
  for k, _ in a
    result[k] = true
  end
  for k, _ in b
    result[k] = true
  end
  result
end

fn set_intersect(a, b)
  let result = {}
  for k, _ in a
    if b[k] == true
      result[k] = true
    end
  end
  result
end

fn set_to_sorted_array(s)
  let ks = keys(s)
  # Simple insertion sort
  let i = 1
  while i < len(ks)
    let key = ks[i]
    let j = i - 1
    while j >= 0 and ks[j] > key
      ks[j + 1] = ks[j]
      j -= 1
    end
    ks[j + 1] = key
    i += 1
  end
  ks
end

fn sorted_array_to_set(arr)
  let s = {}
  for item in arr
    s[item] = true
  end
  s
end

# ─── Codegen constructor ───────────────────────────────────────

fn collect_block_lets(stmt, result)
  if type(stmt) == "table" and stmt.tag == "block"
    for j = 0, len(stmt.stmts)
      if type(stmt.stmts[j]) == "table" and stmt.stmts[j].tag == "let"
        set_add(result, stmt.stmts[j].name)
      end
    end
  end
end

fn collect_top_let_names(stmts, result)
  for i = 0, len(stmts)
    let s = stmts[i]
    if type(s) == "table" and s.tag == "let"
      set_add(result, s.name)
    end
    collect_block_lets(s, result)
  end
end

fn make_codegen(source_name)
  let functions = []
  let forward_decls = []
  let extern_c_decls = []
  let tmp_counter = 0
  let anon_counter = 0
  let defined_fns = {}
  let builtin_fns = {
    print: "gem_print",
    error: "gem_error_fn",
    len: "gem_len_fn",
    type: "gem_type_fn",
    to_string: "gem_to_string_fn",
    push: "gem_push_fn",
    pcall: "gem_pcall_fn",
    keys: "gem_keys_fn",
    str_replace: "gem_str_replace_fn",
    has_key: "gem_has_key_fn",
    substr: "gem_substr_fn",
    chr: "gem_chr_fn",
    ord: "gem_ord_fn",
    buf_new: "gem_buf_new_fn",
    buf_push: "gem_buf_push_fn",
    buf_str: "gem_buf_str_fn",
    spawn: "gem_spawn_builtin",
    send: "gem_send_builtin",
    receive: "gem_receive_builtin",
    self: "gem_self_builtin",
    monitor: "gem_monitor_builtin",
    spawn_monitor: "gem_spawn_monitor_builtin",
    register: "gem_register_builtin",
    whereis: "gem_whereis_builtin"
  }
  let builtins = {}
  for k, _ in builtin_fns
    builtins[k] = true
  end
  let boxed_vars = {}
  let top_level_vars = {}
  let top_level_boxed = {}
  let in_top_level = false

  # ─── Helpers ──

  let tmp = fn()
    tmp_counter += 1
    "_t{tmp_counter}"
  end

  let anon_name = fn()
    anon_counter += 1
    "_anon_{anon_counter}"
  end

  let mangle = fn(name)
    "gem_v_{name}"
  end

  # ─── Free variable analysis ──

  let collect_free_vars = nil
  let collect_free_node = nil

  collect_free_node = fn(node, defined, free)
    if node == nil
      return nil
    end
    if type(node) != "table"
      return nil
    end
    if node.tag == nil
      return nil
    end

    match node
    when {tag: "var", name: name}
      if not set_contains(defined, name) and not set_contains(builtins, name) and not set_contains(defined_fns, name)
        set_add(free, name)
      end
    when {tag: "let", value: value}
      collect_free_node(value, defined, free)
    when {tag: "assign", name: name, value: value}
      if not set_contains(defined, name) and not set_contains(builtins, name) and not set_contains(defined_fns, name)
        set_add(free, name)
      end
      collect_free_node(value, defined, free)
    when {tag: "anon_fn", params: params, rest_param: rest_param, block_param: block_param, body: body}
      let inner_defined = set_union(defined, sorted_array_to_set(params))
      if rest_param != nil
        set_add(inner_defined, rest_param)
      end
      if block_param != nil
        set_add(inner_defined, block_param)
      end
      let inner_free = collect_free_vars(body, inner_defined)
      for ifk, _ in inner_free
        set_add(free, ifk)
      end
    when {tag: "fn_def"}
      # Named functions are global — skip
    when {tag: "if", cond: cond, then: thens, else: el}
      collect_free_node(cond, defined, free)
      let d = set_union(defined, {})
      for i = 0, len(thens)
        collect_free_node(thens[i], d, free)
        if type(thens[i]) == "table" and thens[i].tag == "let"
          set_add(d, thens[i].name)
        end
      end
      if el != nil
        d = set_union(defined, {})
        for i = 0, len(el)
          collect_free_node(el[i], d, free)
          if type(el[i]) == "table" and el[i].tag == "let"
            set_add(d, el[i].name)
          end
        end
      end
    when {tag: "while", cond: cond, body: body}
      collect_free_node(cond, defined, free)
      let d = set_union(defined, {})
      for i = 0, len(body)
        collect_free_node(body[i], d, free)
        if type(body[i]) == "table" and body[i].tag == "let"
          set_add(d, body[i].name)
        end
      end
    when {tag: "match", target: target, target_var: target_var, whens: whens, else: el}
      collect_free_node(target, defined, free)
      let match_def = set_union(defined, {})
      if target_var != nil
        set_add(match_def, target_var)
      end
      for i = 0, len(whens)
        let w = whens[i]
        collect_free_node(w.value, match_def, free)
        let d = set_union(match_def, {})
        if w.bindings != nil
          for bi = 0, len(w.bindings)
            collect_free_node(w.bindings[bi], d, free)
            if type(w.bindings[bi]) == "table" and w.bindings[bi].tag == "let"
              set_add(d, w.bindings[bi].name)
            end
          end
        end
        for j = 0, len(w.body)
          collect_free_node(w.body[j], d, free)
          if type(w.body[j]) == "table" and w.body[j].tag == "let"
            set_add(d, w.body[j].name)
          end
        end
      end
      if el != nil
        let d = set_union(defined, {})
        for j = 0, len(el)
          collect_free_node(el[j], d, free)
          if type(el[j]) == "table" and el[j].tag == "let"
            set_add(d, el[j].name)
          end
        end
      end
    when {tag: "when_clause", value: value, bindings: bindings, body: body}
      collect_free_node(value, defined, free)
      let d = set_union(defined, {})
      if bindings != nil
        for bi = 0, len(bindings)
          collect_free_node(bindings[bi], d, free)
          if type(bindings[bi]) == "table" and bindings[bi].tag == "let"
            set_add(d, bindings[bi].name)
          end
        end
      end
      for i = 0, len(body)
        collect_free_node(body[i], d, free)
        if type(body[i]) == "table" and body[i].tag == "let"
          set_add(d, body[i].name)
        end
      end
    when {tag: "receive_match", arms: rm_arms, after_ms: rm_after_ms, after_body: rm_after_body}
      let recv_def = set_union(defined, {})
      if node.recv_var != nil
        set_add(recv_def, node.recv_var)
      end
      for i = 0, len(rm_arms)
        let arm = rm_arms[i]
        collect_free_node(arm.pattern.condition, recv_def, free)
        let d = set_union(recv_def, {})
        if arm.pattern.bindings != nil
          for bi = 0, len(arm.pattern.bindings)
            collect_free_node(arm.pattern.bindings[bi], d, free)
            if type(arm.pattern.bindings[bi]) == "table" and arm.pattern.bindings[bi].tag == "let"
              set_add(d, arm.pattern.bindings[bi].name)
            end
          end
        end
        for j = 0, len(arm.body)
          collect_free_node(arm.body[j], d, free)
          if type(arm.body[j]) == "table" and arm.body[j].tag == "let"
            set_add(d, arm.body[j].name)
          end
        end
      end
      if rm_after_ms != nil
        collect_free_node(rm_after_ms, recv_def, free)
      end
      if rm_after_body != nil
        let d = set_union(recv_def, {})
        for j = 0, len(rm_after_body)
          collect_free_node(rm_after_body[j], d, free)
          if type(rm_after_body[j]) == "table" and rm_after_body[j].tag == "let"
            set_add(d, rm_after_body[j].name)
          end
        end
      end
    when {tag: "block", stmts: stmts}
      let d = set_union(defined, {})
      for i = 0, len(stmts)
        collect_free_node(stmts[i], d, free)
        if type(stmts[i]) == "table" and stmts[i].tag == "let"
          set_add(d, stmts[i].name)
        end
      end
    when {tag: "return", value: value}
      if value != nil
        collect_free_node(value, defined, free)
      end
    else
      # Generic recursion for binop, unop, call, dot, index, etc.
      for nk, v in node
        if nk != "tag"
          if type(v) == "table"
            let vks = keys(v)
            if len(vks) > 0 and type(vks[0]) == "int"
              let vi = 0
              while vi < len(v)
                if type(v[vi]) == "table"
                  collect_free_node(v[vi], defined, free)
                end
                vi += 1
              end
            else
              collect_free_node(v, defined, free)
            end
          end
        end
      end
    end
  end

  collect_free_vars = fn(stmts, defined)
    let free = {}
    let d = set_union(defined, {})
    for i = 0, len(stmts)
      collect_free_node(stmts[i], d, free)
      if type(stmts[i]) == "table" and stmts[i].tag == "let"
        set_add(d, stmts[i].name)
      end
      collect_block_lets(stmts[i], d)
    end
    free
  end

  # ─── Capture analysis ──

  let walk_captures = nil
  let walk_captures_node = nil

  walk_captures_node = fn(node, scope_vars, captured)
    if node == nil
      return nil
    end
    if type(node) != "table"
      return nil
    end
    if node.tag == nil
      return nil
    end

    match node
    when {tag: "anon_fn", params: params, rest_param: rest_param, block_param: block_param, body: body}
      let inner_defined = sorted_array_to_set(params)
      if rest_param != nil
        set_add(inner_defined, rest_param)
      end
      if block_param != nil
        set_add(inner_defined, block_param)
      end
      let free = collect_free_vars(body, inner_defined)
      let inter = set_intersect(free, scope_vars)
      for ik, _ in inter
        set_add(captured, ik)
      end
      walk_captures(body, set_union(scope_vars, inner_defined), captured)
    when {tag: "fn_def"}
      # Named fns are global — skip
    when {tag: "if", cond: cond, then: thens, else: el}
      walk_captures_node(cond, scope_vars, captured)
      walk_captures(thens, scope_vars, captured)
      if el != nil
        walk_captures(el, scope_vars, captured)
      end
    when {tag: "while", cond: cond, body: body}
      walk_captures_node(cond, scope_vars, captured)
      walk_captures(body, scope_vars, captured)
    when {tag: "match", target: target, whens: whens, else: el}
      walk_captures_node(target, scope_vars, captured)
      for i = 0, len(whens)
        walk_captures_node(whens[i].value, scope_vars, captured)
        if whens[i].bindings != nil
          for bi = 0, len(whens[i].bindings)
            walk_captures_node(whens[i].bindings[bi], scope_vars, captured)
          end
        end
        walk_captures(whens[i].body, scope_vars, captured)
      end
      if el != nil
        walk_captures(el, scope_vars, captured)
      end
    when {tag: "receive_match", arms: rm_arms, after_ms: rm_after_ms, after_body: rm_after_body}
      for i = 0, len(rm_arms)
        walk_captures_node(rm_arms[i].pattern.condition, scope_vars, captured)
        if rm_arms[i].pattern.bindings != nil
          for bi = 0, len(rm_arms[i].pattern.bindings)
            walk_captures_node(rm_arms[i].pattern.bindings[bi], scope_vars, captured)
          end
        end
        walk_captures(rm_arms[i].body, scope_vars, captured)
      end
      if rm_after_ms != nil
        walk_captures_node(rm_after_ms, scope_vars, captured)
      end
      if rm_after_body != nil
        walk_captures(rm_after_body, scope_vars, captured)
      end
    when {tag: "block", stmts: stmts}
      walk_captures(stmts, scope_vars, captured)
    when {tag: "return", value: value}
      if value != nil
        walk_captures_node(value, scope_vars, captured)
      end
    when {tag: "let", value: value}
      walk_captures_node(value, scope_vars, captured)
    when {tag: "assign", value: value}
      walk_captures_node(value, scope_vars, captured)
    else
      # Generic recursion
      for nk, v in node
        if nk != "tag"
          if type(v) == "table"
            let vks = keys(v)
            if len(vks) > 0 and type(vks[0]) == "int"
              let vi = 0
              while vi < len(v)
                if type(v[vi]) == "table"
                  walk_captures_node(v[vi], scope_vars, captured)
                end
                vi += 1
              end
            else
              walk_captures_node(v, scope_vars, captured)
            end
          end
        end
      end
    end
  end

  walk_captures = fn(stmts, scope_vars, captured)
    let sv = set_union(scope_vars, {})
    for i = 0, len(stmts)
      walk_captures_node(stmts[i], sv, captured)
      if type(stmts[i]) == "table" and stmts[i].tag == "let"
        set_add(sv, stmts[i].name)
      end
      collect_block_lets(stmts[i], sv)
    end
  end

  let find_captured_in_scope = fn(body, scope_vars)
    let captured = {}
    walk_captures(body, scope_vars, captured)
    captured
  end

  # ─── Compilation ──

  let compile_expr = nil
  let compile_stmt = nil
  let compile_stmt_return = nil
  let compile_stmts = nil
  let compile_if = nil
  let compile_if_return = nil
  let compile_while = nil
  let compile_match = nil
  let compile_match_return = nil
  let compile_receive_match = nil
  let compile_receive_match_return = nil
  let compile_call = nil
  let compile_binop = nil
  let compile_anon_fn = nil
  let compile_closure_fn = nil
  let compile_table = nil
  let compile_array = nil
  let compile_extern_fn = nil
  let compile_fn = nil

  # ─── compile_expr ──

  compile_expr = fn(node)
    match node
    when {tag: "int", value: value}
      return {expr: "gem_int({value})", setup: ""}
    when {tag: "float", value: value}
      return {expr: "gem_float({format_float(value)})", setup: ""}
    when {tag: "string", value: value}
      let escaped = escape_c_string(value)
      return {expr: "gem_string(\"{escaped}\")", setup: ""}
    when {tag: "interp", parts: parts}
      if len(parts) == 0
        return {expr: "gem_string(\"\")", setup: ""}
      end
      let setup = ""
      let compiled = []
      for i = 0, len(parts)
        let part = parts[i]
        let r = compile_expr(part)
        setup = setup + r.setup
        if part.tag == "string"
          push(compiled, r.expr)
        else
          let ts = tmp()
          setup = setup + "    GemVal {ts}[] = \{{r.expr}};\n"
          push(compiled, "gem_to_string_fn(NULL, {ts}, 1)")
        end
      end
      let acc = compiled[0]
      for i = 1, len(compiled)
        acc = "gem_add({acc}, {compiled[i]})"
      end
      return {expr: acc, setup: setup}
    when {tag: "bool", value: value}
      if value
        return {expr: "gem_bool(1)", setup: ""}
      end
      return {expr: "gem_bool(0)", setup: ""}
    when {tag: "nil"}
      return {expr: "GEM_NIL", setup: ""}
    when {tag: "var", name: name}
      if has_key(builtin_fns, name)
        return {expr: "gem_make_fn({builtin_fns[name]}, NULL)", setup: ""}
      elif set_contains(defined_fns, name)
        return {expr: "gem_make_fn(gem_fn_{name}, NULL)", setup: ""}
      end
      let mname = mangle(name)
      if set_contains(boxed_vars, name) or set_contains(top_level_boxed, name)
        return {expr: "(*{mname})", setup: ""}
      end
      return {expr: mname, setup: ""}
    when {tag: "call"}
      return compile_call(node)
    when {tag: "binop"}
      return compile_binop(node)
    when {tag: "unop", expr: uexpr, op: op}
      let r = compile_expr(uexpr)
      if op == "-"
        return {expr: "gem_neg({r.expr})", setup: r.setup}
      elif op == "not"
        return {expr: "gem_not({r.expr})", setup: r.setup}
      end
      error("unknown unary operator: {op}")
    when {tag: "anon_fn"}
      return compile_anon_fn(node)
    when {tag: "table"}
      return compile_table(node)
    when {tag: "array"}
      return compile_array(node)
    when {tag: "dot", object: object, field: field}
      let r = compile_expr(object)
      let t = tmp()
      let setup = r.setup + "    GemVal {t} = {r.expr};\n"
      let escaped = escape_c_string(field)
      return {expr: "gem_table_get({t}, gem_string(\"{escaped}\"))", setup: setup}
    when {tag: "index", object: object, key: key}
      let obj_r = compile_expr(object)
      let key_r = compile_expr(key)
      return {expr: "gem_table_get({obj_r.expr}, {key_r.expr})", setup: obj_r.setup + key_r.setup}
    end

    error("unknown expression node: {node.tag}")
  end

  # ─── compile_table ─���

  compile_table = fn(node)
    let entries = node.entries
    let t = tmp()
    let setup = "    GemVal {t} = gem_table_new();\n"
    for entry in entries
      let val_r = compile_expr(entry.value)
      let escaped = escape_c_string(entry.key)
      setup = setup + val_r.setup
      setup = setup + "    gem_table_set({t}, gem_string(\"{escaped}\"), {val_r.expr});\n"
    end
    {expr: t, setup: setup}
  end

  # ─── compile_array ──

  compile_array = fn(node)
    let elements = node.elements
    let t = tmp()
    let setup = "    GemVal {t} = gem_table_new();\n"
    for i = 0, len(elements)
      let elem_r = compile_expr(elements[i])
      setup = setup + elem_r.setup
      setup = setup + "    gem_table_set({t}, gem_int({i}), {elem_r.expr});\n"
    end
    {expr: t, setup: setup}
  end

  # ──�� compile_anon_fn ──

  compile_anon_fn = fn(node)
    let inner_defined = sorted_array_to_set(node.params)
    if node.rest_param != nil
      set_add(inner_defined, node.rest_param)
    end
    if node.block_param != nil
      set_add(inner_defined, node.block_param)
    end
    let free = collect_free_vars(node.body, inner_defined)
    let captures = set_to_sorted_array(free)

    if len(captures) == 0
      let result = compile_closure_fn(node, [])
      return {expr: "gem_make_fn({result.fn_name}, NULL)", setup: ""}
    end

    let result = compile_closure_fn(node, captures)

    let setup = ""
    let env_tmp = tmp()
    setup = setup + "    struct {result.struct_name} *{env_tmp} = GC_MALLOC(sizeof(struct {result.struct_name}));\n"
    for cap in captures
      let mc = mangle(cap)
      if set_contains(boxed_vars, cap)
        setup = setup + "    {env_tmp}->{mc} = {mc};\n"
      else
        setup = setup + "    {env_tmp}->{mc} = &{mc};\n"
      end
    end
    {expr: "gem_make_fn({result.fn_name}, {env_tmp})", setup: setup}
  end

  # ─── compile_args: compile an argument list into setup + array name ──
  # Returns {setup, arr_name, argc}. arr_name is nil when argc == 0.

  let compile_args = fn(args)
    let arg_setups = ""
    let arg_exprs = []
    for i = 0, len(args)
      let r = compile_expr(args[i])
      arg_setups = arg_setups + r.setup
      push(arg_exprs, r.expr)
    end
    let argc = len(args)
    if argc == 0
      return {setup: arg_setups, arr_name: nil, argc: 0}
    end
    let t = tmp()
    let arr = arg_exprs[0]
    for i = 1, argc
      arr = arr + ", " + arg_exprs[i]
    end
    {setup: arg_setups + "    GemVal {t}[] = \{{arr}};\n", arr_name: t, argc: argc}
  end

  # Emit a direct call: fn_name(env, args, argc)
  let emit_direct_call = fn(fn_name, env, ca)
    if ca.argc == 0
      return {expr: "{fn_name}({env}, NULL, 0)", setup: ca.setup}
    end
    {expr: "{fn_name}({env}, {ca.arr_name}, {ca.argc})", setup: ca.setup}
  end

  # ─── compile_call ──

  compile_call = fn(node)
    let {func, args} = node

    # Method call: obj.len() → gem_len_val(obj)
    if func.tag == "dot" and func.field == "len" and len(args) == 0
      let obj_r = compile_expr(func.object)
      return {expr: "gem_len_val({obj_r.expr})", setup: obj_r.setup}
    end

    # Direct call optimization for known functions
    if func.tag == "var"
      let name = func.name

      if name == "error"
        let line = node.line
        if line == nil
          line = 0
        end
        let escaped_file = escape_c_string(source_name)
        let ca = compile_args(args)
        if ca.argc == 0
          return {expr: "gem_error_at_fn(\"{escaped_file}\", {line}, NULL, 0)", setup: ca.setup}
        end
        return {expr: "gem_error_at_fn(\"{escaped_file}\", {line}, {ca.arr_name}, {ca.argc})", setup: ca.setup}
      elif has_key(builtin_fns, name)
        return emit_direct_call(builtin_fns[name], "NULL", compile_args(args))
      elif set_contains(defined_fns, name)
        return emit_direct_call("gem_fn_{name}", "NULL", compile_args(args))
      end
    end

    # General case: call through function value
    let func_r = compile_expr(func)
    let ca = compile_args(args)
    let tmp_fn = tmp()
    let setup = func_r.setup + ca.setup + "    GemVal {tmp_fn} = {func_r.expr};\n"
    if ca.argc == 0
      return {expr: "{tmp_fn}.fn({tmp_fn}.env, NULL, 0)", setup: setup}
    end
    {expr: "{tmp_fn}.fn({tmp_fn}.env, {ca.arr_name}, {ca.argc})", setup: setup}
  end

  # ─── compile_binop ──

  compile_binop = fn(node)
    let op = node.op
    let lc_r = compile_expr(node.left)
    let lc = lc_r.expr
    let ls = lc_r.setup

    if op == "+"
      let rc_r = compile_expr(node.right)
      return {expr: "gem_add({lc}, {rc_r.expr})", setup: ls + rc_r.setup}
    elif op == "-"
      let rc_r = compile_expr(node.right)
      return {expr: "gem_sub({lc}, {rc_r.expr})", setup: ls + rc_r.setup}
    elif op == "*"
      let rc_r = compile_expr(node.right)
      return {expr: "gem_mul({lc}, {rc_r.expr})", setup: ls + rc_r.setup}
    elif op == "/"
      let rc_r = compile_expr(node.right)
      return {expr: "gem_div({lc}, {rc_r.expr})", setup: ls + rc_r.setup}
    elif op == "%"
      let rc_r = compile_expr(node.right)
      return {expr: "gem_mod({lc}, {rc_r.expr})", setup: ls + rc_r.setup}
    elif op == "in"
      let rc_r = compile_expr(node.right)
      let t = tmp()
      let setup = ls + rc_r.setup + "    GemVal {t}[] = \{{rc_r.expr}, {lc}};\n"
      return {expr: "gem_has_key_fn(NULL, {t}, 2)", setup: setup}
    elif op == "=="
      let rc_r = compile_expr(node.right)
      return {expr: "gem_eq({lc}, {rc_r.expr})", setup: ls + rc_r.setup}
    elif op == "!="
      let rc_r = compile_expr(node.right)
      return {expr: "gem_neq({lc}, {rc_r.expr})", setup: ls + rc_r.setup}
    elif op == "<"
      let rc_r = compile_expr(node.right)
      return {expr: "gem_lt({lc}, {rc_r.expr})", setup: ls + rc_r.setup}
    elif op == ">"
      let rc_r = compile_expr(node.right)
      return {expr: "gem_gt({lc}, {rc_r.expr})", setup: ls + rc_r.setup}
    elif op == "<="
      let rc_r = compile_expr(node.right)
      return {expr: "gem_le({lc}, {rc_r.expr})", setup: ls + rc_r.setup}
    elif op == ">="
      let rc_r = compile_expr(node.right)
      return {expr: "gem_ge({lc}, {rc_r.expr})", setup: ls + rc_r.setup}
    elif op == "and"
      let rc_r = compile_expr(node.right)
      let t = tmp()
      let setup = ls
      setup = setup + "    GemVal {t};\n"
      setup = setup + "    if (!gem_truthy({lc})) \{\n"
      setup = setup + "        {t} = {lc};\n"
      setup = setup + "    } else \{\n"
      if rc_r.setup != ""
        setup = setup + str_replace(rc_r.setup, "    ", "        ")
      end
      setup = setup + "        {t} = {rc_r.expr};\n"
      setup = setup + "    }\n"
      return {expr: t, setup: setup}
    elif op == "or"
      let rc_r = compile_expr(node.right)
      let t = tmp()
      let setup = ls
      setup = setup + "    GemVal {t};\n"
      setup = setup + "    if (gem_truthy({lc})) \{\n"
      setup = setup + "        {t} = {lc};\n"
      setup = setup + "    } else \{\n"
      if rc_r.setup != ""
        setup = setup + str_replace(rc_r.setup, "    ", "        ")
      end
      setup = setup + "        {t} = {rc_r.expr};\n"
      setup = setup + "    }\n"
      return {expr: t, setup: setup}
    end

    error("unknown binary operator: {op}")
  end

  # ─── compile_stmts ──

  compile_stmts = fn(stmts, indent)
    let out = ""
    for stmt in stmts
      out = out + compile_stmt(stmt, indent) + "\n"
    end
    out
  end

  # ─── compile_stmt ──

  compile_stmt = fn(node, indent)
    let p = pad_for(indent)
    let line_dir = ""
    if node.line != nil
      line_dir = "#line {node.line} \"{escape_c_string(source_name)}\"\n"
    end

    match node
    when {tag: "let", name: name, value: value}
      let r = compile_expr(value)
      let mname = mangle(name)
      if in_top_level and set_contains(top_level_vars, name)
        if set_contains(boxed_vars, name)
          return "{line_dir}{r.setup}{p}{mname} = GC_MALLOC(sizeof(GemVal));\n{p}*{mname} = {r.expr};"
        end
        return "{line_dir}{r.setup}{p}{mname} = {r.expr};"
      end
      if set_contains(boxed_vars, name)
        return "{line_dir}{r.setup}{p}GemVal *{mname} = GC_MALLOC(sizeof(GemVal));\n{p}*{mname} = {r.expr};"
      end
      return "{line_dir}{r.setup}{p}GemVal {mname} = {r.expr};"
    when {tag: "assign", name: name, value: value}
      let r = compile_expr(value)
      let mname = mangle(name)
      if set_contains(boxed_vars, name) or set_contains(top_level_boxed, name)
        return "{line_dir}{r.setup}{p}*{mname} = {r.expr};"
      end
      return "{line_dir}{r.setup}{p}{mname} = {r.expr};"
    when {tag: "dot_assign", object: object, value: value, field: field}
      let obj_r = compile_expr(object)
      let val_r = compile_expr(value)
      let escaped = escape_c_string(field)
      return "{line_dir}{obj_r.setup}{val_r.setup}{p}gem_table_set({obj_r.expr}, gem_string(\"{escaped}\"), {val_r.expr});"
    when {tag: "index_assign", object: object, key: key, value: value}
      let obj_r = compile_expr(object)
      let key_r = compile_expr(key)
      let val_r = compile_expr(value)
      return "{line_dir}{obj_r.setup}{key_r.setup}{val_r.setup}{p}gem_table_set({obj_r.expr}, {key_r.expr}, {val_r.expr});"
    when {tag: "if"}
      return "{line_dir}" + compile_if(node, indent)
    when {tag: "while"}
      return "{line_dir}" + compile_while(node, indent)
    when {tag: "match"}
      return "{line_dir}" + compile_match(node, indent)
    when {tag: "receive_match"}
      return "{line_dir}" + compile_receive_match(node, indent)
    when {tag: "break"}
      return p + "break;"
    when {tag: "continue"}
      return p + "continue;"
    when {tag: "return", value: value}
      if value != nil
        let r = compile_expr(value)
        let t = tmp()
        return "{line_dir}{r.setup}{p}GemVal {t} = {r.expr};\n{p}gem_pop_frame();\n{p}return {t};"
      end
      return "{line_dir}{p}gem_pop_frame();\n{p}return GEM_NIL;"
    when {tag: "call"}
      let r = compile_expr(node)
      return "{line_dir}{r.setup}{p}(void)({r.expr});"
    when {tag: "fn_def"}
      return ""
    when {tag: "block", stmts: stmts}
      let out = ""
      for stmt in stmts
        out = out + compile_stmt(stmt, indent) + "\n"
      end
      return out
    end

    let r = compile_expr(node)
    "{line_dir}{r.setup}{p}(void)({r.expr});"
  end

  # ─── compile_stmt_return ���─

  compile_stmt_return = fn(node, indent)
    let p = pad_for(indent)
    let line_dir = ""
    if node.line != nil
      line_dir = "#line {node.line} \"{escape_c_string(source_name)}\"\n"
    end

    match node
    when {tag: "let", name: name, value: value}
      let r = compile_expr(value)
      let mname = mangle(name)
      if set_contains(boxed_vars, name)
        return "{line_dir}{r.setup}{p}GemVal *{mname} = GC_MALLOC(sizeof(GemVal));\n{p}*{mname} = {r.expr};\n{p}gem_pop_frame();\n{p}return GEM_NIL;"
      end
      return "{line_dir}{r.setup}{p}GemVal {mname} = {r.expr};\n{p}gem_pop_frame();\n{p}return GEM_NIL;"
    when {tag: "assign", name: name, value: value}
      let r = compile_expr(value)
      let t = tmp()
      let mname = mangle(name)
      if set_contains(boxed_vars, name) or set_contains(top_level_boxed, name)
        return "{line_dir}{r.setup}{p}GemVal {t} = {r.expr};\n{p}*{mname} = {t};\n{p}gem_pop_frame();\n{p}return {t};"
      end
      return "{line_dir}{r.setup}{p}GemVal {t} = {r.expr};\n{p}{mname} = {t};\n{p}gem_pop_frame();\n{p}return {t};"
    when {tag: "return", value: value}
      if value != nil
        let r = compile_expr(value)
        let t = tmp()
        return "{line_dir}{r.setup}{p}GemVal {t} = {r.expr};\n{p}gem_pop_frame();\n{p}return {t};"
      end
      return "{line_dir}{p}gem_pop_frame();\n{p}return GEM_NIL;"
    when {tag: "if"}
      return "{line_dir}" + compile_if_return(node, indent)
    when {tag: "while"}
      return "{line_dir}{compile_while(node, indent)}\n{p}gem_pop_frame();\n{p}return GEM_NIL;"
    when {tag: "match"}
      return "{line_dir}" + compile_match_return(node, indent)
    when {tag: "receive_match"}
      return "{line_dir}" + compile_receive_match_return(node, indent)
    when {tag: "block", stmts: stmts}
      let out = "{p}\{\n"
      for i = 0, len(stmts) - 1
        out = out + compile_stmt(stmts[i], indent + 1) + "\n"
      end
      if len(stmts) > 0
        out = out + compile_stmt_return(stmts[len(stmts) - 1], indent + 1) + "\n"
      end
      out = out + "{p}}"
      return out
    when {tag: "dot_assign"}
      return "{compile_stmt(node, indent)}\n{p}gem_pop_frame();\n{p}return GEM_NIL;"
    when {tag: "index_assign"}
      return "{compile_stmt(node, indent)}\n{p}gem_pop_frame();\n{p}return GEM_NIL;"
    when {tag: "break"}
      return "{compile_stmt(node, indent)}\n{p}gem_pop_frame();\n{p}return GEM_NIL;"
    when {tag: "continue"}
      return "{compile_stmt(node, indent)}\n{p}gem_pop_frame();\n{p}return GEM_NIL;"
    when {tag: "fn_def"}
      return "{compile_stmt(node, indent)}\n{p}gem_pop_frame();\n{p}return GEM_NIL;"
    end

    let r = compile_expr(node)
    let t = tmp()
    "{line_dir}{r.setup}{p}GemVal {t} = {r.expr};\n{p}gem_pop_frame();\n{p}return {t};"
  end

  # ─── compile_if ──

  compile_if = fn(node, indent)
    let p = pad_for(indent)
    let cond_r = compile_expr(node.cond)
    let out = cond_r.setup
    out = out + "{p}if (gem_truthy({cond_r.expr})) \{\n"
    out = out + compile_stmts(node.then, indent + 1)
    if node.else != nil
      out = out + "{p}} else \{\n"
      out = out + compile_stmts(node.else, indent + 1)
    end
    out = out + "{p}}"
    out
  end

  # ─── compile_if_return ──

  compile_if_return = fn(node, indent)
    let p = pad_for(indent)
    let cond_r = compile_expr(node.cond)
    let out = cond_r.setup
    out = out + "{p}if (gem_truthy({cond_r.expr})) \{\n"
    let then_body = node.then
    if len(then_body) > 0
      for i = 0, len(then_body) - 1
        out = out + compile_stmt(then_body[i], indent + 1) + "\n"
      end
      out = out + compile_stmt_return(then_body[len(then_body) - 1], indent + 1) + "\n"
    else
      out = out + "{p}    gem_pop_frame();\n{p}    return GEM_NIL;\n"
    end
    if node.else != nil
      out = out + "{p}} else \{\n"
      let else_body = node.else
      if len(else_body) > 0
        for i = 0, len(else_body) - 1
          out = out + compile_stmt(else_body[i], indent + 1) + "\n"
        end
        out = out + compile_stmt_return(else_body[len(else_body) - 1], indent + 1) + "\n"
      else
        out = out + "{p}    gem_pop_frame();\n{p}    return GEM_NIL;\n"
      end
    else
      out = out + "{p}} else \{\n"
      out = out + "{p}    gem_pop_frame();\n{p}    return GEM_NIL;\n"
    end
    out = out + "{p}}"
    out
  end

  # ─── compile_while ──

  compile_while = fn(node, indent)
    let p = pad_for(indent)
    let cond_r = compile_expr(node.cond)
    let out = "{p}while (1) \{\n"
    if cond_r.setup != ""
      out = out + str_replace(cond_r.setup, "    ", "{p}    ")
    end
    out = out + "{p}    if (!gem_truthy({cond_r.expr})) break;\n"
    out = out + compile_stmts(node.body, indent + 1)
    out = out + "{p}}"
    out
  end

  # ─── compile_match ──

  compile_match = fn(node, indent)
    let p = pad_for(indent)
    let target_r = compile_expr(node.target)
    let t = nil
    if node.target_var != nil
      t = mangle(node.target_var)
    else
      t = tmp()
    end
    let out = target_r.setup
    out = out + "{p}GemVal {t} = {target_r.expr};\n"
    if len(node.whens) == 0
      # No when clauses — just emit else body if present
      if node.else != nil
        out = out + compile_stmts(node.else, indent)
      end
      out = out + "{p}(void){t};"
      return out
    end
    for i = 0, len(node.whens)
      let w = node.whens[i]
      let val_r = compile_expr(w.value)
      if i == 0
        out = out + val_r.setup
        out = out + "{p}if (gem_truthy({val_r.expr})) \{\n"
      else
        out = out + "{p}} else \{\n"
        out = out + val_r.setup
        out = out + "{p}if (gem_truthy({val_r.expr})) \{\n"
      end
      if w.bindings != nil
        for b in w.bindings
          out = out + compile_stmt(b, indent + 1) + "\n"
        end
      end
      out = out + compile_stmts(w.body, indent + 1)
    end
    if node.else != nil
      out = out + "{p}} else \{\n"
      out = out + compile_stmts(node.else, indent + 1)
    end
    # Close all the nesting: each when after the first opens an extra else block
    out = out + "{p}}"
    for i = 1, len(node.whens)
      out = out + "\n{p}}"
    end
    out
  end

  # ─── compile_match_return ──

  compile_match_return = fn(node, indent)
    let p = pad_for(indent)
    let target_r = compile_expr(node.target)
    let t = nil
    if node.target_var != nil
      t = mangle(node.target_var)
    else
      t = tmp()
    end
    let out = target_r.setup
    out = out + "{p}GemVal {t} = {target_r.expr};\n"
    if len(node.whens) == 0
      # No when clauses — emit else body or return nil
      if node.else != nil
        let else_body = node.else
        if len(else_body) > 0
          for i = 0, len(else_body) - 1
            out = out + compile_stmt(else_body[i], indent) + "\n"
          end
          out = out + compile_stmt_return(else_body[len(else_body) - 1], indent) + "\n"
        else
          out = out + "{p}gem_pop_frame();\n{p}return GEM_NIL;\n"
        end
      else
        out = out + "{p}gem_pop_frame();\n{p}return GEM_NIL;\n"
      end
      out = out + "{p}(void){t};"
      return out
    end
    for i = 0, len(node.whens)
      let w = node.whens[i]
      let val_r = compile_expr(w.value)
      if i == 0
        out = out + val_r.setup
        out = out + "{p}if (gem_truthy({val_r.expr})) \{\n"
      else
        out = out + "{p}} else \{\n"
        out = out + val_r.setup
        out = out + "{p}if (gem_truthy({val_r.expr})) \{\n"
      end
      if w.bindings != nil
        for b in w.bindings
          out = out + compile_stmt(b, indent + 1) + "\n"
        end
      end
      let body = w.body
      if len(body) > 0
        for j = 0, len(body) - 1
          out = out + compile_stmt(body[j], indent + 1) + "\n"
        end
        out = out + compile_stmt_return(body[len(body) - 1], indent + 1) + "\n"
      else
        out = out + "{p}    gem_pop_frame();\n{p}    return GEM_NIL;\n"
      end
    end
    if node.else != nil
      out = out + "{p}} else \{\n"
      let else_body = node.else
      if len(else_body) > 0
        for i = 0, len(else_body) - 1
          out = out + compile_stmt(else_body[i], indent + 1) + "\n"
        end
        out = out + compile_stmt_return(else_body[len(else_body) - 1], indent + 1) + "\n"
      else
        out = out + "{p}    gem_pop_frame();\n{p}    return GEM_NIL;\n"
      end
    else
      out = out + "{p}} else \{\n"
      out = out + "{p}    gem_pop_frame();\n{p}    return GEM_NIL;\n"
    end
    out = out + "{p}}"
    for i = 1, len(node.whens)
      out = out + "\n{p}}"
    end
    out
  end

  # ─── compile_receive_match ──

  compile_receive_match = fn(node, indent)
    let p = pad_for(indent)
    let arms = node.arms
    let after_ms = node.after_ms
    let after_body = node.after_body

    # Use the recv_var from the parser (pattern conditions reference it)
    let recv_tmp = mangle(node.recv_var)
    let matched_tmp = tmp()
    let prev_tmp = tmp()
    let cur_tmp = tmp()
    let deadline_tmp = tmp()
    let proc_tmp = tmp()

    let out = ""

    # Declare the receive value variable (patterns reference this via mangle(recv_var))
    out = out + "{p}GemVal {recv_tmp} = GEM_NIL;\n"
    out = out + "{p}int {matched_tmp} = -1;\n"

    # Set up deadline if after clause present
    if after_ms != nil
      let ms_r = compile_expr(after_ms)
      out = out + ms_r.setup
      out = out + "{p}int64_t {deadline_tmp} = gem_now_ms() + (int64_t)({ms_r.expr}).ival;\n"
    end

    # Outer loop: keep scanning until a match or timeout
    out = out + "{p}while (1) \{\n"
    let p2 = pad_for(indent + 1)

    # Get current process
    out = out + "{p2}GemProcess *{proc_tmp} = &gem_proc_table[gem_current_pid];\n"

    # Scan mailbox
    out = out + "{p2}GemMsgNode *{prev_tmp} = NULL;\n"
    out = out + "{p2}GemMsgNode *{cur_tmp} = {proc_tmp}->mailbox.head;\n"
    out = out + "{p2}{matched_tmp} = -1;\n"
    out = out + "{p2}while ({cur_tmp}) \{\n"
    let p3 = pad_for(indent + 2)
    out = out + "{p3}{recv_tmp} = {cur_tmp}->value;\n"

    # Test each arm's pattern condition
    for i = 0, len(arms)
      let arm = arms[i]
      let cond_r = compile_expr(arm.pattern.condition)
      if i == 0
        out = out + cond_r.setup
        out = out + "{p3}if (gem_truthy({cond_r.expr})) \{\n"
      else
        out = out + "{p3}} else \{\n"
        out = out + cond_r.setup
        out = out + "{p3}if (gem_truthy({cond_r.expr})) \{\n"
      end
      out = out + "{pad_for(indent + 3)}{matched_tmp} = {i};\n"
    end
    # Close all arm conditions
    for i = 0, len(arms)
      out = out + "{p3}}"
      if i < len(arms) - 1
        out = out + "\n"
      end
    end
    out = out + "\n"

    # If matched, splice out node and break
    out = out + "{p3}if ({matched_tmp} >= 0) \{\n"
    let p4 = pad_for(indent + 3)
    out = out + "{p4}gem_mailbox_remove(&{proc_tmp}->mailbox, {prev_tmp}, {cur_tmp});\n"
    out = out + "{p4}break;\n"
    out = out + "{p3}}\n"

    # Advance to next node
    out = out + "{p3}{prev_tmp} = {cur_tmp};\n"
    out = out + "{p3}{cur_tmp} = {cur_tmp}->next;\n"
    out = out + "{p2}}\n"

    # No match found — check timeout or yield
    out = out + "{p2}if ({matched_tmp} >= 0) break;\n"
    if after_ms != nil
      out = out + "{p2}if (gem_now_ms() >= {deadline_tmp}) \{\n"
      out = out + "{p2}    {matched_tmp} = -2;\n"
      out = out + "{p2}    break;\n"
      out = out + "{p2}}\n"
      out = out + "{p2}gem_selective_yield({deadline_tmp});\n"
      # Check if timed out after yield
      out = out + "{p2}if ({proc_tmp}->timed_out) \{\n"
      out = out + "{p2}    {matched_tmp} = -2;\n"
      out = out + "{p2}    break;\n"
      out = out + "{p2}}\n"
    else
      out = out + "{p2}gem_selective_yield(-1);\n"
    end

    out = out + "{p}}\n"

    # Now dispatch based on matched arm
    for i = 0, len(arms)
      let arm = arms[i]
      if i == 0
        out = out + "{p}if ({matched_tmp} == {i}) \{\n"
      else
        out = out + "{p}} else if ({matched_tmp} == {i}) \{\n"
      end
      # Emit bindings
      if arm.pattern.bindings != nil
        for b in arm.pattern.bindings
          out = out + compile_stmt(b, indent + 1) + "\n"
        end
      end
      out = out + compile_stmts(arm.body, indent + 1)
    end

    # After clause
    if after_ms != nil
      out = out + "{p}} else if ({matched_tmp} == -2) \{\n"
      if after_body != nil
        out = out + compile_stmts(after_body, indent + 1)
      end
    end

    out = out + "{p}}"
    out
  end

  compile_receive_match_return = fn(node, indent)
    let p = pad_for(indent)
    let arms = node.arms
    let after_ms = node.after_ms
    let after_body = node.after_body

    let recv_tmp = mangle(node.recv_var)
    let matched_tmp = tmp()
    let prev_tmp = tmp()
    let cur_tmp = tmp()
    let deadline_tmp = tmp()
    let proc_tmp = tmp()

    let out = ""

    out = out + "{p}GemVal {recv_tmp} = GEM_NIL;\n"
    out = out + "{p}int {matched_tmp} = -1;\n"

    if after_ms != nil
      let ms_r = compile_expr(after_ms)
      out = out + ms_r.setup
      out = out + "{p}int64_t {deadline_tmp} = gem_now_ms() + (int64_t)({ms_r.expr}).ival;\n"
    end

    out = out + "{p}while (1) \{\n"
    let p2 = pad_for(indent + 1)

    out = out + "{p2}GemProcess *{proc_tmp} = &gem_proc_table[gem_current_pid];\n"
    out = out + "{p2}GemMsgNode *{prev_tmp} = NULL;\n"
    out = out + "{p2}GemMsgNode *{cur_tmp} = {proc_tmp}->mailbox.head;\n"
    out = out + "{p2}{matched_tmp} = -1;\n"
    out = out + "{p2}while ({cur_tmp}) \{\n"
    let p3 = pad_for(indent + 2)
    out = out + "{p3}{recv_tmp} = {cur_tmp}->value;\n"

    for i = 0, len(arms)
      let arm = arms[i]
      let cond_r = compile_expr(arm.pattern.condition)
      if i == 0
        out = out + cond_r.setup
        out = out + "{p3}if (gem_truthy({cond_r.expr})) \{\n"
      else
        out = out + "{p3}} else \{\n"
        out = out + cond_r.setup
        out = out + "{p3}if (gem_truthy({cond_r.expr})) \{\n"
      end
      out = out + "{pad_for(indent + 3)}{matched_tmp} = {i};\n"
    end
    for i = 0, len(arms)
      out = out + "{p3}}"
      if i < len(arms) - 1
        out = out + "\n"
      end
    end
    out = out + "\n"

    out = out + "{p3}if ({matched_tmp} >= 0) \{\n"
    let p4 = pad_for(indent + 3)
    out = out + "{p4}gem_mailbox_remove(&{proc_tmp}->mailbox, {prev_tmp}, {cur_tmp});\n"
    out = out + "{p4}break;\n"
    out = out + "{p3}}\n"

    out = out + "{p3}{prev_tmp} = {cur_tmp};\n"
    out = out + "{p3}{cur_tmp} = {cur_tmp}->next;\n"
    out = out + "{p2}}\n"

    out = out + "{p2}if ({matched_tmp} >= 0) break;\n"
    if after_ms != nil
      out = out + "{p2}if (gem_now_ms() >= {deadline_tmp}) \{\n"
      out = out + "{p2}    {matched_tmp} = -2;\n"
      out = out + "{p2}    break;\n"
      out = out + "{p2}}\n"
      out = out + "{p2}gem_selective_yield({deadline_tmp});\n"
      out = out + "{p2}if ({proc_tmp}->timed_out) \{\n"
      out = out + "{p2}    {matched_tmp} = -2;\n"
      out = out + "{p2}    break;\n"
      out = out + "{p2}}\n"
    else
      out = out + "{p2}gem_selective_yield(-1);\n"
    end

    out = out + "{p}}\n"

    # Dispatch with return
    for i = 0, len(arms)
      let arm = arms[i]
      if i == 0
        out = out + "{p}if ({matched_tmp} == {i}) \{\n"
      else
        out = out + "{p}} else if ({matched_tmp} == {i}) \{\n"
      end
      if arm.pattern.bindings != nil
        for b in arm.pattern.bindings
          out = out + compile_stmt(b, indent + 1) + "\n"
        end
      end
      let body = arm.body
      if len(body) > 0
        for j = 0, len(body) - 1
          out = out + compile_stmt(body[j], indent + 1) + "\n"
        end
        out = out + compile_stmt_return(body[len(body) - 1], indent + 1) + "\n"
      else
        out = out + "{p}    gem_pop_frame();\n{p}    return GEM_NIL;\n"
      end
    end

    if after_ms != nil
      out = out + "{p}} else if ({matched_tmp} == -2) \{\n"
      if after_body != nil and len(after_body) > 0
        for j = 0, len(after_body) - 1
          out = out + compile_stmt(after_body[j], indent + 1) + "\n"
        end
        out = out + compile_stmt_return(after_body[len(after_body) - 1], indent + 1) + "\n"
      else
        out = out + "{p}    gem_pop_frame();\n{p}    return GEM_NIL;\n"
      end
    else
      out = out + "{p}} else \{\n"
      out = out + "{p}    gem_pop_frame();\n{p}    return GEM_NIL;\n"
    end

    out = out + "{p}}"
    out
  end

  # ─── compile_extern_fn ──

  compile_extern_fn = fn(node)
    let {name, params, ret_type} = node

    let lines = "static GemVal gem_fn_{name}(void *_env, GemVal *args, int argc) \{\n"

    let c_args = []
    for i = 0, len(params)
      let p = params[i]
      let ptype = p["type"]
      if ptype == "Int"
        lines = lines + "    int64_t _p{i} = args[{i}].ival;\n"
        push(c_args, "_p{i}")
      elif ptype == "Float"
        lines = lines + "    double _p{i} = args[{i}].fval;\n"
        push(c_args, "_p{i}")
      elif ptype == "String"
        lines = lines + "    char* _p{i} = args[{i}].sval;\n"
        push(c_args, "_p{i}")
      elif ptype == "Bool"
        lines = lines + "    int _p{i} = args[{i}].bval;\n"
        push(c_args, "_p{i}")
      elif ptype == "Ptr"
        lines = lines + "    void* _p{i} = (void*)(intptr_t)args[{i}].ival;\n"
        push(c_args, "_p{i}")
      elif ptype == "Table"
        push(c_args, "args[{i}]")
      else
        push(c_args, "args[{i}]")
      end
    end

    # Build call arg list
    let call_args = ""
    for i = 0, len(c_args)
      if i > 0
        call_args = call_args + ", "
      end
      call_args = call_args + c_args[i]
    end

    let call_expr = "{name}({call_args})"

    if ret_type == "Nil"
      lines = lines + "    {call_expr};\n"
      lines = lines + "    return GEM_NIL;\n"
    elif ret_type == "Table"
      lines = lines + "    return {call_expr};\n"
    elif ret_type == "Int"
      lines = lines + "    int64_t _ret = {call_expr};\n"
      lines = lines + "    return gem_int(_ret);\n"
    elif ret_type == "Float"
      lines = lines + "    double _ret = {call_expr};\n"
      lines = lines + "    return gem_float(_ret);\n"
    elif ret_type == "String"
      lines = lines + "    char* _ret = {call_expr};\n"
      lines = lines + "    return gem_string(_ret);\n"
    elif ret_type == "Bool"
      lines = lines + "    int _ret = {call_expr};\n"
      lines = lines + "    return gem_bool(_ret);\n"
    elif ret_type == "Ptr"
      lines = lines + "    void *_ret = {call_expr};\n"
      lines = lines + "    GemVal _r; _r.type = VAL_INT; _r.ival = (int64_t)(intptr_t)_ret; return _r;\n"
    else
      lines = lines + "    {call_expr};\n"
      lines = lines + "    return GEM_NIL;\n"
    end

    lines = lines + "}"

    # Add forward declaration for the Gem wrapper
    push(forward_decls, "static GemVal gem_fn_{name}(void *_env, GemVal *args, int argc);")

    # Auto-generate C forward declaration for the extern function
    let c_ret = "void"
    if ret_type == "Int"
      c_ret = "int64_t"
    elif ret_type == "Float"
      c_ret = "double"
    elif ret_type == "String"
      c_ret = "char*"
    elif ret_type == "Bool"
      c_ret = "int"
    elif ret_type == "Ptr"
      c_ret = "void*"
    elif ret_type == "Table"
      c_ret = "GemVal"
    end

    let c_params = ""
    if len(params) == 0
      c_params = "void"
    else
      for i = 0, len(params)
        if i > 0
          c_params = c_params + ", "
        end
        let pt = params[i]["type"]
        if pt == "Int"
          c_params = c_params + "int64_t"
        elif pt == "Float"
          c_params = c_params + "double"
        elif pt == "String"
          c_params = c_params + "const char*"
        elif pt == "Bool"
          c_params = c_params + "int"
        elif pt == "Ptr"
          c_params = c_params + "void*"
        elif pt == "Table"
          c_params = c_params + "GemVal"
        else
          c_params = c_params + "GemVal"
        end
      end
    end

    push(extern_c_decls, "{c_ret} {name}({c_params});")

    lines
  end

  # ─── emit_param_bindings: generate C code to bind params, rest, block ──

  let emit_param_bindings = fn(node, params, cap_set)
    let out = ""
    # Bind required parameters
    for i = 0, len(params)
      let mp = mangle(params[i])
      if set_contains(cap_set, params[i])
        out = out + "    GemVal *{mp} = GC_MALLOC(sizeof(GemVal));\n"
        out = out + "    *{mp} = (argc > {i}) ? args[{i}] : GEM_NIL;\n"
      else
        out = out + "    GemVal {mp} = (argc > {i}) ? args[{i}] : GEM_NIL;\n"
      end
    end

    # Bind rest param: pack args[N .. argc-end_count-1] into an array
    if node.rest_param != nil
      let N = len(params)
      let end_count = 0
      if node.block_param != nil
        end_count = 1
      end
      let mp_rest = mangle(node.rest_param)
      if set_contains(cap_set, node.rest_param)
        out = out + "    GemVal *{mp_rest} = GC_MALLOC(sizeof(GemVal));\n"
        out = out + "    *{mp_rest} = gem_table_new();\n"
        out = out + "    for (int _ri = {N}; _ri < argc - {end_count}; _ri++) gem_table_set(*{mp_rest}, gem_int(_ri - {N}), args[_ri]);\n"
      else
        out = out + "    GemVal {mp_rest} = gem_table_new();\n"
        out = out + "    for (int _ri = {N}; _ri < argc - {end_count}; _ri++) gem_table_set({mp_rest}, gem_int(_ri - {N}), args[_ri]);\n"
      end
      if node.block_param != nil
        let mp_block = mangle(node.block_param)
        if set_contains(cap_set, node.block_param)
          out = out + "    GemVal *{mp_block} = GC_MALLOC(sizeof(GemVal));\n"
          out = out + "    *{mp_block} = (argc > 0) ? args[argc - 1] : GEM_NIL;\n"
        else
          out = out + "    GemVal {mp_block} = (argc > 0) ? args[argc - 1] : GEM_NIL;\n"
        end
      end
    end
    out
  end

  # ─── emit_fn_body: compile body stmts with implicit return ──

  let emit_fn_body = fn(body)
    let out = ""
    if len(body) > 0
      for i = 0, len(body) - 1
        out = out + compile_stmt(body[i], 1) + "\n"
      end
      out = out + compile_stmt_return(body[len(body) - 1], 1) + "\n"
    else
      out = out + "    gem_pop_frame();\n    return GEM_NIL;\n"
    end
    out
  end

  # ─── compile_fn ──

  compile_fn = fn(node)
    let {params, body, name} = node

    # Determine which variables are captured by nested closures
    let scope_vars = sorted_array_to_set(params)
    if node.rest_param != nil
      set_add(scope_vars, node.rest_param)
    end
    if node.block_param != nil
      set_add(scope_vars, node.block_param)
    end
    collect_top_let_names(body, scope_vars)
    let captured = find_captured_in_scope(body, scope_vars)

    let saved_boxed = boxed_vars
    let saved_top = in_top_level
    boxed_vars = captured
    in_top_level = false

    let lines = "static GemVal gem_fn_{name}(void *_env, GemVal *args, int argc) \{\n"

    # Emit #line for function start
    if node.line != nil
      lines = lines + "#line {node.line} \"{escape_c_string(source_name)}\"\n"
    end

    lines = lines + emit_param_bindings(node, params, captured)

    let fn_line = 0
    if node.line != nil
      fn_line = node.line
    end
    lines = lines + "    gem_push_frame(\"{escape_c_string(name)}\", \"{escape_c_string(source_name)}\", {fn_line});\n"

    lines = lines + emit_fn_body(body)

    lines = lines + "}"
    boxed_vars = saved_boxed
    in_top_level = saved_top
    lines
  end

  # ─── compile_closure_fn ──

  compile_closure_fn = fn(node, captures)
    let {params, body} = node
    let name = anon_name()

    # Find which vars inside THIS closure are captured by nested closures
    let inner_scope = sorted_array_to_set(params)
    if node.rest_param != nil
      set_add(inner_scope, node.rest_param)
    end
    if node.block_param != nil
      set_add(inner_scope, node.block_param)
    end
    collect_top_let_names(body, inner_scope)
    let inner_captured = find_captured_in_scope(body, inner_scope)

    let saved_boxed = boxed_vars
    let saved_top = in_top_level
    boxed_vars = set_union(inner_captured, sorted_array_to_set(captures))
    in_top_level = false

    # Generate struct
    let struct_name = "_closure_{name}"
    let struct_def = "struct {struct_name} \{\n"
    for cap in captures
      struct_def = struct_def + "    GemVal *{mangle(cap)};\n"
    end
    struct_def = struct_def + "};\n"

    # Generate function
    let lines = "static GemVal {name}(void *_env, GemVal *args, int argc) \{\n"
    if len(captures) > 0
      lines = lines + "    struct {struct_name} *_cls = (struct {struct_name} *)_env;\n"
      for cap in captures
        let mc = mangle(cap)
        lines = lines + "    GemVal *{mc} = _cls->{mc};\n"
      end
    end

    lines = lines + emit_param_bindings(node, params, inner_captured)

    lines = lines + "    gem_push_frame(\"{escape_c_string(name)}\", \"{escape_c_string(source_name)}\", 0);\n"

    lines = lines + emit_fn_body(body)

    lines = lines + "}"
    boxed_vars = saved_boxed
    in_top_level = saved_top

    # Add struct + function to functions list
    push(functions, struct_def + lines)

    {fn_name: name, struct_name: struct_name, captures: captures}
  end

  # ─── compile (top-level) ──

  let compile = fn(ast)
    # Separate different statement types
    let fn_defs = []
    let extern_fns_list = []
    let extern_includes = []
    let top_stmts = []

    for s in ast.stmts
      if s.tag == "fn_def"
        push(fn_defs, s)
      elif s.tag == "extern_fn"
        push(extern_fns_list, s)
      elif s.tag == "extern_include"
        push(extern_includes, s)
      else
        push(top_stmts, s)
      end
    end

    # Register extern fns as defined (callable)
    for ef in extern_fns_list
      set_add(defined_fns, ef.name)
    end

    # Forward declarations for user-defined functions
    for fd in fn_defs
      set_add(defined_fns, fd.name)
      let decl = "static GemVal gem_fn_{fd.name}(void *_env, GemVal *args, int argc);"
      push(forward_decls, decl)
    end

    # Collect top-level variable names and compute which are captured
    collect_top_let_names(top_stmts, top_level_vars)
    top_level_boxed = find_captured_in_scope(top_stmts, {})

    # Emit extern fn wrappers
    for ef in extern_fns_list
      push(functions, compile_extern_fn(ef))
    end

    # Emit function definitions
    for fd in fn_defs
      push(functions, compile_fn(fd))
    end

    # Build main
    let saved_boxed = boxed_vars
    boxed_vars = top_level_boxed
    in_top_level = true
    let main_body = compile_stmts(top_stmts, 1)
    in_top_level = false
    boxed_vars = saved_boxed

    let has_main = false
    for fd in fn_defs
      if fd.name == "main"
        has_main = true
      end
    end

    let main_c = "int main(void) \{\n"
    main_c = main_c + "    gem_push_frame(\"main\", \"{escape_c_string(source_name)}\", 0);\n"
    if main_body != ""
      main_c = main_c + main_body
    end
    if has_main
      main_c = main_c + "    GemVal _margs[1] = \{GEM_NIL};\n"
      main_c = main_c + "    gem_fn_main(NULL, _margs, 0);\n"
    end
    main_c = main_c + "    gem_run_scheduler();\n"
    main_c = main_c + "    gem_pop_frame();\n    return 0;\n}\n"


    # Assemble
    let out = ""
    for ei in extern_includes
      out = out + "#include \"{ei.path}\"\n"
    end
    out = out + "#include \"gem.h\"\n"

    # Extern C forward declarations (auto-generated from extern fn signatures)
    # Skip when extern include is present — the user manages declarations via headers
    if len(extern_includes) == 0
      for i = 0, len(extern_c_decls)
        out = out + extern_c_decls[i] + "\n"
      end
    end

    # Forward declarations
    for i = 0, len(forward_decls)
      out = out + forward_decls[i]
      if i < len(forward_decls) - 1
        out = out + "\n"
      end
    end
    out = out + "\n"

    # Top-level variable globals
    let tlv_keys = keys(top_level_vars)
    for i = 0, len(tlv_keys)
      let vname = tlv_keys[i]
      if set_contains(top_level_boxed, vname)
        out = out + "GemVal *gem_v_{vname};\n"
      else
        out = out + "GemVal gem_v_{vname};\n"
      end
    end
    out = out + "\n"

    # Functions
    for i = 0, len(functions)
      out = out + functions[i]
      if i < len(functions) - 1
        out = out + "\n\n"
      end
    end
    out = out + "\n\n"

    out = out + main_c
    out
  end

  {compile: compile}
end

# Bootstrap fallback: old stage0 doesn't know str_replace is a builtin.
# The new compiler treats calls to str_replace as direct builtin calls and
# never invokes this function body. It exists so stage0 can compile this file.
fn str_replace(s, old, new_s)
  let result = ""
  let i = 0
  let old_len = len(old)
  let s_len = len(s)
  while i < s_len
    if i + old_len <= s_len
      let found = true
      let j = 0
      while j < old_len
        if s[i + j] != old[j]
          found = false
          break
        end
        j += 1
      end
      if found
        result = result + new_s
        i += old_len
        continue
      end
    end
    result = result + s[i]
    i += 1
  end
  result
end
