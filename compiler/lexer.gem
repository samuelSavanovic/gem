# Lexer — hand-written scanner for Gem source code.
# Takes a source string, returns a flat array of token tables:
#   {type: "NUMBER", value: "42", line: 3}
#
# Token types: NUMBER, STRING, NAME, NEWLINE, EOF,
# keywords (fn, end, let, if, else, while, return, break, continue,
#   do, match, when, and, or, not, true, false, nil, load, extern),
# operators (+, -, *, /, %, ==, !=, <=, >=, <, >, =, +=, -=, *=, /=, ->),
# punctuation ( ( ) [ ] { } . , : | )

# ─── Character classification (range checks, no lookup tables) ──

fn is_digit(ch)
  ch >= "0" and ch <= "9"
end

fn is_alpha(ch)
  (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z") or ch == "_"
end

fn is_alnum(ch)
  is_alpha(ch) or is_digit(ch)
end

# ─── Number conversion helpers ───────────────────────────────────

fn digit_val(ch)
  match ch
  when "0"
    0
  when "1"
    1
  when "2"
    2
  when "3"
    3
  when "4"
    4
  when "5"
    5
  when "6"
    6
  when "7"
    7
  when "8"
    8
  when "9"
    9
  else
    error("not a digit: " + ch)
  end
end

fn str_to_int(s)
  let result = 0
  let i = 0
  while i < len(s)
    result = result * 10 + digit_val(s[i])
    i += 1
  end
  result
end

extern fn atof(s: String) -> Float

fn contains_dot(s)
  let i = 0
  while i < len(s)
    if s[i] == "."
      return true
    end
    i += 1
  end
  false
end

# ─── Tokenizer ───────────────────────────────────────────────────

fn build_keyword_set()
  let t = {}
  t["fn"] = true
  t["end"] = true
  t["let"] = true
  t["if"] = true
  t["else"] = true
  t["while"] = true
  t["return"] = true
  t["break"] = true
  t["continue"] = true
  t["do"] = true
  t["match"] = true
  t["when"] = true
  t["and"] = true
  t["or"] = true
  t["not"] = true
  t["true"] = true
  t["false"] = true
  t["nil"] = true
  t["load"] = true
  t["extern"] = true
  t
end

fn tokenize(source)
  let kw = build_keyword_set()
  let tokens = []
  let pos = 0
  let line = 1
  let length = len(source)
  let count = 0

  while pos < length
    let ch = source[pos]

    # Skip whitespace (spaces/tabs, NOT newlines)
    if ch == " " or ch == "\t"
      pos += 1
      continue
    end

    # Skip comments (# to end of line)
    if ch == "#"
      while pos < length
        if source[pos] == "\n"
          break
        end
        pos += 1
      end
      continue
    end

    # Newlines and semicolons — collapse consecutive
    if ch == "\n" or ch == ";"
      let should_add = true
      if count > 0
        if tokens[count - 1].type == "NEWLINE"
          should_add = false
        end
      end
      if should_add
        tokens[count] = {type: "NEWLINE", value: "\n", line: line}
        count += 1
      end
      if ch == "\n"
        line += 1
      end
      pos += 1
      # Skip additional newlines, semicolons, whitespace, comments
      while pos < length
        let c2 = source[pos]
        if c2 == "\n"
          line += 1
          pos += 1
        else
          if c2 == ";" or c2 == " " or c2 == "\t"
            pos += 1
          else
            if c2 == "#"
              while pos < length
                if source[pos] == "\n"
                  break
                end
                pos += 1
              end
            else
              break
            end
          end
        end
      end
      continue
    end

    # Numbers
    if is_digit(ch)
      let val = ""
      while pos < length
        if not is_digit(source[pos])
          break
        end
        val = val + source[pos]
        pos += 1
      end
      let has_dot = false
      if pos < length
        if source[pos] == "."
          has_dot = true
        end
      end
      if has_dot
        val = val + "."
        pos += 1
        while pos < length
          if not is_digit(source[pos])
            break
          end
          val = val + source[pos]
          pos += 1
        end
      end
      tokens[count] = {type: "NUMBER", value: val, line: line}
      count += 1
      continue
    end

    # Strings
    if ch == "\""
      pos += 1
      let val = ""
      while pos < length
        if source[pos] == "\""
          break
        end
        if source[pos] == "\\"
          pos += 1
          if pos >= length
            error("unterminated string escape at line " + to_string(line))
          end
          let esc = source[pos]
          match esc
          when "n"
            val = val + "\n"
          when "t"
            val = val + "\t"
          when "\\"
            val = val + "\\"
          when "\""
            val = val + "\""
          else
            val = val + "\\" + esc
          end
        else
          val = val + source[pos]
        end
        pos += 1
      end
      if pos >= length
        error("unterminated string at line " + to_string(line))
      end
      pos += 1
      tokens[count] = {type: "STRING", value: val, line: line}
      count += 1
      continue
    end

    # Names and keywords
    if is_alpha(ch)
      let val = ""
      while pos < length
        if not is_alnum(source[pos])
          break
        end
        val = val + source[pos]
        pos += 1
      end
      if kw[val] == true
        tokens[count] = {type: val, value: val, line: line}
      else
        tokens[count] = {type: "NAME", value: val, line: line}
      end
      count += 1
      continue
    end

    # Multi-char operators (check before single-char)
    let next = ""
    if pos + 1 < length
      next = source[pos + 1]
    end

    if ch == "=" and next == "="
      tokens[count] = {type: "==", value: "==", line: line}
      count += 1
      pos += 2
      continue
    end
    if ch == "!" and next == "="
      tokens[count] = {type: "!=", value: "!=", line: line}
      count += 1
      pos += 2
      continue
    end
    if ch == "<" and next == "="
      tokens[count] = {type: "<=", value: "<=", line: line}
      count += 1
      pos += 2
      continue
    end
    if ch == ">" and next == "="
      tokens[count] = {type: ">=", value: ">=", line: line}
      count += 1
      pos += 2
      continue
    end
    if ch == "+" and next == "="
      tokens[count] = {type: "+=", value: "+=", line: line}
      count += 1
      pos += 2
      continue
    end
    if ch == "-" and next == "="
      tokens[count] = {type: "-=", value: "-=", line: line}
      count += 1
      pos += 2
      continue
    end
    if ch == "*" and next == "="
      tokens[count] = {type: "*=", value: "*=", line: line}
      count += 1
      pos += 2
      continue
    end
    if ch == "/" and next == "="
      tokens[count] = {type: "/=", value: "/=", line: line}
      count += 1
      pos += 2
      continue
    end
    if ch == "-" and next == ">"
      tokens[count] = {type: "->", value: "->", line: line}
      count += 1
      pos += 2
      continue
    end

    # Single-char operators and punctuation
    if ch == "+" or ch == "-" or ch == "*" or ch == "/" or ch == "%"
      tokens[count] = {type: ch, value: ch, line: line}
      count += 1
      pos += 1
      continue
    end
    if ch == "<" or ch == ">" or ch == "="
      tokens[count] = {type: ch, value: ch, line: line}
      count += 1
      pos += 1
      continue
    end
    if ch == "(" or ch == ")" or ch == "[" or ch == "]" or ch == "{" or ch == "}"
      tokens[count] = {type: ch, value: ch, line: line}
      count += 1
      pos += 1
      continue
    end
    if ch == "." or ch == "," or ch == ":" or ch == "|"
      tokens[count] = {type: ch, value: ch, line: line}
      count += 1
      pos += 1
      continue
    end

    error("unexpected character: '" + ch + "' at line " + to_string(line))
  end

  tokens[count] = {type: "EOF", value: "", line: line}
  tokens
end
