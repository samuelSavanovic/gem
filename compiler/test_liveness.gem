# Liveness validation gate: for every TCO-eligible function in std/ and
# examples/, run compute_loop_live_at_backedge on the function's body treated as
# the body of a `while true` loop, and compare the resulting live set to the
# function's parameter set.
#
# Hard gate: missing-params (a param that the recursive tail-call path uses
# but liveness misses) is a soundness bug. Extra entries in the live set
# beyond params (function names, top-level globals, builtins) are filtered
# out — codegen handles those separately.
#
# Usage:
#   ./build/gem compiler/test_liveness.gem --run

load "../std/string"
load "parser" (parse_source)
load "liveness" (compute_loop_live_at_backedge, liveness_has_self_tail_call, sorted_params_to_set)

let install_root = dirname(dirname(argv()[0]))

# ─── File walk ────────────────────────────────────────────────

fn walk_gem_files(dir, into)
  if not is_dir(dir)
    return nil
  end
  let entries = list_dir(dir)
  for e in entries
    let full = path_join(dir, e)
    if is_dir(full)
      walk_gem_files(full, into)
    elif string.ends_with(e, ".gem")
      push(into, full)
    end
  end
end

# ─── TCO-eligibility (mirrors codegen.gem) ────────────────────

fn has_any_default(node)
  if node.defaults == nil
    return false
  end
  for d in node.defaults
    if d != nil
      return true
    end
  end
  false
end

fn collect_top_let_names(stmts, into)
  for s in stmts
    if type(s) == "table" and s.tag == "let"
      into[s.name] = true
    end
    if type(s) == "table" and s.tag == "block"
      for inner in s.stmts
        if type(inner) == "table" and inner.tag == "let"
          into[inner.name] = true
        end
      end
    end
  end
end

fn is_tco_eligible(fn_node)
  if fn_node.rest_param != nil
    return false
  end
  if has_any_default(fn_node)
    return false
  end
  let scope = sorted_params_to_set(fn_node.params)
  collect_top_let_names(fn_node.body, scope)
  if scope[fn_node.name] == true
    return false
  end
  liveness_has_self_tail_call(fn_node.name, fn_node.body)
end

# ─── Synthesize a `while true` from fn body ───────────────────

fn synth_while_true_node(body)
  {tag: "while", cond: {tag: "bool", value: true}, body: body, line: 0}
end

fn set_to_sorted_array(s)
  let arr = []
  for k, _ in s
    push(arr, k)
  end
  sort(arr)
  arr
end

fn set_diff(a, b)
  let r = {}
  for k, _ in a
    if b[k] != true
      r[k] = true
    end
  end
  r
end

fn set_size(s)
  let n = 0
  for k, _ in s
    n += 1
  end
  n
end

# ─── Driver state ────────────────────────────────────────────

let pass_count = 0
let fail_count = 0
let refused_count = 0
let skipped_count = 0

fn check_fn(file, fn_node, params_set)
  let synth = synth_while_true_node(fn_node.body)
  let r = compute_loop_live_at_backedge(synth, {})
  if not r.ok
    eprint("REFUSED  {file}:{fn_node.line} fn `{fn_node.name}`: {r.reason}\n")
    refused_count += 1
    return nil
  end
  let live = r.live
  let missing = set_diff(params_set, live)
  let extra = set_diff(live, params_set)

  if set_size(missing) > 0
    let missing_str = string.join(set_to_sorted_array(missing), ", ")
    let params_str = string.join(set_to_sorted_array(params_set), ", ")
    let live_str = string.join(set_to_sorted_array(live), ", ")
    eprint("FAIL     {file}:{fn_node.line} fn `{fn_node.name}`: missing params {missing_str}\n")
    eprint("         params: {params_str}\n")
    eprint("         live:   {live_str}\n")
    fail_count += 1
    return nil
  end

  if set_size(extra) > 0
    # Informational. extras are typically fn names and globals — codegen
    # filters those. Print only first time per file for noise control.
    let extra_str = string.join(set_to_sorted_array(extra), ", ")
    let params_str = string.join(set_to_sorted_array(params_set), ", ")
    eprint("INFO     {file}:{fn_node.line} fn `{fn_node.name}`: live ⊇ params, extras: {extra_str} (params: {params_str})\n")
  end
  pass_count += 1
end

fn check_file(file)
  let read_r = pcall read_file(file)
  if not read_r.ok
    skipped_count += 1
    return nil
  end
  let source = read_r.value

  let parse_r = pcall parse_source(source, file)
  if not parse_r.ok
    eprint("SKIP     {file}: parse error: {parse_r.error}\n")
    skipped_count += 1
    return nil
  end
  let ast = parse_r.value
  for s in ast.stmts
    if type(s) == "table" and s.tag == "fn_def"
      if is_tco_eligible(s)
        let params_set = sorted_params_to_set(s.params)
        check_fn(file, s, params_set)
      end
    end
  end
end

# ─── Negative tests ──────────────────────────────────────────
# Parse tiny synthetic loop bodies, run liveness, assert the live
# set EXCLUDES variables that should be dead. Catches "mark
# everything live" regressions that the param-superset check misses.

fn first_while_in(stmts)
  for s in stmts
    if type(s) == "table" and s.tag == "while"
      return s
    end
    if type(s) == "table" and s.tag == "fn_def"
      let inner = first_while_in(s.body)
      if inner != nil
        return inner
      end
    end
  end
  nil
end

let neg_pass = 0
let neg_fail = 0

fn neg_assert(label, src, must_have, must_miss)
  let pr = pcall parse_source(src, "<neg:{label}>")
  if not pr.ok
    eprint("NEG-FAIL {label}: parse error\n")
    neg_fail += 1
    return nil
  end
  let w = first_while_in(pr.value.stmts)
  if w == nil
    eprint("NEG-FAIL {label}: no while node\n")
    neg_fail += 1
    return nil
  end
  let r = compute_loop_live_at_backedge(w, {})
  if not r.ok
    eprint("NEG-FAIL {label}: liveness refused: {r.reason}\n")
    neg_fail += 1
    return nil
  end
  for n in must_have
    if r.live[n] != true
      eprint("NEG-FAIL {label}: expected `{n}` live, was not\n")
      neg_fail += 1
      return nil
    end
  end
  for n in must_miss
    if r.live[n] == true
      let live_str = string.join(set_to_sorted_array(r.live), ", ")
      eprint("NEG-FAIL {label}: expected `{n}` dead, was live (live: {live_str})\n")
      neg_fail += 1
      return nil
    end
  end
  neg_pass += 1
end

# Dead local: defined and used inside one iteration only.
neg_assert("dead-local",
  "fn f(state)\n  while true\n    let dead = state + 1\n    let used = dead\n    state = used\n  end\nend\n",
  ["state"],
  ["dead", "used"])

# Killed-then-redefined: var assigned before any read.
neg_assert("killed-no-read",
  "fn f(x)\n  let y = 0\n  while true\n    y = 1\n    x = y + x\n  end\nend\n",
  ["x"],
  ["y"])

# Truly dead var never read across back-edge.
neg_assert("write-only",
  "fn f(state)\n  while true\n    let scratch = 99\n    state = state + 1\n  end\nend\n",
  ["state"],
  ["scratch"])

# Spawn-arg closure: captures are deep-copied at the spawn call site, so
# they don't need to bubble across the loop back-edge. The capture (`fd`)
# is killed by the local `let fd = ...` above the spawn and must NOT be
# in the live-at-back-edge set. `server_fd` is read every iteration so
# remains live.
neg_assert("spawn-closure-capture-dead",
  "fn accept_loop(server_fd)\n  while true\n    let fd = server_fd + 1\n    spawn(fn()\n      let x = fd + 1\n      x\n    end)\n  end\nend\n",
  ["server_fd"],
  ["fd"])

# Same shape, spawn_link.
neg_assert("spawn_link-closure-capture-dead",
  "fn accept_loop(server_fd)\n  while true\n    let fd = server_fd + 1\n    spawn_link(fn()\n      let x = fd + 1\n      x\n    end)\n  end\nend\n",
  ["server_fd"],
  ["fd"])

# Counter-case: a closure NOT passed to spawn (here, assigned to an outer
# var that escapes the loop) must still bubble its captures across the
# back-edge — that's the over-approximation we deliberately keep. Without
# bubbling, `arg` would be killed by `arg = 99` and reported dead.
neg_assert("non-spawn-closure-still-bubbles",
  "fn f(arg)\n  let h = nil\n  while true\n    arg = 99\n    h = fn() arg + 1 end\n  end\nend\n",
  ["arg"],
  [])

# Arm-merged let after the lift pre-pass: `let next = nil` hoisted before
# the if; arm bodies become assigns. Liveness must see `carry` as the only
# live param across the back-edge — `next` is killed by the consuming
# `carry = next` assign, then re-defined inside both arms.
neg_assert("arm-merged-lift-shape",
  "fn f(carry)\n  while true\n    let next = nil\n    if carry == 0\n      next = 1\n    else\n      next = 2\n    end\n    carry = next\n  end\nend\n",
  ["carry"],
  ["next"])

# ─── Post-loop liveness (3a) ──────────────────────────────────
# These exercise the parameterized worker `compute_loop_live_at_backedge`,
# which accepts a synthesized post-loop set. Drives the post-loop union path
# directly without depending on a surrounding fn body's structure.

fn neg_assert_with_post(label, src, post_loop_arr, must_have, must_miss)
  let pr = pcall parse_source(src, "<neg:{label}>")
  if not pr.ok
    eprint("NEG-FAIL {label}: parse error\n")
    neg_fail += 1
    return nil
  end
  let w = first_while_in(pr.value.stmts)
  if w == nil
    eprint("NEG-FAIL {label}: no while node\n")
    neg_fail += 1
    return nil
  end
  let post = {}
  for n in post_loop_arr
    post[n] = true
  end
  let r = compute_loop_live_at_backedge(w, post)
  if not r.ok
    eprint("NEG-FAIL {label}: liveness refused: {r.reason}\n")
    neg_fail += 1
    return nil
  end
  for n in must_have
    if r.live[n] != true
      eprint("NEG-FAIL {label}: expected `{n}` live, was not\n")
      neg_fail += 1
      return nil
    end
  end
  for n in must_miss
    if r.live[n] == true
      let live_str = string.join(set_to_sorted_array(r.live), ", ")
      eprint("NEG-FAIL {label}: expected `{n}` dead, was live (live: {live_str})\n")
      neg_fail += 1
      return nil
    end
  end
  neg_pass += 1
end

# `while true` with break + non-empty post-loop set: post_var must transfer
# through the back-edge so the rescue covers reads after the loop exits.
neg_assert_with_post("break-exits-with-post-loop-set",
  "fn f(state)\n  while true\n    if state == 0\n      break\n    end\n    state = state + 1\n  end\nend\n",
  ["post_var"],
  ["state", "post_var"],
  [])

# `while true` with break + empty post-loop set: vars assigned only in the
# break-taking arm (and never read afterwards) must not be live at back-edge.
neg_assert_with_post("break-with-no-post-use",
  "fn f(state)\n  while true\n    if state == 0\n      let dead = 99\n      break\n    end\n    state = state + 1\n  end\nend\n",
  [],
  ["state"],
  ["dead"])

# `while cond` (non-true cond): cond's free vars live across back-edge, since
# the cond is re-evaluated each iteration. With post-reachable propagation
# enabled even when the post-loop set is empty.
neg_assert_with_post("while-cond-tagged",
  "fn f(running, x)\n  while running\n    x = x + 1\n  end\nend\n",
  [],
  ["running", "x"],
  [])

print("Negative tests: PASS={neg_pass} FAIL={neg_fail}")
if neg_fail > 0
  print("Gate FAILED — negative tests detected over-approximation regression.")
  exit(1)
end

let std_dir = path_join(install_root, "std")
let examples_dir = path_join(install_root, "examples")
let compiler_dir = path_join(install_root, "compiler")

let files = []
walk_gem_files(std_dir, files)
walk_gem_files(examples_dir, files)

print("Liveness validation gate: scanning {len(files)} .gem files")
for f in files
  check_file(f)
end

print("")
print("─── Results ─────────────────────────────────")
print("PASS:    {pass_count}")
print("FAIL:    {fail_count}")
print("REFUSED: {refused_count}")
print("SKIP:    {skipped_count}")

if fail_count > 0
  print("")
  print("Gate FAILED — see FAIL entries above. Liveness pass has soundness bugs (missing live params) — must fix before wiring to codegen.")
  exit(1)
end
print("")
print("Gate PASSED — every TCO function's params are reachable from the liveness result.")
