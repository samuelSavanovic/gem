# push builtin tests

# Basic push
let a = []
push(a, 10)
push(a, 20)
push(a, 30)
print(len(a))
print(a[0])
print(a[1])
print(a[2])

# Push returns the value
let v = push(a, 99)
print(v)

# Len after push
print(len(a))

# Push in a loop
let b = []
for i = 0, 5
  push(b, i * 10)
end
for item in b
  print(item)
end

# Push to empty array then iterate
let c = []
push(c, "hello")
push(c, "world")
for s in c
  print(s)
end
