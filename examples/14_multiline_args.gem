let add = fn(a, b)
  return a + b
end

let add3 = fn(a, b, c)
  return a + b + c
end

# Basic multi-line call
let x = add(
  10,
  20
)
print(x)

# Nested multi-line calls
let y = add(
  add(1, 2),
  add(
    3,
    4
  )
)
print(y)

# Single arg per line with three args
let z = add3(
  100,
  200,
  300
)
print(z)

# Newline after opening paren only
let w = add(
  5, 6)
print(w)

# Newline before closing paren only
let v = add(7, 8
)
print(v)
