# Edge case and adversarial tests for new builtins

# ─── delete edge cases ───
# delete all keys from a table
let d = {a: 1, b: 2}
delete(d, "a")
delete(d, "b")
print("delete all len:", len(d))

# delete same key twice
let d2 = {x: 10}
delete(d2, "x")
let r = delete(d2, "x")
print("delete twice:", r)

# ─── pop edge cases ───
# pop from error test
let ok = pcall pop([])
print("pop empty err:", ok.ok == false)

# pop preserves remaining elements
let a = [10, 20, 30]
pop(a)
print("pop preserve:", a[0], a[1])

# ──�� sort edge cases ───
# sort already sorted
let s = [1, 2, 3, 4, 5]
sort(s)
print("sort sorted:", s[0], s[1], s[2], s[3], s[4])

# sort reverse sorted
let r2 = [5, 4, 3, 2, 1]
sort(r2)
print("sort reverse:", r2[0], r2[1], r2[2], r2[3], r2[4])

# sort duplicates
let dups = [3, 1, 3, 2, 1]
sort(dups)
print("sort dups:", dups[0], dups[1], dups[2], dups[3], dups[4])

# sort large array
let big = []
for i = 0, 100
  push(big, random(1000))
end
sort(big)
let sorted_ok = true
for i = 1, len(big)
  if big[i] < big[i - 1]
    sorted_ok = false
  end
end
print("sort 100:", sorted_ok)

# ─── math edge cases ��──
print("floor 0.0:", floor(0.0))
print("ceil 0.0:", ceil(0.0))
print("round 0.0:", round(0.0))
print("abs min int:", abs(-1))

# pow with negative exponent
print("pow neg exp:", pow(2, -1))

# sqrt of 1
print("sqrt 1:", sqrt(1))

# sqrt error
let sqrt_err = pcall sqrt(-1)
print("sqrt neg:", sqrt_err.ok == false)

# ─── random edge cases ───
let r3 = random(1)
print("random 1:", r3 == 0)

# random error
let rand_err = pcall random(0)
print("random 0:", rand_err.ok == false)

let rand_err2 = pcall random(-5)
print("random neg:", rand_err2.ok == false)

# ─── insert/remove_at edge cases ───
# insert into empty
let empty = []
insert(empty, 0, "first")
print("insert empty:", empty[0])
print("insert empty len:", len(empty))

# remove_at to make empty
let one = [42]
remove_at(one, 0)
print("remove_at to empty:", len(one))

# insert/remove_at errors
let ins_err = pcall insert([], -1, "x")
print("insert neg idx:", ins_err.ok == false)

let ins_err2 = pcall insert([], 1, "x")
print("insert past end:", ins_err2.ok == false)

let rem_err = pcall remove_at([], 0)
print("remove_at empty:", rem_err.ok == false)

let rem_err2 = pcall remove_at([1, 2], 5)
print("remove_at oob:", rem_err2.ok == false)

# ─── getenv edge case ───
let ge_err = pcall getenv(42)
print("getenv non-str:", ge_err.ok == false)

# ─── append_file error ───
let af_err = pcall append_file("/nonexistent/dir/file.txt", "data")
print("append_file bad:", af_err.ok == false)

# ─── exit error cases ───
# exit with no args = exit(0), can't test without actually exiting
# just verify it exists as a function
print("exit type:", type(exit))

# ─── values on empty ───
let ev = values({})
print("values empty:", len(ev))

# ─── delete + has_key consistency ───
let t = {a: 1, b: 2, c: 3}
delete(t, "a")
print("delete consistency:", has_key(t, "a") == false and has_key(t, "b") == true and has_key(t, "c") == true)

# verify remaining values are accessible
let ks = keys(t)
let found_b = false
let found_c = false
for k in ks
  if t[k] == 2
    found_b = true
  end
  if t[k] == 3
    found_c = true
  end
end
print("delete access:", found_b and found_c)

print("ALL EDGE CASES PASSED")
