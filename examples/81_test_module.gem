load "std/test"

test.case("equality on primitives", fn()
  test.assert_eq(2 + 2, 4)
  test.assert_eq("a" + "b", "ab")
  test.assert_eq(true, true)
end)

test.case("inequality", fn()
  test.assert_neq(1, 2)
  test.assert_neq("a", "b")
end)

test.case("plain assert", fn()
  test.assert(1 < 2)
  test.assert("hello" != nil, "string should not be nil")
end)

test.case("assert_throws catches errors", fn()
  test.assert_throws(fn() error("boom") end)
end)

test.case("intentional failure", fn()
  test.assert_eq(1, 2)
end)

test.run()
