# Test std/log module

load "std/log"

# Default level is info - debug should be suppressed
log.debug("this should not appear")
log.info("info message")
log.warn("warn message")
log.error("error message")

# Change level to debug - all should appear
log.set_level("debug")
log.debug("debug after level change")

# Change level to error - only error should appear
log.set_level("error")
log.info("this should not appear")
log.warn("this should not appear either")
log.error("only errors now")

# Invalid level should be silently ignored
log.set_level("bogus")
log.error("still works after bogus set_level")

print("log test done")
