# std/math — math utilities for Gem

fn min(a, b)
  if a < b
    return a
  end
  b
end

fn max(a, b)
  if a > b
    return a
  end
  b
end

fn clamp(val, low, high)
  if val < low
    return low
  end
  if val > high
    return high
  end
  val
end

fn assert(cond, msg)
  if not cond
    if msg == nil
      error("assertion failed")
    else
      error("assertion failed: {msg}")
    end
  end
end

export min, max, clamp, assert
