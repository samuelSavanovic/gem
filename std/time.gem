# std/time — time formatting and utilities

fn now()
  epoch_ms()
end

fn format(ms, fmt)
  format_time(ms, fmt)
end

fn format_local(ms, fmt)
  format_time_local(ms, fmt)
end

fn http_date(ms = epoch_ms())
  format_time(ms, "%a, %d %b %Y %H:%M:%S GMT")
end

fn iso8601(ms = epoch_ms())
  format_time(ms, "%Y-%m-%dT%H:%M:%SZ")
end

fn date(ms = epoch_ms())
  format_time(ms, "%Y-%m-%d")
end

export now, format, format_local, http_date, iso8601, date
